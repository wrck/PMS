# Build stage
FROM node:18-alpine AS builder
WORKDIR /build
COPY pms-frontend/package*.json ./
RUN npm ci
COPY pms-frontend/ .
RUN npm run build

# Runtime stage
FROM nginx:alpine
COPY --from=builder /build/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
