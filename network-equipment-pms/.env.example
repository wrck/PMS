# MySQL 配置
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=pms
MYSQL_USER=pms
MYSQL_PASSWORD=changeme_pms
MYSQL_PORT=3306

# Redis 配置
REDIS_PASSWORD=changeme_redis
REDIS_PORT=6379

# 应用配置
SPRING_PROFILES_ACTIVE=prod
APP_ENCRYPT_KEY=Base64编码的32字节密钥

# 应用端口
BACKEND_PORT=8080
FRONTEND_PORT=80

# Mock 服务（可选）
MOCK_D365_PORT=8090
MOCK_FP_PORT=8091
MOCK_OA_PORT=8092

# 可观测性端口
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme_grafana
ALERTMANAGER_PORT=9093
JAEGER_UI_PORT=16686
JAEGER_GRPC_PORT=4317
JAEGER_HTTP_PORT=4318

# 集成外部系统
D365_API_BASE_URL=https://d365.example.com
D365_OAUTH_TOKEN_URL=https://d365.example.com/oauth2/token
D365_OAUTH_CLIENT_ID=your_client_id
D365_OAUTH_CLIENT_SECRET=your_client_secret

FP_API_BASE_URL=https://fp.example.com
FP_OAUTH_TOKEN_URL=https://fp.example.com/oauth2/token
FP_OAUTH_CLIENT_ID=your_client_id
FP_OAUTH_CLIENT_SECRET=your_client_secret

OA_API_BASE_URL=https://oa.example.com
OA_OAUTH_TOKEN_URL=https://oa.example.com/oauth2/token
OA_OAUTH_CLIENT_ID=your_client_id
OA_OAUTH_CLIENT_SECRET=your_client_secret

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_at_least_32_chars_long
