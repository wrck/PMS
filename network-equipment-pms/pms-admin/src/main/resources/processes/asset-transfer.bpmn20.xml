<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://flowable.org/bpmn">
  <process id="assetTransfer" name="资产转移流程" isExecutable="true">
    <documentation>Asset transfer workflow: source PM review then target PM review.
      SkipExpression auto-skips a task when its assignee equals the process initiator.
      Each review task has an exclusive gateway: approved continues, rejected goes to a
      terminate end event. OA task listener mirrors task create/complete to 致远 OA.</documentation>
    <startEvent id="startEvent" name="开始"/>
    <userTask id="fromPmReview" name="源PM审核"
              flowable:assignee="${fromPmUserId}"
              flowable:skipExpression="${assignee == initiator}">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${oaTaskListener}"/>
        <flowable:taskListener event="complete" delegateExpression="${oaTaskListener}"/>
      </extensionElements>
    </userTask>
    <exclusiveGateway id="fromPmDecisionGateway" name="源PM审核决定"/>
    <userTask id="toPmReview" name="目标PM审核"
              flowable:assignee="${toPmUserId}"
              flowable:skipExpression="${assignee == initiator}">
      <extensionElements>
        <flowable:taskListener event="create" delegateExpression="${oaTaskListener}"/>
        <flowable:taskListener event="complete" delegateExpression="${oaTaskListener}"/>
      </extensionElements>
    </userTask>
    <exclusiveGateway id="toPmDecisionGateway" name="目标PM审核决定"/>
    <endEvent id="endEvent" name="结束"/>
    <endEvent id="rejectedEnd" name="驳回终止">
      <terminateEventDefinition/>
    </endEvent>
    <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="fromPmReview"/>
    <sequenceFlow id="flow2" sourceRef="fromPmReview" targetRef="fromPmDecisionGateway"/>
    <sequenceFlow id="fromPmApproveFlow" sourceRef="fromPmDecisionGateway" targetRef="toPmReview">
      <conditionExpression>${approved}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="fromPmRejectFlow" sourceRef="fromPmDecisionGateway" targetRef="rejectedEnd">
      <conditionExpression>${!approved}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow3" sourceRef="toPmReview" targetRef="toPmDecisionGateway"/>
    <sequenceFlow id="toPmApproveFlow" sourceRef="toPmDecisionGateway" targetRef="endEvent">
      <conditionExpression>${approved}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="toPmRejectFlow" sourceRef="toPmDecisionGateway" targetRef="rejectedEnd">
      <conditionExpression>${!approved}</conditionExpression>
    </sequenceFlow>
  </process>
</definitions>
