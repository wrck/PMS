<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://flowable.org/bpmn">
  <process id="assetTransfer" name="资产转移流程" isExecutable="true">
    <documentation>Asset transfer workflow: source PM review then target PM review.</documentation>
    <startEvent id="startEvent" name="开始"/>
    <userTask id="fromPmReview" name="源PM审核" flowable:assignee="${fromPmUserId}"/>
    <userTask id="toPmReview" name="目标PM审核" flowable:assignee="${toPmUserId}"/>
    <endEvent id="endEvent" name="结束"/>
    <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="fromPmReview"/>
    <sequenceFlow id="flow2" sourceRef="fromPmReview" targetRef="toPmReview"/>
    <sequenceFlow id="flow3" sourceRef="toPmReview" targetRef="endEvent"/>
  </process>
</definitions>
