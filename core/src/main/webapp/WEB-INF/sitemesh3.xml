<sitemesh> 
	<!-- 装饰所有请求的页面 --> 
	<mapping path="/*" decorator="/common/main.jsp"/>  
	<!-- 首页不需要装饰 -->
	<mapping path="/index.jsp" exclue="true"/> 
	<mapping path="/login.html" exclue="true"/>   
	<mapping path="/base/*" exclue="true"/>
	<mapping path="/*/modals/*" exclue="true"/>  
	<mapping path="/export/*" exclue="true"/> 
	<mapping path="/druid/*" exclue="true"/>
	<mapping path="/modeler.html" exclue="true"/>
	<mapping path="/modeler/*" exclue="true"/>
	<mapping path="/editor-app/*" exclue="true"/>
	<mapping path="/VAADIN/*" exclue="true"/>
	<mapping path="/data/import.html" exclue="true"/>
	<mapping path="/data/import/*" exclue="true"/>
	<mapping path="/data/export.html" exclue="true"/>
	<mapping path="/data/export/*" exclue="true"/>
	<mapping path="/m/*" exclue="true"/>
	<mapping path="/*/login.html" exclue="true"/>
	<mapping path="/*/index.jsp" exclue="true"/>
	<mapping path="/app/download.html" exclue="true"/>
	
	<!-- 自定义 tag 规则 -->  
	<!-- Sitemesh 3 默认只提供了 body，title，head 等 tag 类型，我们可以通过实现 TagRuleBundle 扩展自定义的 tag 规则： -->  
	<content-processor>
	 <tag-rule-bundle class="com.dp.plat.core.tags.SiteMeshExtTagRuleBundle" />   
	</content-processor> 	
</sitemesh>