<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dp.plat.core.dao.SynchronizeMapper">

	<select id="selectSyncState" parameterType="string" resultType="map">
		select
		lastId,offset,lastSyncTime
		from t_sync_state
		where tableObject = #{tableObject}
	</select>

	<insert id="insertSyncState" parameterType="com.dp.plat.core.pojo.SyncState">
		insert into t_sync_state
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="id != null">
				id,
			</if>
			<if test="tableObject != null">
				tableObject,
			</if>
			<if test="lastId != null">
				lastId,
			</if>
			<if test="lastSyncTime != null">
				lastSyncTime,
			</if>
			<if test="offset != null">
				offset,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="id != null">
				#{id,jdbcType=INTEGER},
			</if>
			<if test="tableObject != null">
				#{tableObject,jdbcType=VARCHAR},
			</if>
			<if test="lastId != null">
				#{lastId,jdbcType=VARCHAR},
			</if>
			<if test="lastSyncTime != null">
				#{lastSyncTime,jdbcType=TIMESTAMP},
			</if>
			<if test="offset != null">
				#{offset,jdbcType=INTEGER},
			</if>
		</trim>
		ON DUPLICATE KEY UPDATE
		<trim suffixOverrides=",">
			<if test="lastId != null">
				lastId = #{lastId,jdbcType=VARCHAR},
			</if>
			<if test="lastSyncTime != null">
				lastSyncTime = #{lastSyncTime,jdbcType=TIMESTAMP},
			</if>
			<if test="offset != null">
				offset = #{offset,jdbcType=INTEGER},
			</if>
		</trim>
	</insert>

	<select id="clearSyncState">
		truncate table t_sync_state
	</select>

	<insert id="insertSyncLog" parameterType="com.dp.plat.core.pojo.SyncLog">
		insert into t_sync_log
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="id != null">
				id,
			</if>
			<if test="targetMethod != null">
				targetMethod,
			</if>
			<if test="tableObject != null">
				tableObject,
			</if>
			<if test="dataFrom != null">
				dataFrom,
			</if>
			<if test="dataTo != null">
				dataTo,
			</if>
			<if test="syncParams != null">
				syncParams,
			</if>
			<if test="syncStartTime != null">
				syncStartTime,
			</if>
			<if test="syncEndTime != null">
				syncEndTime,
			</if>
			<if test="isSuccess != null">
				isSuccess,
			</if>
			<if test="dataCount != null">
				dataCount,
			</if>
			<if test="syncType != null">
				syncType,
			</if>
			<if test="exception != null">
				exception,
			</if>
		</trim>
		<trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="id != null">
				#{id,jdbcType=INTEGER},
			</if>
			<if test="targetMethod != null">
				#{targetMethod,jdbcType=CHAR},
			</if>
			<if test="tableObject != null">
				#{tableObject,jdbcType=CHAR},
			</if>
			<if test="dataFrom != null">
				#{dataFrom,jdbcType=CHAR},
			</if>
			<if test="dataTo != null">
				#{dataTo,jdbcType=CHAR},
			</if>
			<if test="syncParams != null">
				#{syncParams,jdbcType=VARCHAR},
			</if>
			<if test="syncStartTime != null">
				#{syncStartTime,jdbcType=TIMESTAMP},
			</if>
			<if test="syncEndTime != null">
				#{syncEndTime,jdbcType=TIMESTAMP},
			</if>
			<if test="isSuccess != null">
				#{isSuccess,jdbcType=BIT},
			</if>
			<if test="dataCount != null">
				#{dataCount,jdbcType=INTEGER},
			</if>
			<if test="syncType != null">
				#{syncType,jdbcType=SMALLINT},
			</if>
			<if test="exception != null">
				#{exception,jdbcType=LONGVARCHAR},
			</if>
		</trim>
	</insert>

</mapper>
