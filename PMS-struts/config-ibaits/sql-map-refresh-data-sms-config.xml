        <![CDATA[
            INSERT INTO pm_project_property_from_sms(`orderExecNumber`,projectCode, projectName, `salesManCode`,`salesManName`,`marketCode`,`marketName`,`systemId`,
                `systemName`,`expendId`,`expendName`,`industryId`,`industryName`, officeCode, officeName, 
                serviceTypeName , channelName, engineeFee, objId, applyType, `corporationCode`, customerProjectName,
                finalCustomerName, agentName, majorProjectLevel, projectMoney, submitTime, predBidDate,
                linkmanName, linkmanTel
                )
            values
        ]]>
        <iterate conjunction="," property="list">
            (
             #list[].orderExecNumber# ,#list[].projectCode#, #list[].projectName#, #list[].salesManCode# ,#list[].salesManName# ,#list[].marketCode# ,#list[].marketName# ,#list[].systemId# ,
