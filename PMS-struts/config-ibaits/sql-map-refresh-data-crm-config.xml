    <update id="updatePmProjectTaskEventPlanDate" parameterClass="java.util.Map">
        <![CDATA[ 
        UPDATE pm_pb_plan_from_sms pps
		    INNER JOIN fnd_basic_data fbd
		    ON fbd.dataTypeCode = '09'
		        AND fbd.basicDataName = pps.referenceEventName
		        AND fbd.effectiveFrom <= NOW()
		        AND (fbd.effectiveTo > NOW()
		            OR fbd.effectiveTo IS NULL)
		    INNER JOIN pm_project_task pt
		    ON pt.taskTypeCode = fbd.dataTypeCode
		        AND pt.taskTypeId = fbd.basicDataId
		SET pt.eventPlanHappenDate = pps.eventPlanHappenDate, pt.visibleFlag = '1'
		WHERE pt.contractNo = pps.contractNo
            AND pt.effectiveFrom <= NOW() AND (pt.effectiveTo > NOW() OR pt.effectiveTo IS NULL) 
        ]]>
        <isNotEmpty prepend="AND" property="sourceDbName"> pps.dataSource = #sourceDbName#</isNotEmpty>
    </update>
    
    
