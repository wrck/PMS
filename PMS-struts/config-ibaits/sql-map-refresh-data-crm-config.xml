        </dynamic>
    </delete>
    <insert id="insertProjectProductConfigLevelInfoFromCRM" parameterClass="java.util.Map">
        <![CDATA[
            INSERT INTO pm_project_product_config_level_info_from_crm(
                projectCode,orderExecNumber,itemGroup,parentCode,itemCode
                ,quantity,itemModel,itemDesc,bomPaths,level
                ,dataSource
            )
            values
        ]]>
        <iterate conjunction="," property="list">
            (
             #list[].projectCode#, #list[].orderExecNumber#, #list[].itemGroup#, #list[].parentCode#, #list[].itemCode#
             , #list[].quantity#, #list[].itemModel#, #list[].itemDesc#, #list[].bomPaths#, #list[].level#
