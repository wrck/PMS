		]]>
		<!-- <selectKey resultClass="int"  keyProperty="id">    
             SELECT last_insert_id() as id ;   
        </selectKey> -->
	</insert>
	
	<select id="query_department_map" resultClass="java.util.HashMap">
		<![CDATA[
			SELECT departmentNum AS officeCode , departmentName AS officeName FROM fnd_department WHERE isparam = 1 
		]]>
	</select>
	
	<select id="queryDepartmentByDepartmentNum" resultMap="departmentMap">
        <![CDATA[
            SELECT * FROM fnd_department WHERE departmentNum = #officeCode# limit 1
        ]]>
    </select>
	
	<select id="select-user-byusername" parameterClass="string" resultMap="userRole">
		<![CDATA[
			select user.id,username,realName,email,password,roleIds,user.status,user.pwdoverdue, user.customInfo from fnd_user_info user 
			where user.username = #username# ORDER BY user.`status` DESC LIMIT 1
		]]>
	</select>
	<select id="select-users-byusernames" parameterClass="string" resultMap="userRole">
        <![CDATA[
            select user.id,username,realName,email,password,roleIds,user.status,user.pwdoverdue, user.customInfo from fnd_user_info user 
            where FIND_IN_SET(user.username, #username#) ORDER BY user.`status` DESC
