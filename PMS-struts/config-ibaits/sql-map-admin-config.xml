<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0 //EN"
 "http://ibatis.apache.org/dtd/sql-map-2.dtd">
<sqlMap namespace="business">
    <cacheModel type="CopyLRU" id="userCache" readOnly="true">
        <flushInterval hours="1"/>
        <flushOnExecute statement="insert-user-object"/>
        <flushOnExecute statement="update-user-object"/>
	    <flushOnExecute statement="update-user"/>
	    <flushOnExecute statement="update-user-chageloginpass"/>
        <flushOnExecute statement="update-pwd-byusername"/>
        <flushOnExecute statement="update-md5pwd-byusername"/>
	    <flushOnExecute statement="insert-menuForUser-object"/>
	    <flushOnExecute statement="delete-menuForUser-byUserId"/>
	    
	    <flushOnExecute statement="delete-roleMenuPower-byRoleId"/>
	    <flushOnExecute statement="insert-roleMenuPower-object"/>
	    <flushOnExecute statement="insert-roleObject"/>
	    <flushOnExecute statement="update-roleObject"/>
	    <flushOnExecute statement="update_user_power"/>
	    <flushOnExecute statement="insert_user_power"/>
	    
	    <flushOnExecute statement="refreshCacheData"/>
	    
        <property name="size" value="50"/>
    </cacheModel>
    
    <!-- 最近一次手动清理缓存时间 -->
    <update id="refreshCacheData">
        update fnd_sys_arg set var = now() where code = 'sys.cache.latest.refreshTime'
    </update>
    
	<!-- 查询用户权限 -->
	<resultMap class="java.util.HashMap" id="user_permissions">
		<result property="menuCode" column="menuCode" javaType="java.lang.String"/>
		<result property="menuValue" column="menuValue" javaType="java.lang.Integer"/>
	</resultMap>
	<select id="query_permissions_by_name" resultMap="user_permissions" parameterClass="int" cacheModel="userCache">
		<![CDATA[
			SELECT menuCode,menuValue FROM fnd_user_menus 
			WHERE  fnd_user_id = #userId# AND effectiveFrom < NOW() 
			AND( effectiveTo > NOW() OR effectiveTo IS NULL)
		]]>
	</select>
	<select id="query_permissions_name_code_by_userId" parameterClass="int" resultClass="java.util.HashMap" cacheModel="userCache">
        <![CDATA[
            SELECT 
			    m.`menuName`, um.menuCode 
			FROM
			    fnd_user_menus um
			    LEFT JOIN `fnd_menus` m
			    ON um.`menuCode` = m.`menuCode`
			WHERE um.fnd_user_id = #userId# 
			    AND um.effectiveFrom < NOW() 
			    AND (
			        um.effectiveTo > NOW() 
			        OR um.effectiveTo IS NULL
			    )
        ]]>
    </select>
	<!-- 查询用户角色集合 -->
	<resultMap class="com.dp.plat.data.bean.Role" id="RoleList">
		<result property="id" column="id" nullValue="0"/>
		<result property="roleName" column="roleName"/>
	</resultMap>
	<select id="query_sys_roles" resultMap="RoleList" cacheModel="userCache">
		<![CDATA[
			select id ,roleName from fnd_roles where status = 1 
		]]>
	</select>
	<!-- 查询系统菜单 -->
	<resultMap class="com.dp.plat.data.bean.UserMenu" id="UserSuperMenu">
		<result property="menuCode" column="menuCode"/>
		<result property="menuName" column="menuName"/>
		<result property="menuLevel" column="menuLevel"/>
		<result property="id" column="id"/>
		<result property="superId" column="superId"/>
		<result property="path" column="path"/>
	</resultMap>
	<select id="query_menu_modules" resultMap="UserSuperMenu" parameterClass="java.util.Map" cacheModel="userCache">
		<![CDATA[
			SELECT * FROM fnd_menus WHERE superId = #superId# and effectiveFrom < NOW() AND( effectiveTo > NOW() OR effectiveTo IS NULL);;
		]]>
	</select>
	<select id="query-menu-byId" parameterClass="int" resultMap="UserSuperMenu" cacheModel="userCache">
		<![CDATA[
			select * from fnd_menus where id = #id# and effectiveFrom < NOW() AND( effectiveTo > NOW() OR effectiveTo IS NULL);
		]]>
	</select>
	<resultMap class="com.dp.plat.data.bean.User" id="user_All">
		<result property="id" column="id"/>
		<result property="username" column="username"/>
		<result property="password" column="password"/>
		<result property="email" column="email"/>
		<result property="realName" column="realName"/>
		<result property="status" column="status"/>
		<result property="pwdoverdue" column="pwdoverdue"/>
		<result property="defaultPage" column="defaultPage"/>
		<result property="dpNo" column="dpNo"/>
		<result property="areapower" column="areapower"/>
		<result property="roleids" column="roleIds"/>
		<result property="customInfo" column="customInfo"/>
	</resultMap>
	<select id="query_user_by_id" parameterClass="int" resultMap="user_All" cacheModel="userCache">
		<![CDATA[
			select a.id,a.username,a.password,a.email,a.realName,a.status,a.pwdoverdue,a.roleIds,
			b.id as defaultPage , a.dpNo,c.`areapower`, a.customInfo
			from fnd_user_info a
			left join fnd_menus b on  a.defaultPage=b.path
			LEFT JOIN fnd_user_power c ON a.`id` = c.`fndUserId`  AND c.`effectiveFrom` < NOW() AND (c.`effectiveTo` IS NULL OR c.`effectiveTo`> NOW())
			where a.id = #id# 
			
		]]>
	</select>
	
	<select id="query_usermenuids_by_id" parameterClass="int" resultClass="string" cacheModel="userCache">
		<![CDATA[
			SELECT GROUP_CONCAT(m.id) FROM fnd_user_menus p, fnd_menus m 
			WHERE fnd_user_id = #id# AND p.`menuCode` = m.`menuCode`  AND p.`menuValue` = 1;
		]]>
	</select>
	
	
	<resultMap class="com.dp.plat.data.bean.User" id="LoginInfo">
		<result property="id" column="id"/>
		<result property="username" column="username"/>
		<result property="password" column="password"/>
		<result property="email" column="email"/>
		<result property="realName" column="realName"/>
		<result property="status" column="status"/>
		<result property="roleids" column="roleIds"/>
		<result property="isemail" column="isemail" nullValue="1"/>
		<result property="dpNo" column="dpNo"/>
		<result property="areapower" column="areapower"/>
		<result property="pwdoverdue" column="pwdoverdue"/>
		<result property="customInfo" column="customInfo"/>
	</resultMap>
	<resultMap class="com.dp.plat.data.bean.User" id="userRole">
		<result property="id" column="id"/>
		<result property="username" column="username"/>
		<result property="password" column="password"/>
		<result property="email" column="email"/>
		<result property="realName" column="realName"/>
		<result property="roleids" column="roleIds"/>
		<result property="status" column="status" nullValue="0"/>
		<result property="pwdoverdue" column="pwdoverdue"/>
		<result property="customInfo" column="customInfo"/>
	</resultMap>
	<resultMap class="com.dp.plat.data.bean.User" id="user">
		<result property="id" column="id" />
		<result property="username" column="username"/>
		<result property="password" column="password"/>
		<result property="email" column="email"/>
		<result property="realName" column="realName"/>
		<result property="status" column="status"/>
		<result property="roleids" column="roleIds"/>
		<result property="isemail" column="isemail"/>
	</resultMap>
	
	<select id="get-id-byname" parameterClass="string" resultClass="int" cacheModel="userCache">
		<![CDATA[
		select id from fnd_user_info
		where username = #username#
		]]>
	</select>
	<!-- 根据用户名查询用户 -->
	<select id="query-user-by-name" parameterClass="string" resultMap="LoginInfo" cacheModel="userCache">
		<![CDATA[
			select u.* , CASE WHEN  (p.`areapower` IS NULL OR p.`areapower` = '' ) THEN '-1' ELSE p.`areapower` END AS areapower from fnd_user_info u LEFT JOIN fnd_user_power p ON u.`id` = p.`fndUserId` 
			where u.username = #name# and u.status = 1 limit 1
		]]>
	</select>
	<!-- 查询所有的用户 -->
	<select id="query-user-count" parameterClass="com.dp.plat.data.bean.User" resultClass="int" cacheModel="userCache">
		<![CDATA[
		select count(1) from fnd_user_info ui
		]]>
		<isNotEmpty property="dpNo">
                LEFT JOIN fnd_user_power up 
                    ON up.`fndUserId` = ui.`id` 
        </isNotEmpty>
        <dynamic prepend="where">
			<isNotEmpty prepend="AND" property="username"> (ui.username like CONCAT('%', #username#, '%') or ui.realName like CONCAT('%', #username#, '%'))</isNotEmpty>
			<isNotEmpty prepend="AND" property="roleids"> ui.roleIds like CONCAT('%', #roleids#, '%') </isNotEmpty>
			<isNotEmpty prepend="and" property="dpNo"><![CDATA[ (ui.dpNo = #dpNo# or FIND_IN_SET(#dpNo#, up.areapower) ) ]]></isNotEmpty>
	    </dynamic>
	</select>
	<!-- 配置缓存模型  -->
<!-- 	<cacheModel type="OSCache" id="user_cache" readOnly="true" serialize="true">
		<flushInterval minutes="5"/>
		<flushOnExecute statement="insertUser"/>
		<property name="size" value="500"/>
	</cacheModel> -->
	<select id="query-userlist" parameterClass="com.dp.plat.param.UserParam" resultMap="userRole" cacheModel="userCache"><!-- cacheModel="user_cache" -->
		<![CDATA[
			SELECT 
			    ui.id, ui.username, ui.realName, ui.email, ui.password, ui.roleIds, ui.status, ui.pwdoverdue, ui.customInfo 
			FROM
			    fnd_user_info ui 
		]]>
		<isNotEmpty property="user.dpNo">
			    LEFT JOIN fnd_user_power up 
			        ON up.`fndUserId` = ui.`id` 
		</isNotEmpty>
		<dynamic prepend="where">
			<isNotEmpty prepend="AND" property="user.username"><![CDATA[  ( ui.username like CONCAT('%', #user.username#, '%') or ui.realName like CONCAT('%', #user.username#, '%') )]]></isNotEmpty>
			<isNotEmpty prepend="and" property="user.roleids"><![CDATA[ ui.roleIds like CONCAT('%', #user.roleids#, '%')]]></isNotEmpty>
			<isNotEmpty prepend="and" property="user.dpNo"><![CDATA[ (ui.dpNo = #user.dpNo# or FIND_IN_SET(#user.dpNo#, up.areapower) ) ]]></isNotEmpty>
		</dynamic>
        <isNotEmpty prepend=" order by " property="displayParam.sort">
			#displayParam.sort#
			<isEqual prepend=" " property="displayParam.order" compareValue="desc">
				desc
		      </isEqual>
			<isEqual prepend=" " property="displayParam.order" compareValue="asc">
				asc
		      </isEqual>
		</isNotEmpty>
		<isNotEmpty property="displayParam.offset">
			limit #displayParam.offset#, #displayParam.pagesize# 
		</isNotEmpty>
	</select>
	
	<select id="query-userlist-all" parameterClass="com.dp.plat.data.bean.User" resultMap="userRole" cacheModel="userCache">
		<![CDATA[
			select user.id,username,realName,email,password,roleIds,user.status,user.pwdoverdue, user.customInfo from fnd_user_info user
		]]>
		<dynamic prepend="where">
			<isNotEqual prepend="and" property="status" compareValue="0"><![CDATA[ status=#status# ]]></isNotEqual>
			<isNotEmpty prepend="and" property="username"><![CDATA[  user.username like CONCAT('%', #username#, '%') ]]></isNotEmpty>
			<isNotEmpty prepend="and" property="roleids"><![CDATA[ user.roleIds like CONCAT('%', #roleids#, '%')]]></isNotEmpty>
		</dynamic>
	</select>
	
	<resultMap class="com.dp.plat.data.bean.User" id="extendsUserInfo">
		<result property="username" column="username"/>
		<result property="realName" column="realName"/>
	</resultMap>
	<select id="query-all-user" resultMap="extendsUserInfo" cacheModel="userCache">
		<![CDATA[
		select username, realName from fnd_user_info
		]]>
	</select>
	<select id="select-roleName" resultClass="string">
		<![CDATA[
		select roleName from role where status = 1
		]]>
	</select>
	<update id="update-user-chageloginpass" parameterClass="com.dp.plat.param.PasswordEditParam">
		<![CDATA[
		update fnd_user_info set password = #newPassword#,pwdoverdue = date_add(NOW(), interval 3 MONTH)
		where id = #id#
		]]>
	</update>
	<update id="update-pwd-byusername" parameterClass="com.dp.plat.data.bean.User">
		<![CDATA[
		update fnd_user_info set password = #password#
		]]>
		<isNotEmpty prepend="," property="pwdoverdue"> pwdoverdue = #pwdoverdue# </isNotEmpty>
		where username = #username#
	</update>
	<select id="select-roleid-byRoleName" parameterClass="string" resultClass="int" cacheModel="userCache">
		<![CDATA[
		select id from role
		where roleName = #roleName#
		]]>
	</select>
	<!-- 用户管理 -->
	<insert id="insert-user-object" parameterClass="com.dp.plat.data.bean.User">
		insert into fnd_user_info(username
		<isNotEmpty prepend="," property="password">password</isNotEmpty>
		,email,realName,status,roleIds,isemail,pwdoverdue,defaultPage,dpNo,createBy,createTime, effectiveFrom
		, customInfo)
		values(#username#
		<isNotEmpty prepend="," property="password">#password#</isNotEmpty>
		,#email#,#realName#,1,#roleids#,1,now(),#defaultPage#,#dpNo#,#createBy# ,now(),now()
		, #customInfo#)
		<selectKey resultClass="int"  keyProperty="id">    
             SELECT last_insert_id() as id ;   
        </selectKey>
	</insert>
	<update id="update-user-object" parameterClass="com.dp.plat.data.bean.User">
		<![CDATA[
		update fnd_user_info set username=#username#,email=#email#,realName=#realName#,
		status=#status#,roleIds = #roleids#,isemail=1,effectiveTo=#effectiveTo#, updateBy=#updateBy#,updateTime=now(),defaultPage=#defaultPage#,dpNo = #dpNo#
		]]>
		<isNotEmpty prepend="," property="customInfo"> customInfo = JSON_MERGE_PATCH(IFNULL(customInfo, "{}"), #customInfo#) </isNotEmpty>
		where id=#id#
	</update>
	<insert id="insert-menuForUser-object" parameterClass="com.dp.plat.data.bean.MenuForUser">
		<![CDATA[
		insert into fnd_user_menus(fnd_user_id,username,menuCode,menuValue,createTime,effectiveFrom)
		values(#sys_user_id#,#username#,#menuCode#,1,now(),now())
		]]>
	</insert>
	<delete id="delete-menuForUser-byUserId" parameterClass="int">
		<![CDATA[
			delete from fnd_user_menus where fnd_user_id=#userId#
			]]>
	</delete>
	<update id="update-md5pwd-byusername" parameterClass="com.dp.plat.param.Md5Param">
		<![CDATA[
		update user set password = #md5pwd#
		where username = #username#
		]]>
	</update>
	<select id="select-user" parameterClass="com.dp.plat.data.bean.User" resultMap="userRole" cacheModel="userCache">
		<![CDATA[
		select user.id,username,realName,email,password,roleIds,user.status,user.pwdoverdue, user.customInfo
		from fnd_user_info user 
		where user.id = #id#
		]]>
	</select>
	<update id="update-user" parameterClass="com.dp.plat.data.bean.User">
		<![CDATA[
		update fnd_user_info set email = #email#, realName = #realName#, roleIds = #roleids#, status = #status#
		]]>
		<isNotEmpty prepend="," property="customInfo"> customInfo = JSON_MERGE_PATCH(IFNULL(customInfo, "{}"), #customInfo#) </isNotEmpty>
		where username = #username#
	</update>
	
	<resultMap class="com.dp.plat.data.bean.User" id="userAllMap">
		<result property="username" column="username" javaType="java.lang.String"/>
		<result property="email" column="email" javaType="java.lang.String"/>
		<result property="realName" column="realName" javaType="java.lang.String"/>
		<result property="status" column="status" javaType="java.lang.Integer"/>
		<result property="roleids" column="roleIds" javaType="java.lang.String"/>
		<result property="isemail" column="isemail" javaType="java.lang.Integer"/>
	</resultMap>
	
	<select id="query_user_allMap" resultMap="userAllMap" cacheModel="userCache">
		<![CDATA[
			select * from fnd_user_info
		]]>
	</select>
	
	<resultMap class="com.dp.plat.data.bean.Role" id="roleMap">
		<result property="id" column="id" />
		<result property="roleName" column="roleName"/>
		<result property="status" column="status"/>
		<result property="defaultPage" column="defaultPage"/>
		<result property="roleRemark" column="roleRemark"/>
		<result property="effectiveFrom" column="effectiveFrom" jdbcType="DATE"/>
		<result property="effectiveTo" column="effectiveTo" jdbcType="DATE"/>
	</resultMap>
	<resultMap class="com.dp.plat.data.bean.RoleMenuPower" id="roleMenuMap">
		<result property="id" column="id" />
		<result property="roleId" column="roleId"/>
		<result property="menuPower" column="menuPower"/>
		<result property="menuId" column="menuId"/>
	</resultMap>
	<!-- 角色管理 -->
	<select id="query-role-count" parameterClass="com.dp.plat.data.bean.Role"  resultClass="int" cacheModel="userCache">
		<![CDATA[
		select count(1) from fnd_roles  
		]]>
		<dynamic prepend="WHERE">
			<isNotEmpty prepend="AND" property="roleName">
			 	roleName like CONCAT('%', #roleName#, '%')
			 </isNotEmpty>
			  <isNotEqual prepend="AND" property="id" compareValue="0">
					id=#id#
		      </isNotEqual>
		</dynamic>
	</select>
	
	<select id="query-rolelist" parameterClass="com.dp.plat.param.RoleParam" resultMap="roleMap" cacheModel="userCache">
		<![CDATA[
		select * from fnd_roles 
		]]>
		<dynamic prepend="WHERE">
			<isNotEmpty prepend="AND" property="role.roleName">
			 	roleName like CONCAT('%', #role.roleName#, '%')
			 </isNotEmpty>
			 <isNotEqual prepend="AND" property="role.id" compareValue="0">
					id=#role.id#
		      </isNotEqual>
		</dynamic>
		<isNotEmpty prepend=" order by " property="displayParam.sort">
					#displayParam.sort#
			<isEqual prepend=" " property="displayParam.order" compareValue="desc">
					desc
		      </isEqual>
			<isEqual prepend=" " property="displayParam.order" compareValue="asc">
					asc
		      </isEqual>
		</isNotEmpty>
		<isNotEmpty property="displayParam.offset">
			limit #displayParam.offset#, #displayParam.pagesize# 
		</isNotEmpty>
	</select>
	
	<select id="query-roleMenu-list" parameterClass="com.dp.plat.data.bean.Role" resultMap="roleMenuMap" cacheModel="userCache">
		<![CDATA[
			select * from fnd_role_menus where roleId=#id#
		]]>
	</select>
	
	<delete id="delete-roleMenuPower-byRoleId" parameterClass="com.dp.plat.data.bean.Role">
		<![CDATA[
			delete from fnd_role_menus where roleId=#id#
		]]>
	</delete>
	
	<!-- 角色新增 -->
	<insert id="insert-roleObject" parameterClass="com.dp.plat.data.bean.Role">
		<![CDATA[
		insert into fnd_roles(roleName,defaultPage,status,roleRemark,createTime,effectiveFrom,effectiveTo,updateTime)
		values(#roleName#,#defaultPage#,#status#,#roleRemark#,now(),now(),#effectiveTo#,null)
		]]>
		<selectKey resultClass="int"  keyProperty="id">    
             SELECT last_insert_id() as id ;   
        </selectKey>
	</insert>
	<insert id="insert-roleMenuPower-object" parameterClass="com.dp.plat.data.bean.RoleMenuPower">
		<![CDATA[
		insert into fnd_role_menus(roleId,menuPower,menuId,createTime,effectiveFrom)
		values(#roleId#,#menuPower#,#menuId#,now(),now())
		]]>
	</insert>
	
	<!-- 角色更新 -->
	<insert id="update-roleObject" parameterClass="com.dp.plat.data.bean.Role">
		<![CDATA[
		update fnd_roles set roleName=#roleName#,defaultPage=#defaultPage#,status=#status#,
		roleRemark=#roleRemark#,effectiveTo=#effectiveTo#,updateTime=now()
		where id=#id#
		]]>
	</insert>
	
	<!-- 部门管理 -->
	<resultMap class="com.dp.plat.data.bean.Department" id="departmentMap">
		<result property="id" column="id" />
		<result property="departmentNum" column="departmentNum"/>
		<result property="departmentName" column="departmentName"/>
		<result property="createTime" column="createTime" jdbcType="DATE"/>
	</resultMap>
	<resultMap class="com.dp.plat.data.bean.Department" id="departmentMapForSAP">
