<%@ page contentType="text/html;charset=UTF-8" language="java"%>
<%@ taglib prefix="s" uri="/struts-tags"%>
<%@ taglib prefix="dp" uri="/dp"%>
<%@ taglib uri="http://displaytag.sf.net" prefix="display"%>
<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN">
<html>
<head>
<dp:base />
<meta name="menu" content="SysLeftMenu">
<meta name="module" content="<s:text name='module.plat' />">
<meta name="group" content="<s:text name='sys.leftmenu.powermanage' />">
<meta name="function" content="<s:text name='pm.subcontract.manage' />">
<style type="text/css">
#mainForm div lable{
	width: 100px;
}
</style>
<script type="text/javascript">
	$(function(){
		//获取流程图
		$("#querySubcontractView").click(function(){
			$.ajax({
				url:"viewDeployment.action",
				type:"post",
				dataType:"json",
				data:{procdefKey:"Subcontract"},
				success:function(data){
				  	window.open("work/WorkFlowViewImage.action?param.deploymentId="+data.deploymentId+"&param.imageName="+data.imageName);
				},
				error:function(){
					alert('error!');
				}
			});
			return false;
		});
		
		date_picker("searchStartTime");
		date_picker("searchEndTime");
	});
</script>
</head>
<body>
	<!-- 查询 -->
	<s:form id="mainForm" name="mainForm" cssClass="form-inline" action="module/subcontract_list.action">
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="subcontractName"><s:text name="pm.subcontract.subcontractName" /></label>
			<s:textfield name="subcontractVO.subcontractName" id="subcontractName"
				placeholder="支持模糊搜索" cssStyle="width:163px" cssClass="form-control" />
		</div>
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="contractNos">&nbsp;&nbsp;&nbsp;<s:text name="pm.subcontract.contractNos" /></label>
			<s:textfield name="subcontractVO.contractNos" id="contractNos"
				 cssStyle="width:163px" cssClass="form-control" placeholder="合同号/转包合同号" />
		</div>
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="officeCode"><s:text name="pm.subcontract.officeName"/></label>
			<s:select name="subcontractVO.officeCode" id="officeCode"  cssClass="form-control" cssStyle="width:163px;"
				list="depList" listKey="departmentNum" listValue="departmentName"
				headerKey="" headerValue="--请选择--"></s:select>	
		</div>
        <div class="form-group form-group-query form-group-width-1">
            <label>
                <select name="subcontractVO.searchTimeType" id="searchTimeType" class="form-control" style="padding:0px;border:none;box-shadow:none;">
                    <option value="createTime" <s:if test='%{subcontractVO.searchTimeType == "createTime"}'>selected="selected"</s:if>>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;申请时间</option>
                    <option value="zrApproverTime" <s:if test='%{subcontractVO.searchTimeType == "zrApproverTime"}'>selected="selected"</s:if>>主任审批通过时间</option>
                    <option value="paymentTime" <s:if test='%{subcontractVO.searchTimeType == "paymentTime"}'>selected="selected"</s:if>>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;付款时间</option>
                </select>
                <%-- <s:select name="subcontractVO.searchTimeType" list="#{'createTime':'　　　　申请时间', 'zrApproverTime':'主任审批通过时间'}" id="searchTimeType" cssClass="form-control" style="padding:0px;border:none;box-shadow:none;" filter="false">
                </s:select> --%>
            </label>
            <s:textfield id="searchStartTime" name="subcontractVO.searchStartTime" cssClass="form-control" style="width: 100px; display: inline-block;" placeholder="开始时间"></s:textfield>
            <s:textfield id="searchEndTime" name="subcontractVO.searchEndTime" cssClass="form-control" style="width: 100px; display: inline-block;" placeholder="结束时间"></s:textfield>
        </div>
		<br/>
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="facilitatorName">&nbsp;&nbsp;&nbsp;<s:text name="pm.subcontract.facilitator" /></label>
			<s:textfield name="subcontractVO.facilitatorName" id="pm_hide" cssClass="form-control" placeholder="支持模糊查询"></s:textfield>
		</div>
		<div class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="subcontractType"><s:text name="pm.subcontract.type" /></label>
            <s:select list="typeList" name="subcontractVO.type" id="subcontractType"
                cssClass="form-control" listKey="basicDataId" listValue="basicDataName"
                headerKey="" headerValue="--请选择--" cssStyle="width:163px;"></s:select>  
        </div>
        <div class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="profitDepCode">&nbsp;&nbsp;&nbsp;<s:text name="pm.subcontract.profitDep" /></label>
            <s:select name="subcontractVO.profitDepCode" id="profitDepCode"  cssClass="form-control" cssStyle="width:163px;"
                list="profitDepList" listKey="departmentNum" listValue="departmentName"
                headerKey="" headerValue="--请选择--"></s:select>
        </div>
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="subcontractState">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<s:text name="pm.subcontract.state" /></label>
			<s:select list="stateList" name="subcontractVO.state" id="subcontractState"
				cssClass="form-control" listKey="basicDataId" listValue="basicDataName"
				headerKey="" headerValue="--请选择--" cssStyle="width:163px;"></s:select>	
		</div>
		<div class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="subcontractCallbackState">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<s:text name="pm.subcontract.callbackState" /></label>
            <s:select list="callbackStateList" name="subcontractVO.callbackState" id="subcontractCallbackState"
                cssClass="form-control" listKey="basicDataId" listValue="basicDataName"
                headerKey="" headerValue="--请选择--" cssStyle="width:163px;"></s:select>  
        </div>
		<div class="form-group form-group-query form-group-width-1">
			<button class="btn btn-default btn-sm">
				<span class="glyphicon glyphicon-search"></span> 查询
			</button>
		</div>
	</s:form>
	<!-- 蓝色箭头，项目列表 -->
	<div class="divHeader div-height">
		<img src="images/right_zhishi.gif" border="0">
		<s:text name="pm.subcontract.list"></s:text>
	</div>
	<div style="position: relative;">
		<s:if test="user.isHasRole(13) || user.isHasRole(11)">
	        <a href="module/subcontract_input.action" target="_blank" style="margin-bottom:1rem;" class="btn btn-default btn-sm">申请转包</a>
	    </s:if>
	    <a id="querySubcontractView" class="pull-right" target="_blank" href="" style=" position: absolute; bottom: -1rem; right: 0;">
            <span class="glyphicon glyphicon-picture" style="font-size:12px; color:#428bca;"><span class="panel-heading">查看项目转包流程图&nbsp;</span></span>
        </a>
	</div>
	<div>
		<!-- 查看项目转包流程图 -->
		<div style="text-align: right;">
		</div>
		<!-- 分页，项目列表 -->
        <display:table name="subcontractVOList" pagesize="${displayParam.pagesize }"
            export="true" size="${displayParam.totalcount }" sort="external"
            requestURI="module/subcontract_list.action" decorator="com.dp.plat.decorators.Wrapper"
            class="table table-striped" partialList="true" >
            <display:column property="subcontractNo" titleKey="pm.subcontract.subcontractNo" media="html" style="width:150px"></display:column>
            <display:column property="subcontractName" titleKey="pm.subcontract.subcontractName" style="word-wrap: break-word; white-space: normal; width:300px;" href="module/subcontract_input.action" paramProperty="id" paramId="subcontract.id" media="html"></display:column>
            <display:column property="contractNos" titleKey="pm.subcontract.contractNos" decorator="com.dp.plat.decorators.ContractNoList" media="html"></display:column>
            <display:column property="typeName" titleKey="pm.subcontract.type" media="html"></display:column>
            <display:column property="officeName" titleKey="pm.subcontract.officeName" media="html"></display:column>
            <display:column property="facilitatorName" titleKey="pm.subcontract.facilitator" media="html"></display:column>
            <display:column property="createName" titleKey="pm.subcontract.createName" media="html"></display:column>
            <display:column property="createTime" titleKey="pm.subcontract.createTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="html"></display:column>
            <display:column property="stateName" titleKey="pm.subcontract.state" media="html"></display:column>
            
            <%-- 数据导出列 --%>
            <display:column property="contractNos" titleKey="pm.subcontract.contractNos" media="excel"></display:column>
            <display:column property="subcontractNo" titleKey="pm.subcontract.subcontractNo" media="excel"></display:column>
            <display:column property="subcontractName" titleKey="pm.subcontract.subcontractName" href="module/subcontract_input.action" paramProperty="id" paramId="subcontract.id" media="excel"></display:column>
            <display:column property="typeName" titleKey="pm.subcontract.type" media="excel"></display:column>
            <%-- <display:column property="facilitatorName" titleKey="pm.subcontract.facilitator" media="excel"></display:column>
            <display:column property="subcontractAmount" titleKey="pm.subcontract.subcontractAmount" media="excel"></display:column> --%>
            <display:column property="facilitatorName" title="合作代理商" media="excel"></display:column>
            <display:column property="subcontractAmount" title="成交价" media="excel"></display:column>
            <display:column property="officeName" titleKey="pm.subcontract.officeName" media="excel"></display:column>
            <display:column property="profitDepName" titleKey="pm.subcontract.profitDep" media="excel"></display:column>
            <display:column property="createTime" titleKey="pm.subcontract.createTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
            <display:column property="zrApproverTime" titleKey="pm.subcontract.zrApproverTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
            <display:column property="stateName" titleKey="pm.subcontract.state" media="excel"></display:column>
            <display:column property="callbackStateName" titleKey="pm.subcontract.callbackState" media="excel"></display:column>
            <display:column property="isAccrued" titleKey="pm.subcontract.accrued" media="excel"></display:column>
            <display:column property="isInvoiced" titleKey="pm.subcontract.invoiced" media="excel"></display:column>
            <display:column property="confirmTime" titleKey="pm.subcontract.confirmTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
            <display:column property="paidRatio" titleKey="pm.subcontract.paidRatio" media="excel"></display:column>
            <display:column property="paidAmountWrapper" titleKey="pm.subcontract.paidAmount" media="excel"></display:column>
            <display:column property="paymentTime" titleKey="pm.subcontract.paymentTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
            <display:column property="remark" titleKey="pm.subcontract.remark" media="excel"></display:column>
        </display:table>
	</div>
</body>
</html>