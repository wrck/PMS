    <delete id="drop_prob_statistics_tempTable">
        DROP TEMPORARY TABLE IF EXISTS statistic_tempTable
    </delete>
    
    <delete id="drop_prob_softChangeLog_tempTable">
        DROP TEMPORARY TABLE IF EXISTS softChangeLog_tempTable
    </delete>
    
    <select id="query_prob_statistics_report" resultClass="com.dp.plat.data.bean.ReportLineData">
        SELECT 
		    t.column001 AS officeCode, t.officeName,
		    COUNT(DISTINCT s.projectId) AS conditionValue, COUNT(DISTINCT t.projectId) AS totalValue,
		    CONCAT(ROUND(COUNT(DISTINCT s.projectId)/COUNT(DISTINCT t.projectId) * 100, 2) ,'%') AS specificValue
		FROM
		    projectTempTable t 
		    LEFT JOIN statistic_tempTable s 
		        ON s.projectId = t.projectId 
		GROUP BY t.column001
		ORDER BY specificValue DESC, conditionValue DESC, totalValue DESC
    </select>
    
    <insert id="create_prob_statistics_projectTempTable" parameterClass="com.dp.plat.prob.bean.ProbStatistic">
        CREATE TEMPORARY TABLE IF NOT EXISTS projectTempTable
        SELECT 
		    ph.*, GROUP_CONCAT(DISTINCT pc.`contractNo`) AS contractNo, 
		    ph.column001 as officeCode, fd.departmentName AS officeName, fbd.`basicDataName` AS projectStateName,
		    sm.`memberCode` AS serviceManagerCode, sm.`memberName` AS serviceManagerCodeforjson, 
		    pm1.`memberCode` AS programManagerCodeA, pm1.`memberName` AS programManagerCodeforjson,
		    pm2.`memberCode` AS programManagerCodeB, pm2.`memberName` AS programManagerCodeforjsonB 
		FROM
		    pm_project_header ph 
		    LEFT JOIN pm_project_group_relationship pgr 
		        ON ph.`projectCode` = pgr.`projectCode` 
		    LEFT JOIN pm_project_group pg 
		        ON pgr.`projectGroupCode` = pg.`projectGroupCode` 
		    LEFT JOIN pm_project_contract pc 
		        ON pc.`projectGroupCode` = pg.`projectGroupCode` 
		    LEFT JOIN fnd_department fd 
		        ON fd.`departmentNum` = ph.column001 
		    LEFT JOIN fnd_basic_data fbd 
		        ON fbd.`basicDataId` = ph.`projectState` 
		        AND fbd.`dataTypeCode` = "02" 
		    LEFT JOIN pm_project_member sm 
		        ON sm.`projectId` = ph.`projectId` 
		        AND sm.`memberRole` = "20" 
		        AND sm.`effectiveTo` IS NULL 
		        AND sm.`fromFlag` = 1 
		    LEFT JOIN pm_project_member pm1 
		        ON pm1.`projectId` = ph.`projectId` 
		        AND pm1.`memberRole` = "30" 
		        AND pm1.`effectiveTo` IS NULL 
		        AND pm1.`fromFlag` = 1 
		    LEFT JOIN pm_project_member pm2 
                ON pm2.`projectId` = ph.`projectId` 
                AND pm2.`memberRole` = "30" 
                AND pm2.`effectiveTo` IS NULL 
                AND pm2.`fromFlag` = 2 
            LEFT JOIN `pm_project_soft_change_logs` pscl
			    ON pscl.`projectId` = ph.`projectId`
			        AND pscl.`latest` = 1 
		WHERE (
		        ph.`column012` = 0 
		        OR ph.`columno12_readonly` = 0
		        OR pscl.id IS NOT NULL
		    ) 
		    AND ph.`effectiveTo` IS NULL 
		<!-- GROUP BY pgr.`projectGroupCode`, ph.`projectCode` -->
		GROUP BY ph.`projectCode`
    </insert>
    
     <delete id="drop_prob_statistics_projectTempTable">
        DROP TEMPORARY TABLE IF EXISTS projectTempTable
    </delete>
    
    <select id="query_prob_statistics_project_Count" parameterClass="com.dp.plat.prob.bean.ProbStatistic" resultClass="int">
        select count(*) from projectTempTable
        <dynamic prepend="where">
            <isNotEmpty prepend="and" property="projectCode"> (projectCode like CONCAT("%", #projectCode#, "%") or contractNo like CONCAT("%", #projectCode#, "%"))</isNotEmpty>
            <isNotEmpty prepend="and" property="projectName"> projectName like CONCAT("%", #projectName#, "%")</isNotEmpty>
            <isNotEmpty prepend="and" property="officeCode"> officeCode = #officeCode#</isNotEmpty>
            <isNotEmpty prepend="and" property="programManagerCode"> (programManagerCodeA = #programManagerCode# or programManagerCodeB = #programManagerCode#) </isNotEmpty>
            <isNotEmpty prepend="and" property="serviceManagerCode"> serviceManagerCode = #serviceManagerCode#</isNotEmpty>
        </dynamic>
    </select>
    
    <select id="query_prob_statistics_project" parameterClass="map" resultClass="com.dp.plat.data.bean.Project">
        select * from projectTempTable
        <dynamic prepend="where">
            <isNotEmpty prepend="and" property="probStatistic.projectCode"> (projectCode like CONCAT("%", #probStatistic.projectCode#, "%") or contractNo like CONCAT("%", #probStatistic.projectCode#, "%"))</isNotEmpty>
            <isNotEmpty prepend="and" property="probStatistic.projectName"> projectName like CONCAT("%", #probStatistic.projectName#, "%")</isNotEmpty>
            <isNotEmpty prepend="and" property="probStatistic.officeCode"> officeCode = #probStatistic.officeCode#</isNotEmpty>
            <isNotEmpty prepend="and" property="probStatistic.programManagerCode"> (programManagerCodeA = #probStatistic.programManagerCode# or programManagerCodeB = #probStatistic.programManagerCode#) </isNotEmpty>
            <isNotEmpty prepend="and" property="probStatistic.serviceManagerCode"> serviceManagerCode = #probStatistic.serviceManagerCode#</isNotEmpty>
        </dynamic>
    </select>
    
    <select id="query_prob_statistics_report_total" parameterClass="map" resultClass="com.dp.plat.data.bean.ReportLineData">
        SELECT 
		    "total" as officeCode, "全国" as officeName, SUM(conditionValue) AS conditionValue, SUM(totalValue) AS totalValue, CONCAT(
		        ROUND(
		            SUM(conditionValue) / SUM(totalValue) * 100, 2
		        ), '%'
		    ) AS specificValue 
		FROM
	        (SELECT 
	            t.column001 AS officeCode, t.officeName,
	            COUNT(DISTINCT s.projectId) AS conditionValue, COUNT(DISTINCT t.projectId) AS totalValue,
	            CONCAT(ROUND(COUNT(DISTINCT s.projectId)/COUNT(DISTINCT t.projectId) * 100, 2) ,'%') AS specificValue
	        FROM
	            projectTempTable t 
	            LEFT JOIN statistic_tempTable s 
	                ON s.projectId = t.projectId 
	        GROUP BY t.column001) t
    </select>
    
    <insert id="insertProbReadLog" parameterClass="com.dp.plat.prob.bean.ProbReadLog" >
        INSERT INTO `prob_read_log`
        SELECT 
            null, #probId#, #reader#, NOW(), GREATEST(IFNULL(MAX(status), #status#), #status#), 
		    IFNULL(MIN(readTime), now()) AS firstTime, 
		    IFNULL(Max(commitTime), IF(#status# = 1, now(), null)) AS commitTime
		FROM
		    `prob_read_log` 
		WHERE probId = #probId# 
		    AND reader = #reader#
        <selectKey resultClass="int" keyProperty="id">
            SELECT last_insert_id() as id ;   
        </selectKey>
    </insert>
    <select id="count_prob_read_log" parameterClass="com.dp.plat.prob.bean.ProbReadLog" resultClass="int">
        SELECT 
            count(*)
        FROM
            prob_read_log rl 
        where rl.probId = #probId#
        <isNotEmpty prepend="and" property="reader"> rl.reader = #reader# </isNotEmpty>
        <isNotEmpty prepend="and" property="status"> rl.status = #status# </isNotEmpty>
    </select>
    <select id="query_prob_read_log" parameterClass="map" resultClass="com.dp.plat.prob.bean.ProbReadLog">
        SELECT 
		    rl.*, IFNULL(
		        CONCAT(ui.`username`, "-", ui.`realName`), rl.reader
		    ) AS readerName 
		FROM
		    prob_read_log rl 
		    LEFT JOIN fnd_user_info ui 
		        ON rl.`reader` = ui.`username` 
		where rl.probId = #probReadLog.probId#
		<isNotEmpty prepend="and" property="probReadLog.reader"> rl.reader = #probReadLog.reader# </isNotEmpty>
		<isNotEmpty prepend="and" property="probReadLog.status"> rl.status = #probReadLog.status# </isNotEmpty>
        order by rl.readTime desc
        <isNotEmpty property="displayParam.offset">
            limit #displayParam.offset#,  #displayParam.pagesize#
        </isNotEmpty>
    </select>
    
    <select id="query_prob_read_statistics" parameterClass="map" resultClass="com.dp.plat.prob.bean.ProbReadLog">
        SELECT 
		    p.probNum, p.`theme`, p.`watch`, bd1.`basicDataName` AS watchName, p.`status`, bd2.`basicDataName` AS statusName, 
		    ui.`username` AS render, CONCAT(ui.username, "-", ui.realName) AS readerName, rl.firstTime, rl.commitTime, rl.readStatus
		FROM
		    prob_main p 
		    LEFT JOIN `fnd_user_info` ui 
		        ON FALSE = FIND_IN_SET(ui.`roleIds`, ";1;,;9;,;20;") 
		    LEFT JOIN 
		        (SELECT 
		            probId, reader, MIN(readTime) AS firstTime, MAX(commitTime) AS commitTime, IFNULL(MAX(STATUS), 0) AS readStatus
		        FROM
		            prob_read_log 
		        GROUP BY `probId`, `reader`) rl 
		        ON ui.`username` = rl.`reader` 
		    LEFT JOIN fnd_basic_data bd1 
		        ON p.`watch` = bd1.`basicDataId` 
		        AND bd1.`dataTypeCode` = '30' 
		        AND bd1.`effectiveTo` IS NULL 
		    LEFT JOIN fnd_basic_data bd2 
		        ON p.`priority` = bd2.`basicDataId` 
		        AND bd2.`dataTypeCode` = '32' 
		    LEFT JOIN fnd_basic_data bd3 
		        ON p.`status` = bd3.basicDataId 
		        AND bd3.dataTypeCode = '31' 
		        AND bd3.`effectiveTo` IS NULL 
        <dynamic prepend="where">
            <isNotEmpty prepend="and" property="prob.probNum"> p.probNum = #probNum#</isNotEmpty>
            <isNotEmpty prepend="and" property="prob.theme"> p.theme = #theme#</isNotEmpty>
            <isNotEmpty prepend="and" property="probReadLog.reader"> p.probNum = #probNum#</isNotEmpty>
            <isNotEmpty prepend="and" property="probNum"> p.probNum = #probNum#</isNotEmpty>
        </dynamic>
		ORDER BY p.visibleRange, p.`id`
    </select>
    
    <select id="count_prob_read_statistics" parameterClass="map" resultClass="com.dp.plat.prob.bean.ProbReadLog">
        SELECT 
            p.probNum, p.`theme`, p.`watch`, bd1.`basicDataName` AS watchName, p.`status`, bd2.`basicDataName` AS statusName, CONCAT(ui.username, "-", ui.realName) AS readerName, rl.* 
        FROM
            prob_main p 
            LEFT JOIN `fnd_user_info` ui 
                ON FALSE = FIND_IN_SET(ui.`roleIds`, ";1;,;9;,;20;") 
            LEFT JOIN 
                (SELECT 
                    probId, reader, MIN(readTime) AS firstTime, MAX(commitTime) AS commitTime, IFNULL(MAX(STATUS), 0) AS readStatus
                FROM
                    prob_read_log 
                GROUP BY `probId`, `reader`) rl 
                ON ui.`username` = rl.`reader` 
            LEFT JOIN fnd_basic_data bd1 
                ON p.`watch` = bd1.`basicDataId` 
                AND bd1.`dataTypeCode` = '30' 
                AND bd1.`effectiveTo` IS NULL 
            LEFT JOIN fnd_basic_data bd2 
                ON p.`priority` = bd2.`basicDataId` 
                AND bd2.`dataTypeCode` = '32' 
            LEFT JOIN fnd_basic_data bd3 
                ON p.`status` = bd3.basicDataId 
                AND bd3.dataTypeCode = '31' 
                AND bd3.`effectiveTo` IS NULL 
        <dynamic prepend="where">
            <isNotEmpty prepend="and" property="probNum"> p.probNum = #probNum#</isNotEmpty>
            <isNotEmpty prepend="and" property="theme"> p.theme = #theme#</isNotEmpty>
            <isNotEmpty prepend="and" property="probNum"> p.probNum = #probNum#</isNotEmpty>
            <isNotEmpty prepend="and" property="probNum"> p.probNum = #probNum#</isNotEmpty>
        </dynamic>
        ORDER BY p.visibleRange, p.`id`
    </select>
</sqlMap>