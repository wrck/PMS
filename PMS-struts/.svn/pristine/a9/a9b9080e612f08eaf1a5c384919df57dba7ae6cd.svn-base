<table cellpadding="0" cellspacing="0">
<tr>
	<td nowrap style="PADDING-RIGHT: 2px" valign=left width="132px">
	<input type=checkbox name="autoref" value="true" #if($autoref)checked#end onclick="autoref_click(this);">
	${interval}#text("module.refresh.unit")
	<A href="javascript:refresh_page();"><IMG style="BORDER-RIGHT: medium none; BORDER-TOP: medium none; BORDER-LEFT: medium none; BORDER-BOTTOM: medium none" alt='#text("module.refresh.tip")'  src="images/refresh.gif" align="absMiddle"/></A></td>
</tr>
</table>
<script>
var interval=$interval * 1000;
function refresh_page()
{
	var par = sys_env;
	if(getObj("autoref").checked)
	{
		par = addaddenvparam(par, "autoref", "true");
	}
	window.location=window.location.pathname+"?" + par;
}
function autoref_click(cb)
{
	autoref_settimeout(cb.checked);
}
var autoref_timer;
function autoref_settimeout(flag)
{
	if(true == flag)
	{
		autoref_timer = setTimeout("refresh_page();",interval);
	}
	else
	{
		clearTimeout(autoref_timer);
		autoref_timer=null;
	}
}
#if($autoref)
	autoref_settimeout(true);
#end
</script>