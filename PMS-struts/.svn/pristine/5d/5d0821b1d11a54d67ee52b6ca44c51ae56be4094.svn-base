<?xml version="1.0" encoding="UTF-8"?>  
<!DOCTYPE sqlMap  
PUBLIC "-//ibatis.apache.org//DTD SQL MAP 2.0//EN"  
"http://ibatis.apache.org/dtd/sql-map-2.dtd">  
<sqlMap>
	<select id="test" resultClass="int">
		<![CDATA[
			select count(1) from pm_column_of_relationship
		]]>
	</select>
	<!-- 从ERP刷新订单信息 -->
	<resultMap class="com.dp.plat.param.OrderBean" id="OrderBeans">
		<result property="orderNumber" column="order_number"/>
		<result property="contractNo" column="contract_number"/>
		<result property="orderExecNumber" column="order_exec_number"/>
		<result property="orderCreateTime" column="order_creation_date"/>
		<result property="customerRequireTime" column="customer_require_date"/>
		<result property="customerCode" column="customer_code"/>
		<result property="customerName" column="customer_name"/>
		<result property="projectName" column="project_name"/>
		<result property="orderComment" column="comment"/>
	</resultMap>
	<select id="query_DP_V_SO_ORDER_4_PMS"  resultMap="OrderBeans">
		<![CDATA[
			SELECT * from dp_reports.DP_V_SO_ORDER_4_PMS 
		]]>
	</select>
	<!-- 退货信息 -->
	<resultMap class="com.dp.plat.param.OrderBean" id="RmaOrderBeans">
		<result property="orderNumber" column="rma_order_number"/>
		<result property="contractNo" column="contract_number"/>
		<result property="orderExecNumber" column="order_exec_number"/>
		<result property="orderCreateTime" column="order_creation_date"/>
		<result property="customerRequireTime" column="customer_require_date"/>
		<result property="customerCode" column="customer_code"/>
		<result property="customerName" column="customer_name"/>
		<result property="projectName" column="project_name"/>
		<result property="orderComment" column="comment"/>
	</resultMap>
	<select id="query_DP_V_RMA_ORDER_4_PMS" resultMap="RmaOrderBeans">
		<![CDATA[
			SELECT * from dp_reports.DP_V_RMA_ORDER_4_PMS		
		]]>
	</select>
	
	<insert id="insert_pm_order_data" parameterClass="java.util.Map">
		<![CDATA[
			INSERT INTO `pm_order_data_from_sap`( orderNumber ,contractNo , orderExecNumber , orderCreateTime ,customerRequireTime ,
			 customerCode ,customerName,projectName,orderComment,orderType) values
		]]>
		<iterate conjunction="," property="list">
			( #list[].orderNumber#,#list[].contractNo#,#list[].orderExecNumber#,#list[].orderCreateTime#,#list[].customerRequireTime#,
				#list[].customerCode#,#list[].customerName#,#list[].projectName#,#list[].orderComment#,#orderType#
			)
		</iterate>
	</insert>
	<delete id="delete_pm_order_data" >
		<![CDATA[
			truncate table pm_order_data_from_sap
		]]>
	</delete>
	<resultMap class="com.dp.plat.param.OrderLineBean" id="orderLineBeans">
		<result property="orderNumber" column="order_number"/>
		<result property="lineNum" column="LineNum"/>
		<result property="itemCode" column="item_code"/>
		<result property="itemDesc" column="item_description"/>
		<result property="orderQuantity" column="order_quantity" nullValue="0"/>
		<result property="openQuantity" column="open_quantity" nullValue="0"/>
		<result property="bundleCode" column="bundle_parent_item_code"/>
		<result property="warrantyMonth" column="warranty_by_month" nullValue="0"/>
	</resultMap>
	<select id="query_DP_V_SO_LINE_4_PMS" resultMap="orderLineBeans">
		<![CDATA[
			select * from dp_reports.DP_V_SO_LINE_4_PMS
		]]>
	</select>
	
	<select id="query_DP_V_RMA_LINE_4_PMS" resultMap="orderLineBeans">
		<![CDATA[
			SELECT * from dp_reports.DP_V_RMA_LINE_4_PMS
		]]>
	</select>
	<delete id="delete_pm_order_line" >
		<![CDATA[
			truncate table pm_order_line_from_sap
		]]>
	</delete>
	<insert id="insert_pm_order_line" parameterClass="java.util.Map">
		<![CDATA[
			INSERT INTO `pm_order_line_from_sap`(orderNumber ,lineNum ,itemCode ,itemDesc ,
				orderQuantity ,openQuantity ,bundleCode ,warrantyMonth,lineType) values
		]]>
		<iterate conjunction="," property="lineList">
			(
			#lineList[].orderNumber#,#lineList[].lineNum#,#lineList[].itemCode#,#lineList[].itemDesc#,
			#lineList[].orderQuantity#,#lineList[].openQuantity#,#lineList[].bundleCode#,#lineList[].warrantyMonth#,#lineType#
			)
		</iterate>
	</insert>
	<resultMap class="com.dp.plat.data.bean.Product" id="pm_product_list">
		<result property="projectId" column="projectId"/>
		<result property="contractNo" column="contractNo"/>
	</resultMap>
	<select id="query_pm_project_product_line" resultMap="pm_product_list">
		<![CDATA[
			SELECT DISTINCT projectId , contractNo FROM `pm_project_product_line` 
			WHERE contractNo IS NOT NULL AND (projectQuantity IS NULL OR projectQuantity = 0);
		]]>
	</select>
	
	
	<select id="query_2_DP_V_SO_LINE_4_PMS" parameterClass="string" resultMap="orderLineBeans">
		<![CDATA[
			SELECT b.* from dp_reports.DP_V_SO_ORDER_4_PMS a LEFT JOIN dp_reports.DP_V_SO_LINE_4_PMS b on 
			a.order_number = b.order_number where a.contract_number = #contractNo# and  b.order_number is not null
		]]>
	</select>
	
	<delete id="delete_2_pm_project_product_line" parameterClass="com.dp.plat.data.bean.Product">
		<![CDATA[
			DELETE FROM `pm_project_product_line` WHERE projectId = #projectId# AND contractNo = #contractNo#
		]]>
	</delete>
	
	<insert id="insert_2_pm_project_product_line" parameterClass="java.util.Map" >
		<![CDATA[
			INSERT INTO `pm_project_product_line`(`projectId`,`contractNo`,`itemCode`,`itemName`,`orderQuantity`,`deliverQuantity`,`openQuantity`)
			VALUES
		]]>
		<iterate conjunction="," property="productlist">
			(#projectId# , #contractNo# ,#productlist[].itemCode# ,#productlist[].itemDesc# ,#productlist[].orderQuantity# ,#productlist[].deliverQuantity# ,#productlist[].openQuantity#)
		</iterate>
	</insert>
	
	<!-- 日志记录 -->
	
	<insert id="insert_fnd_data_refresh_log" parameterClass="java.util.Map" >
		<![CDATA[
			INSERT INTO fnd_data_refresh_log(refreshTaskName ,handleUser , dataFrom ,dataTo ,refreshFrom) 
			values( #refreshTaskName# ,#handleUser# ,#dataFrom# , #dataTo# , now())
		]]>
		<selectKey resultClass="int"  keyProperty="id">    
             SELECT last_insert_id() as id    
        </selectKey>
	</insert>
	<update id="update_fnd_data_refresh_log_success" parameterClass="java.util.Map">
		<![CDATA[
			update fnd_data_refresh_log set refreshTo = now() , refreshState = #refreshState#
			where id = #id#
		]]>
	</update>
	<update id="update_fnd_data_refresh_log_fail" parameterClass="java.util.Map">
		<![CDATA[
			update fnd_data_refresh_log set refreshException = #refreshException#
			where id = #id#
		]]>
	</update>
	
	<!-- 从SMS刷新项目信息 -->
	<resultMap class="com.dp.plat.param.PrjProperty" id="prjPropertys">
		<result property="orderExecNumber" column="orderCodeReal"/>
		<result property="projectCode" column="projectCode"/>
		<result property="salesManCode" column="usernamec"/>
		<result property="salesManName" column="realName"/>
		<result property="marketCode" column="marketCode"/>
		<result property="marketName" column="marketName"/>
		<result property="systemId" column="systemid" nullValue="-1"/>
		<result property="systemName" column="systemName"/>
		<result property="expendId" column="expendId" nullValue="-1"/>
		<result property="expendName" column="expendName"/>
		<result property="industryId" column="industryid" nullValue="-1"/>
		<result property="industryName" column="industryName"/>
		<result property="officeCode" column="officeCode"/>
		<result property="officeName" column="officeName"/>
		<result property="serviceTypeName" column="serviceTypeName"/>
		<result property="channelName" column="channelName"/>
		<result property="engineeFee" column="engineeFee"/>
		<result property="objId" column="objId"/>
		<result property="applyType" column="applyType"/>
		<result property="corporationCode" column="corporationCode" nullValue="01"/>
	</resultMap>
	<select id="query_v_prj_property_4_pm" resultMap="prjPropertys">
		<![CDATA[
			SELECT * FROM v_prj_property_4_pm
		]]>
	</select>
	<delete id="delete_pm_project_property_from_sms" >
		<![CDATA[
			truncate table pm_project_property_from_sms
		]]>
	</delete>
	<insert id="insert_pm_project_property_from_sms" parameterClass="java.util.Map">
		<![CDATA[
			INSERT INTO pm_project_property_from_sms(`orderExecNumber`,projectCode,`salesManCode`,`salesManName`,`marketCode`,`marketName`,`systemId`,
				`systemName`,`expendId`,`expendName`,`industryId`,`industryName`, officeCode, officeName, 
				serviceTypeName , channelName, engineeFee, objId, applyType, `corporationCode`
				)
			values
		]]>
		<iterate conjunction="," property="list">
			(
			 #list[].orderExecNumber# ,#list[].projectCode#,#list[].salesManCode# ,#list[].salesManName# ,#list[].marketCode# ,#list[].marketName# ,#list[].systemId# ,
			 #list[].systemName# ,#list[].expendId# ,#list[].expendName# ,#list[].industryId# ,#list[].industryName#,#list[].officeCode#,#list[].officeName#,
			 #list[].serviceTypeName# , #list[].channelName#, #list[].engineeFee#, #list[].objId#, #list[].applyType#, #list[].corporationCode#
			)
		</iterate>
	</insert>
	<!-- 刷新OA人员信息 -->
	<resultMap class="com.dp.plat.param.Person" id="person">
		<result property="salesmanCode" column="work_card_number"/>
		<result property="salesmanName" column="staff_name"/>
		<result property="salesmanMail" column="company_mail"/>
		<result property="salesmanTel" column="phone"/>
	</resultMap>
	<select id="query_view_person_info_4_pms" resultMap="person" parameterClass="int">
		<![CDATA[
			select  * from view_person_info_4_pms where staff_status = #staffStatus#  and work_card_number is not NULL;		
		]]>
	</select>
	<update id="update_project_member" parameterClass="string">
		<![CDATA[
			UPDATE pm_project_member SET effectiveTo = NOW() WHERE memberCode LIKE '%$jobNo$' AND memberRole = '10' AND effectiveTo IS NULL
		]]>
	</update>
	<insert id="update_pm_salesmember_info">
		<![CDATA[
			INSERT INTO pm_project_member(projectId , memberRole ,memberCode , memberName , phoneNum ,email ,fromFlag ,createTime ,effectiveFrom )			
			SELECT t1.`projectId` , 10 ,t3.`salesManCode` ,t3.`salesManName`, t4.salesManTel, t4.salesmanMail,1 , NOW() ,NOW() 
			FROM pm_project_header t1
			JOIN pm_project_member t2 ON t1.`projectId` = t2.`projectId` AND t2.`effectiveTo` IS NOT NULL AND t2.`memberRole` = 10
			LEFT JOIN pm_project_property_from_sms t3 ON LEFT(t1.projectCode ,14 )  = LEFT(t3.projectCode ,14 )
			LEFT JOIN pm_person_from_oa t4 ON t4.salesmanCode = RIGHT(t3.`salesManCode` ,5)
			JOIN ( 
				SELECT MAX(id) AS memberId,projectId FROM pm_project_member WHERE memberRole = 10  GROUP BY projectId 
			 ) t  ON t1.projectId = t.projectId AND t2.id = t.memberId
			WHERE t1.`projectState` IN (30,31,32)  AND t2.`memberCode` != t3.`salesManCode` 
		]]>
	</insert>
	
	<delete id="delete_pm_person_from_oa">
		<![CDATA[ truncate table pm_person_from_oa ]]>
	</delete>
	
	<insert id="insert_pm_person_from_oa" parameterClass="java.util.Map">
		<![CDATA[
			insert into pm_person_from_oa(salesmanCode ,salesmanName ,salesmanMail ,salesmanTel)
			values
		]]>
		<iterate conjunction="," property="list">
			(
			#list[].salesmanCode#,	#list[].salesmanName#, #list[].salesmanMail#, #list[].salesmanTel#
			)
		</iterate>
	</insert>
	<update id="update_keshanhui_from_oa" >
		<![CDATA[
			update pm_person_from_oa set salesmanCode='00260' where salesmanCode='02260';
		]]>
	</update>
	<resultMap class="com.dp.plat.data.bean.MailSenderInfo" id="MailInfo">
		<result property="subject" column="mailSubject"/>
		<result property="id" column="id"/>
		<result property="content" column="mailContent"/>
		<result property="tos" column="mailTos"/>
		<result property="ccs" column="mailCcs"/>
		<result property="bcc" column="mailBcc"/>
		<result property="attachFileNames" column="mailAttachFiles"/>
		<result property="mailServerPort" column="mailserverPort"/>
		<result property="mailServerHost" column="mailServerHost"/>
		<result property="userName" column="mailUsername"/>
		<result property="password" column="mailPassword"/>
		<result property="fromAddress" column="mailFromaddress"/>
	</resultMap>
	<select id="query_waiting_mail" resultMap="MailInfo">
		<![CDATA[
			select id, mailSubject ,mailContent,mailTos ,mailCcs ,mailBcc ,
				mailAttachFiles, mailserverPort,mailServerHost ,mailUsername ,mailPassword, 
				mailFromaddress from fnd_mails where sendFlag = 0 and 
				mailExpectSendTime < now()
		]]>
	</select>
	
	<update id="update_waiting_mail" parameterClass="string">
		<![CDATA[
			update fnd_mails set mailSendTime = now(),	sendFlag = 1 where id in ($ids$)
		]]>
	</update>
	
	<!-- 判断表中字段是否存在 -->
	<select id="describe_table_field" parameterClass="java.util.Map" resultClass="int">
		<![CDATA[
			SELECT COUNT(*) FROM information_schema.columns WHERE table_schema= '$dbname$'
				AND table_name= '$tablename$'
				AND column_name= '$fieldname$' 
		]]>
	</select>
	<update id="add_field" parameterClass="java.util.Map">
		<![CDATA[
			ALTER TABLE $tablename$ ADD $fieldname$ $fieldtype$
		]]>
	</update>
	
	<update id="create_shipment_state_tmp">
		<![CDATA[
			CREATE TEMPORARY TABLE IF NOT EXISTS  tmp 
			SELECT	projectId , CASE
			WHEN SUM(openQuantity) = 0 THEN
				-1
			WHEN SUM(openQuantity) = SUM(orderQuantity) THEN
				1
			ELSE
				2
			END AS deliverstate FROM
				pm_project_product_line GROUP BY projectId
		]]>
	</update>
	
	<update id="update_shipment_state" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_project_state t1 , tmp SET t1.`shipmentState` = tmp.deliverstate , t1.`shipmentTime` = NOW() WHERE t1.`projectId` = tmp.projectId ;
		]]>
	</update>
