	   ]]>
	</insert> -->
	
	<insert id="create_temp_max_ppfsId">
        CREATE TEMPORARY TABLE temp_max_ppfsId (KEY id (id)) 
		SELECT 
		    MAX(t2.id) AS id 
		FROM
		    pm_project_property_from_sms t2 
		GROUP BY t2.projectCode 
	</insert>
	
	<insert id="create_temp_max_ppfs">
        CREATE TEMPORARY TABLE temp_max_ppfs (KEY id (id), KEY projectCode (projectCode)) 
		SELECT 
		    id, projectCode, serviceTypeName, channelName, salesManCode, salesManName, corporationCode
		FROM
		    pm_project_property_from_sms t1 
		WHERE id IN 
		    (SELECT 
		        id 
		    FROM
		        temp_max_ppfsId)
    </insert>
    
    <insert id="create_temp_max_prpId">
        CREATE TEMPORARY TABLE temp_max_prpId (KEY id (id)) 
		SELECT 
		    MAX(id) AS id
		FROM
		    `pm_project_related_party` 
		WHERE partyRole = 30 
		    AND effectiveTo IS NULL 
		GROUP BY projectId
	</insert>
	
	<insert id="create_temp_not_ppfs">
	    CREATE TEMPORARY TABLE temp_not_ppfs (KEY id (id)) 
		SELECT 
		    ppfs1.id ,fbd.basicDataName
		FROM
		    pm_project_property_from_sms ppfs1 
		    LEFT JOIN fnd_basic_data fbd 
		        ON ppfs1.serviceTypeName = fbd.basicDataId 
		        AND fbd.dataTypeCode = 21 
		        AND fbd.effectiveFrom 
    </insert>
	
	<insert id="create_temporary_serviceType_and_channelName_table">
        <![CDATA[
            CREATE TEMPORARY TABLE serviceType_and_channelName_table 
            SELECT 
			    ph.`projectId`, ppfs.projectCode, ph.column012, ph.`columno12_readonly`, fbd.basicDataName, ppfs.`serviceTypeName`, ppfs.`channelName`, prp.id, prp.partyName, ppfs.salesManCode, ppfs.salesManName
			FROM
			    pm_project_header ph 
			    LEFT JOIN temp_max_ppfs ppfs 
			        ON ppfs.projectCode = LEFT(ph.projectCode, 15) 
			    LEFT JOIN pm_project_related_party prp 
			        ON ph.`projectId` = prp.projectId 
			        AND prp.id IN 
			        (SELECT 
			            id 
			        FROM
			            temp_max_prpId) 
			    LEFT JOIN fnd_basic_data fbd 
			        ON ppfs.serviceTypeName = fbd.basicDataId 
			        AND fbd.dataTypeCode = 21 
			        AND fbd.effectiveFrom <= NOW() 
			        AND (
			            fbd.effectiveTo > NOW() 
			            OR fbd.effectiveTo IS NULL
			        ) 
			    LEFT JOIN temp_not_ppfs tppfs 
			        ON tppfs.id = ppfs.id 
			        AND ph.`columno12_readonly` = tppfs.basicDataName 
			    LEFT JOIN pm_project_related_party prp1 
			        ON prp1.`id` = prp.`id` 
			        AND (
			            ppfs.`channelName` = prp1.`partyName` 
			            OR ppfs.channelName IS NULL 
			            OR ppfs.`channelName` = ''
			        ) 
			WHERE (
			        tppfs.id IS NULL 
			        OR (
			            prp1.id IS NULL 
			            AND prp.id IS NOT NULL
			        )
			    ) 
			    AND ppfs.`serviceTypeName` IS NOT NULL 
       ]]>
    </insert>
    
    <insert id="create_temp_project_sales_change">
        CREATE TEMPORARY TABLE temp_project_sales_change
		SELECT DISTINCT 
		    t1.`projectId`, 10 AS memberRole, t3.`salesManCode` AS memberCode, t3.`salesManName` AS memberName, t4.salesManTel AS phoneNum, t4.salesmanMail AS email, 1 AS fromFlag, NOW() AS createTime, NOW() AS effectiveFrom 
		FROM
		    pm_project_header t1 
		    LEFT JOIN temp_max_ppfs t3 
		        ON t3.projectCode = LEFT(t1.projectCode, 15)
		    LEFT JOIN 
		        (SELECT 
		            projectId, IFNULL(
		                GROUP_CONCAT(DISTINCT memberCode), ''
		            ) AS salesCodes 
		        FROM
		            pm_project_member 
		        WHERE `memberRole` = 10 
		            AND effectiveTo IS NULL 
		        GROUP BY `projectId`) t2 
		        ON t2.projectId = t1.`projectId` 
		    LEFT JOIN 
		        (SELECT 
		            projectId, IFNULL(
		                GROUP_CONCAT(DISTINCT memberCode), ''
		            ) AS invalidSalesCodes 
		        FROM
		            pm_project_member 
		        WHERE `memberRole` = 10 
		            AND effectiveTo IS NOT NULL 
		        GROUP BY `projectId`) tt2 
		        ON tt2.projectId = t1.`projectId` 
		    LEFT JOIN pm_person_from_oa t4 
		        ON t4.salesmanCode = RIGHT(t3.`salesManCode`, 5) 
		WHERE t1.`projectState` IN (30, 31, 32) 
		    AND (
		        FALSE = FIND_IN_SET(
		            t3.`salesManCode`, CONCAT(
		                IFNULL(t2.salesCodes, ""), ",", IFNULL(tt2.invalidSalesCodes, "")
		            )
		        ) 
		        OR (
		            t4.`salesmanCode` IS NOT NULL 
		            AND FIND_IN_SET(
		                t3.`salesManCode`, IFNULL(tt2.invalidSalesCodes, "")
		            ) 
		            AND FALSE = FIND_IN_SET(
		                t3.`salesManCode`, IFNULL(t2.salesCodes, "")
		            )
		        )
		    )
    </insert>
    
	<update id="update_project_serviceType">
       UPDATE 
	       pm_project_header ph 
	       INNER JOIN serviceType_and_channelName_table t 
	           ON ph.`projectId` = t.projectId 
       SET ph.`column012` = t.basicDataName, ph.`columno12_readonly` = t.basicDataName 
	</update>
	
	<update id="update_project_channelName">
       UPDATE 
	       pm_project_related_party prp 
	       INNER JOIN serviceType_and_channelName_table t 
	           ON prp.`projectId` = t.projectId 
	            AND t.id IS NOT NULL 
       SET prp.`partyName` = t.channelName 
	   WHERE prp.`partyRole` = 30 
	       AND prp.`effectiveTo` IS NULL
    </update>
    
    <update id="update_project_compId">
		UPDATE 
		    `pm_project_header` ph 
		    INNER JOIN `temp_max_ppfs` ppfs 
		        ON ppfs.`projectCode` = LEFT(ph.`projectCode`, 15) 
		    LEFT JOIN fnd_company c FORCE KEY (CODE) 
		        ON ppfs.`corporationCode` = c.code 
		SET ph.`compId` = IFNULL(c.`id`, '0') 
		WHERE ph.`compId` = '0'
    </update>
    
    <delete id="drop_temp_max_ppfsId">
       DROP TEMPORARY TABLE temp_max_ppfsId 
    </delete>
    
    <delete id="drop_temp_max_ppfs">
       DROP TEMPORARY TABLE temp_max_ppfs 
    </delete>
    
    <delete id="drop_temp_max_prpId">
       DROP TEMPORARY TABLE temp_max_prpId 
    </delete>
    
    <delete id="drop_temp_not_ppfs">
       DROP TEMPORARY TABLE temp_not_ppfs 
    </delete>
    
    <delete id="drop_temporary_serviceType_and_channelName_table">
       DROP TEMPORARY TABLE serviceType_and_channelName_table 
    </delete>
    
    <delete id="drop_temp_project_sales_change">
       DROP TEMPORARY TABLE temp_project_sales_change 
    </delete>
    
    
   <!--  <select id="query_project_sales_change" resultClass="java.util.HashMap">
        SELECT 
		    ph.`projectId`, ph.`projectCode`, ph.`projectName`, sl.`memberCode`, sl.`memberName`, ppfs.salesManCode, ppfs.salesManName 
		FROM
		    pm_project_header ph 
		    LEFT JOIN temp_max_ppfs ppfs 
		        ON ph.projectCode LIKE CONCAT(ppfs.projectCode, "%") 
		    LEFT JOIN pm_project_member sl 
		        ON sl.`memberRole` = '10' 
		        AND ph.`projectId` = sl.`projectId`
		        AND sl.`effectiveTo` IS NULL 
		WHERE ph.`projectState` IN ("30", "31", "32") 
		    AND ppfs.salesManCode != sl.`memberCode` 
		GROUP BY ph.projectId
    </select> -->
    
    <update id="invalid_project_invalid_sales">
        UPDATE 
		    pm_project_member pm 
		SET
		    effectiveTo = NOW() 
		WHERE pm.`memberRole` = 10 
		    AND pm.`effectiveTo` IS NULL 
		    AND (
		        pm.`projectId` IN 
		        (SELECT 
		            projectId 
		        FROM
		            temp_project_sales_change) 
		        OR pm.`memberCode` = '' 
		        OR pm.`memberCode` IS NULL
		    )
    </update>
    
    <insert id="insert_changed_project_sales">
        INSERT INTO pm_project_member (
		    projectId, memberRole, memberCode, memberName, phoneNum, email, fromFlag, createTime, effectiveFrom
		) 
		SELECT 
		    projectId, memberRole, memberCode, memberName, phoneNum, email, fromFlag, createTime, effectiveFrom 
		FROM
		    temp_project_sales_change 
    </insert>
</sqlMap>