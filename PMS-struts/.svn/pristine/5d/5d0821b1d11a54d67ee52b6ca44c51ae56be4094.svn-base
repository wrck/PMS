	<delete id="delete_pm_project_real_product_line_from_sms" >
		<![CDATA[
			truncate table pm_project_real_product_line_from_sms
		]]>
	</delete>
	<insert id="insert_pm_project_real_product_line_from_sms" parameterClass="java.util.Map">
		<![CDATA[
			INSERT INTO pm_project_real_product_line_from_sms(projectCode ,orderExecNumber, productFirstName, productName, productSubCode ,productSubModel, productSubName, num, memo)
			values
		]]>
		<iterate conjunction="," property="list">
			(
			 #list[].projectCode# ,#list[].orderExecNumber#,#list[].productFirstName# ,#list[].productName# ,#list[].productSubCode# ,#list[].productSubModel# ,#list[].productSubName# ,
			 #list[].num# ,#list[].memo#
			)
		</iterate>
	</insert>
	
	<delete id="delete_pm_project_product_line_real" >
		<![CDATA[
			truncate table pm_project_product_line_real
		]]>
	</delete>
	<insert id="insert_pm_project_product_line_real">
		<![CDATA[
			INSERT INTO pm_project_product_line_real SELECT 
			 NULL AS id, pph.`projectId`,podfs.`contractNo`, vrp.*  
			FROM
			  pm_project_real_product_line_from_sms vrp 
			  INNER JOIN pm_order_data_from_sap podfs 
			    ON vrp.`orderExecNumber` = podfs.`orderExecNumber` 
			  INNER JOIN pm_project_contract ppc 
			    ON ppc.`contractNo` = podfs.`contractNo` 
			  INNER JOIN pm_project_group_relationship ppgr 
			    ON ppc.`projectGroupCode` = ppgr.`projectGroupCode` 
			  INNER JOIN pm_project_header pph 
			    ON pph.`projectCode` = ppgr.`projectCode`
		]]>
	</insert>
	
	
	<select id="query_pm_self_service_project" resultClass="com.dp.plat.data.bean.Project">
	    <![CDATA[
		    SELECT DISTINCT 
			    `p`.`projectName` AS `projectName`, `p`.`contractNo` AS `contractNo`, `pp`.`officeCode` AS `column001` 
			FROM
			    `view_distinct_contract` `v` 
			    LEFT JOIN `pm_order_data_from_sap` `p` 
			        ON ((`v`.`id` = `p`.`id`)) 
			    LEFT JOIN `pm_project_property_from_sms` `pp` 
			        ON (
			            (
			                `p`.`orderExecNumber` = `pp`.`orderExecNumber`
			            )
			        ) 
			    LEFT JOIN fnd_basic_data fbd 
			        ON pp.serviceTypeName = fbd.basicDataId 
			        AND fbd.dataTypeCode = 21 
			        AND fbd.effectiveFrom <= NOW() 
			        AND (
			            fbd.effectiveTo > NOW() 
			            OR fbd.effectiveTo IS NULL
			        ) 
			WHERE NOT EXISTS 
			    (SELECT 
			        1 
			    FROM
			        (
			            `pm_project_contract` `t1` 
			            JOIN `pm_project_group_relationship` `t2` 
			                ON (
			                    (
			                        `t1`.`projectGroupCode` = `t2`.`projectGroupCode`
			                    )
			                )
			        ) 
			        JOIN `pm_project_header` `t3` 
			            ON (
			                `t2`.`projectCode` = `t3`.`projectCode`
			            ) 
			            AND (`t3`.`effectiveFrom` <= NOW()) 
			            AND (
			                (`t3`.`effectiveTo` > NOW()) 
			                OR ISNULL(`t3`.`effectiveTo`)
			            ) 
			    WHERE (
			            `p`.`contractNo` = `t1`.`contractNo`
			        )) 
			    AND v.contractNo IS NOT NULL
			   AND fbd.`basicDataName` = 3
	   ]]>
	</select>
	
	<select id="query_project_serviceManager_by_officeCode" parameterClass="string" resultClass="com.dp.plat.data.bean.ProjectMember">
        SELECT 
		    CASE
		        WHEN fui.username IS NOT NULL 
		        THEN fui.username 
		        ELSE fupt.username 
		    END AS memberCode,
		    CONCAT (CASE
				        WHEN fui.username IS NOT NULL 
				        THEN fui.username 
				        ELSE fupt.username 
			        END, "-", 
			        CASE
				        WHEN fui.username IS NOT NULL 
				        THEN fui.realName 
				        ELSE fupt.realName 
		            END
	        ) AS memberName
		FROM
		    `fnd_department` fd 
		    LEFT JOIN fnd_user_info fui 
		        ON fd.`departmentNum` = fui.`dpNo` 
		        AND roleIds LIKE "%;11;%" 
		        AND fui.status = 1 
		    LEFT JOIN 
		        (SELECT 
		            fup.* ,fui2.realname
		        FROM
		            fnd_user_power fup 
		            LEFT JOIN fnd_user_info fui2 
		                ON fup.`fndUserId` = fui2.`id` 
		            LEFT JOIN fnd_department fdt 
		                ON fdt.departmentNum = fui2.dpNO 
		        WHERE (
		                roleIds LIKE "%;11;%" 
		                AND fui2.status = 1 
		                AND fup.effectiveTo IS NULL 
		                AND fdt.isparam = 1
		            ) 
		            OR fui2.roleIds LIKE "%;13;%") fupt 
		        ON fupt.`areapower` LIKE CONCAT("%", fd.`departmentNum`, "%") 
		WHERE isparam = 1 and fd.departmentNum = #_parameter#
	</select>
	
	<!-- <insert id="create_temporary_serviceType_and_channelName_table">
	    <![CDATA[
		    CREATE TEMPORARY TABLE serviceType_and_channelName_table 
			SELECT 
