				#plist[].productSubModel# ,#plist[].productSubName# ,#plist[].lendNum# ,#plist[].memo# ,now(),
				#plist[].orderNum#, #plist[].deliverNum#, #plist[].hexiaoNum#, #plist[].transferNum#
