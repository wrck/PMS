            select * from v_lend_products_sale_4_pm
        ]]>
    </select>
	<delete id="delete_pm_presales_lend_info_from_sms">
        truncate pm_presales_lend_info_from_sms;
    </delete>
    <delete id="delete_pm_presales_lend_product_from_sms">
        truncate pm_presales_lend_product_from_sms;
    </delete>
    <delete id="delete_pm_presales_lend_order_from_sms">
        truncate pm_presales_lend_order_from_sms;
    </delete>
	<insert id="insert_pm_presales_lend_info_from_sms" parameterClass="List">
        <![CDATA[
            INSERT INTO pm_presales_lend_info_from_sms( projectCode,  projectName,  marketName,  systemName,  expendName,
             industryName,  officeCode,  dutyName,  pspm,  dutyContactWay,  lendInfoId,
             decPath)
            VALUES
        ]]>
        <iterate conjunction=",">
            (
            #[].projectCode#, #[].projectName#, #[].marketName#, #[].systemName#, #[].expendName#,
            #[].industryName#, #[].officeCode#, #[].dutyName#, #[].pspm#, #[].dutyContactWay#, #[].lendInfoId#,
            #[].decPath#
            )
        </iterate>
    </insert>
    <insert id="insert_pm_presales_lend_product_from_sms" parameterClass="List">
        <![CDATA[
            INSERT INTO pm_presales_lend_product_from_sms(lendInfoId, productFirstName, productName, productSubCode,
               productSubModel, productSubName, lendNum, memo
            ) VALUES
        ]]>
        <iterate conjunction=",">
            (
                #[].lendInfoId# ,#[].productFirstName# ,#[].productName# ,#[].productSubCode# ,
                #[].productSubModel# ,#[].productSubName# ,#[].lendNum# ,#[].memo#
            )
        </iterate>
    </insert>
    <insert id="insert_pm_presales_lend_order_from_sms" parameterClass="List">
        INSERT INTO `pm_presales_lend_order_from_sms` (`id`, `orderNumber`, `ppliCode`, `orderType`, `contract`, 
	        `customer`, `projectName`, `businessunit`, `office`, `dutyperson`, `itemcode`, 
	        `description`, `orderQty`, `dlvQty`, `rmaQty`, `lineStatus`, `createDate`, 
	        `lineId`, `systemId`, `canceled`, `discountVersion`, `borrowNum`) 
        VALUES 
        <iterate conjunction=",">
            (
                #[].id#, #[].orderNumber#, #[].ppliCode#, #[].orderType#, #[].contract#, 
	            #[].customer#, #[].projectName#, #[].businessunit#, #[].office#, #[].dutyperson#, #[].itemcode#, 
	            #[].description#, #[].orderQty#, #[].dlvQty#, #[].rmaQty#, #[].lineStatus#, #[].createDate#, 
	            #[].lineId#, #[].systemId#, #[].canceled#, #[].discountVersion#, #[].borrowNum#
            )
        </iterate>
    </insert>
    <update id="updatePresalesTransferState">
        UPDATE 
            pm_presales_project_header pph
            LEFT JOIN 
                (SELECT DISTINCT 
                    contract AS projectCode, IF(borrowNum > 0, 1, 0) AS hasTransfer 
                FROM
                    `pm_presales_lend_order_from_sms` plr 
                WHERE borrowNum > 0) plr 
                ON pph.`projectCode` = plr.projectCode SET pph.hasTransfer = IFNULL(plr.hasTransfer, 0) 
        WHERE plr.hasTransfer = 1
    </update>
	<resultMap class="int" id="lendIdMap">
		<result property="lendInfoId" column="lendInfoId"/>
	</resultMap>
