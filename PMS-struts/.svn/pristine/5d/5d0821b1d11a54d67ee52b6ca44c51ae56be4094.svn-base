		<result property="productName" column="productName"/>
		<result property="productSubCode" column="productsubCode"/>
		<result property="productSubModel" column="productSubModel"/>
		<result property="productSubName" column="productSubName"/>
		<result property="lendNum" column="lendNum"/>
