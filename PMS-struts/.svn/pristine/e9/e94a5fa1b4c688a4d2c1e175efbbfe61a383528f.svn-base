<?xml version="1.0" encoding="UTF-8"?>  
<!DOCTYPE sqlMap  
PUBLIC "-//ibatis.apache.org//DTD SQL MAP 2.0//EN"  
"http://ibatis.apache.org/dtd/sql-map-2.dtd"> 
<!-- 售前测试项目数据库操作--> 
<sqlMap>
	<typeAlias alias="Presales" type="com.dp.plat.data.bean.Presales"/>
	<typeAlias alias="PresalesProduct" type="com.dp.plat.data.bean.PresalesProduct"/>
	<resultMap class="Presales" id="PresalesMap">
		<result property="presalesId" column="presalesId"/>
		<result property="instId" column="instId"/>
		<result property="applyState" column="applyState" nullValue="-1"/>
		<result property="applyBy" column="applyBy"/>
		<result property="applyTime" column="applyTime"/>
		<result property="endTime" column="endTime"/>
		<result property="presalesCode" column="pcode"/>
		<result property="projectCode" column="opcode"/>
		<result property="projectName" column="projectName"/>
		<result property="projectState" column="projectState"/>
		<result property="projectType" column="projectType"/>
		<result property="projectTypeName" column="projectTypeName"/>
		<result property="marketName" column="marketName"/>
		<result property="systemName" column="systemName"/>
		<result property="expendName" column="expendName"/>
		<result property="industryName" column="industryName"/>
		<result property="officeCode" column="officeCode"/>
		<result property="officeName" column="officeName"/>
		<result property="salesman" column="salesman"/>
		<result property="salesmanLink" column="salesmanLink"/>
		<result property="productManager" column="productManager"/>
		<result property="serviceManager" column="serviceManager"/>
		<result property="serviceManagerName" column="serviceManagerName"/>
		<result property="projectManager" column="projectManager"/>
		<result property="projectManagerName" column="projectManagerName"/>
		<result property="confirmFileIds" column="confirmFileIds"/>
		<result property="taskId" column="taskId"/>
		<result property="quesnaireId" column="quesnaireId" nullValue="0"/>
		<result property="quesnaireState" column="quesnaireState" nullValue="0"/>
		<result property="taskDefKey" column="taskDefKey"/>
		<result property="taskAssignee" column="taskAssignee"/>
		<result property="lendfiles" column="lendfiles"/>
		<result property="lendInfoId" column="lendInfoId" nullValue="0"/>
		<result property="finshedTime" column="eventActualFinishDate"/>
		<result property="applyDuration" column="applyDuration"/>
		<result property="totalDuration" column="totalDuration"/>
		<result property="serviceDuration" column="serviceDuration"/>
		<result property="programDuration" column="programDuration"/>
		<result property="testDuration" column="testDuration"/>
		<result property="callbackDuration" column="callbackDuration"/>
		<result property="hasTransfer" column="hasTransfer"/>
		<result property="hasRma" column="hasRma"/>
	</resultMap>
	<select id="query_presales_byid" parameterClass="int" resultMap="PresalesMap">
		<![CDATA[
			SELECT t1.* ,CASE WHEN t1.presalesCode IS NULL THEN t1.projectCode ELSE t1.presalesCode END AS pcode , t1.projectCode as opcode, t2.`departmentName` AS officeName , 
			t3.`memberCode`  AS serviceManager,t3.`memberName` AS serviceManagerName,
			t4.`memberCode` AS projectManager ,t4.`memberName` AS projectManagerName, t5.ASSIGNEE_ as taskAssignee,
			t5.`ID_` AS taskId , t6.`quesnaireId` , t6.`quesnaireState` ,t5.TASK_DEF_KEY_ AS taskDefKey ,t7.eventActualFinishDate,
			t8.`basicDataName` as projectTypeName,
			pppd.applyDuration, pppd.totalDuration, pppd.serviceDuration, pppd.programDuration, pppd.testDuration, pppd.callbackDuration
			FROM pm_presales_project_header t1
			LEFT JOIN fnd_department t2 ON t1.`officeCode` = t2.`departmentNum`
			LEFT JOIN pm_project_member t3 ON t3.`projectId` = t1.`presalesId` AND t3.`memberRole` = '20' AND t3.`effectiveTo` IS NULL
			LEFT JOIN pm_project_member t4 ON t4.`projectId` = t1.`presalesId` AND t4.`memberRole` = '30' AND t4.`effectiveTo` IS NULL
			LEFT JOIN act_ru_task t5 ON t5.`PROC_INST_ID_` = t1.`instId`
			LEFT JOIN pm_presales_project_callback t6 ON t1.`presalesId` = t6.`presalesId` AND t5.`ID_` = t6.`taskId`
			LEFT JOIN pm_project_task t7 ON t7.projectId = t1.presalesId AND t7.taskTypeId = "completeTest"
			LEFT JOIN fnd_basic_data t8 ON t8.`basicDataId` = t1.`projectType` AND t8.`dataTypeCode` = "presalesType" AND t8.`effectiveTo` IS NULL
			LEFT JOIN view_presales_project_duration pppd ON pppd.presalesId = t1.presalesId
			WHERE t1.presalesId = #presalesId#
		]]>
	</select>
	<resultMap class="PresalesProduct" id="PresalesProductMap">
		<result property="productLineId" column="productLineId"/>
		<result property="presalesId" column="presalesId" nullValue="0"/>
		<result property="productFirstName" column="productFirstName"/>
		<result property="productTypeName" column="productTypeName"/>
		<result property="itemCode" column="itemCode"/>
		<result property="itemModel" column="itemModel"/>
		<result property="itemDesc" column="itemDesc"/>
		<result property="productNum" column="productNum"/>
		<result property="transferNum" column="transferNum"/>
		<result property="hexiaoNum" column="hexiaoNum"/>
		<result property="remark" column="remark"/>
	</resultMap>
	<select id="query_presalesproduct_by_presalesid" parameterClass="int" resultMap="PresalesProductMap">
		<![CDATA[
			SELECT * FROM pm_presales_project_product_line WHERE ( presalesId = #presalesId# OR 
				lendInfoId = (SELECT lendInfoId FROM pm_presales_project_header WHERE presalesId = #presalesId#)
			) AND effectiveTo IS NULL
		]]>
	</select>
	
	<update id="update_invalid_member_bymemberRole" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_project_member SET effectiveTo = NOW() WHERE projectId = #objId# AND memberRole = #memberRole#;
		]]>
	</update>
	
	<select id="query_presales_count" parameterClass="Presales" resultClass="int">
		<![CDATA[
			SELECT COUNT(DISTINCT t1.`presalesId`) FROM pm_presales_project_header t1 LEFT JOIN act_ru_task t2 ON t1.`instId` = t2.`PROC_INST_ID_`
			LEFT JOIN pm_project_member t3 ON t1.`presalesId` = t3.`projectId` AND t3.`memberRole` = '20' AND t3.`effectiveTo` IS NULL
			LEFT JOIN pm_project_member t4 ON t1.`presalesId` = t4.`projectId` AND t4.`memberRole` = '30' AND t4.`effectiveTo` IS NULL
		]]>
		<isEqual property="searchTimeType" compareValue="testCompleteTime">
            LEFT JOIN `act_hi_taskinst` cbt ON cbt.PROC_INST_ID_ = t1.instId AND cbt.TASK_DEF_KEY_ = 'usertask4' 
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackQuesnarieTime">
            LEFT JOIN `pm_presales_project_callback` pcb ON pcb.presalesId = t1.presalesId AND pcb.quesnaireState = 1
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackCompleteTime">
            LEFT JOIN `act_hi_taskinst` cbt ON cbt.PROC_INST_ID_ = t1.instId AND cbt.TASK_DEF_KEY_ = 'usertask4' 
        </isEqual>
			WHERE 1 = 1
		<isNotEmpty prepend="and" property="serviceManager">
		 	<![CDATA[ (t3.`memberCode` = #serviceManager#  or t4.`memberCode` = #serviceManager# ) ]]> 
		</isNotEmpty>
		<isNotEmpty prepend="and" property="projectManager">
			<![CDATA[ t4.`memberCode` = #projectManager#]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="presalesCode">
			<![CDATA[( t1.projectCode = #presalesCode# or t1.presalesCode = #presalesCode# )]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="projectName">
			<![CDATA[ t1.projectName like '%$projectName$%']]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="projectType">
            <![CDATA[ t1.projectType = #projectType#]]>
        </isNotEmpty>
		<isNotEmpty prepend="and" property="officeCode">
			<![CDATA[ t1.officeCode = #officeCode#]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="projectState">
			<![CDATA[ t1.projectState = #projectState#]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="projectStates">
            <![CDATA[ FIND_IN_SET(t1.projectState, #projectStates#) ]]>
        </isNotEmpty>
		<isNotEmpty prepend="and" property="hasTransfer">
            <![CDATA[ t1.hasTransfer = #hasTransfer#]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="hasRma">
            <![CDATA[ t1.hasRma = #hasRma#]]>
        </isNotEmpty>
        <isEqual property="searchTimeType" compareValue="applyTime">
            <isNotNull prepend="AND" property="searchStartTime"> t1.applyTime >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ t1.applyTime <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="endTime">
            <isNotNull prepend="AND" property="searchStartTime"> t1.endTime >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ t1.endTime <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="testCompleteTime">
            <isNotNull prepend="AND" property="searchStartTime"> cbt.START_TIME_ >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ cbt.START_TIME_ <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackQuesnarieTime">
            <isNotNull prepend="AND" property="searchStartTime"> pcb.createTime >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ pcb.createTime <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackCompleteTime">
            <isNotNull prepend="AND" property="searchStartTime"> cbt.END_TIME_ >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ cbt.END_TIME_ <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
	</select>
	<resultMap class="Presales" id="PresalesListMap">
		<result property="presalesId" column="presalesId"/>
		<result property="instId" column="instId"/>
		<result property="applyState" column="applyState" nullValue="-1"/>
		<result property="applyBy" column="applyBy"/>
		<result property="applyTime" column="applyTime"/>
		<result property="endTime" column="endTime"/>
		<result property="presalesCode" column="pcode"/>
		<result property="projectName" column="projectName"/>
		<result property="projectType" column="projectType"/>
		<result property="marketName" column="marketName"/>
		<result property="systemName" column="systemName"/>
		<result property="expendName" column="expendName"/>
		<result property="industryName" column="industryName"/>
		<result property="officeCode" column="officeCode"/>
		<result property="officeName" column="officeName"/>
		<result property="salesman" column="salesman"/>
		<result property="salesmanLink" column="salesmanLink"/>
		<result property="productManager" column="productManager"/>
		<result property="serviceManager" column="serviceManager"/>
		<result property="serviceManagerName" column="serviceManagerName"/>
		<result property="projectManager" column="projectManager"/>
		<result property="projectManagerName" column="projectManagerName"/>
		<result property="taskId" column="taskId"/>
		<result property="taskAssignee" column="ASSIGNEE_"/>
		<result property="taskAssigneeName" column="ASSIGNEE_NAME"/>
		<result property="taskName" column="NAME_"/>
		<result property="taskDefKey" column="taskDefKey"/>
		<result property="projectState" column="projectState"/>
		<result property="projectStateName" column="projectStateName"/>
		<result property="projectTypeName" column="projectTypeName"/>
		<result property="hasTransfer" column="hasTransfer"/>
		<result property="hasRma" column="hasRma"/>
	</resultMap>
	<select id="query_presales_list" parameterClass="java.util.Map" resultMap="PresalesListMap">
		<![CDATA[
			SELECT t1.* ,CASE WHEN t1.presalesCode IS NULL THEN t1.projectCode ELSE t1.presalesCode END AS pcode ,t5.`departmentName` AS officeName , 
				t3.`memberCode`  AS serviceManager,t3.`memberName` AS serviceManagerName,
				t4.`memberCode` AS projectManager ,t4.`memberName` AS projectManagerName ,
				t2.`ID_`  AS taskId,t2.`ASSIGNEE_` ,t2.`NAME_` , CONCAT(t6.`username` , '-',t6.`realName`) AS ASSIGNEE_NAME,
				t2.TASK_DEF_KEY_ AS taskDefKey ,t7.`basicDataName` AS projectStateName,
				t8.`basicDataName` AS projectTypeName
			FROM pm_presales_project_header t1 LEFT JOIN act_ru_task t2 ON t1.`instId` = t2.`PROC_INST_ID_`
			LEFT JOIN pm_project_member t3 ON t1.`presalesId` = t3.`projectId` AND t3.`memberRole` = '20' AND t3.`effectiveTo` IS NULL
			LEFT JOIN pm_project_member t4 ON t1.`presalesId` = t4.`projectId` AND t4.`memberRole` = '30' AND t4.`effectiveTo` IS NULL
			LEFT JOIN fnd_department t5 ON t1.`officeCode` = t5.`departmentNum` AND t5.`status` = 1
			LEFT JOIN fnd_user_info t6 ON t2.`ASSIGNEE_` = t6.`username`
			LEFT JOIN fnd_basic_data t7 ON t7.`basicDataId` = t1.`projectState` AND t7.`dataTypeCode` = 27 AND t7.`effectiveTo` IS NULL
			LEFT JOIN fnd_basic_data t8 ON t8.`basicDataId` = t1.`projectType` AND t8.`dataTypeCode` = "presalesType" AND t8.`effectiveTo` IS NULL
		]]>
		<isEqual property="presales.searchTimeType" compareValue="testCompleteTime">
			LEFT JOIN `act_hi_taskinst` cbt ON cbt.PROC_INST_ID_ = t1.instId AND cbt.TASK_DEF_KEY_ = 'usertask4' 
		</isEqual>
		<isEqual property="presales.searchTimeType" compareValue="callbackQuesnarieTime">
            LEFT JOIN `pm_presales_project_callback` pcb ON pcb.presalesId = t1.presalesId AND pcb.quesnaireState = 1
        </isEqual>
		<isEqual property="presales.searchTimeType" compareValue="callbackCompleteTime">
		    LEFT JOIN `act_hi_taskinst` cbt ON cbt.PROC_INST_ID_ = t1.instId AND cbt.TASK_DEF_KEY_ = 'usertask4' 
        </isEqual>
			where 1 = 1 
		<isNotEmpty prepend="and" property="presales.serviceManager">
		 	<![CDATA[ (t3.`memberCode` = #presales.serviceManager#  or t4.`memberCode` = #presales.serviceManager# ) ]]> 
		</isNotEmpty>
		<isNotEmpty prepend="and" property="presales.projectManager">
			<![CDATA[ t4.`memberCode` = #presales.projectManager#]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="presales.presalesCode">
			<![CDATA[ (t1.projectCode = #presales.presalesCode# or t1.presalesCode = #presales.presalesCode# )]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="presales.projectName">
			<![CDATA[ t1.projectName like '%$presales.projectName$%']]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="presales.projectType">
            <![CDATA[ t1.projectType = #presales.projectType#]]>
        </isNotEmpty>
		<isNotEmpty prepend="and" property="presales.officeCode">
			<![CDATA[ t1.officeCode = #presales.officeCode#]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="presales.projectState">
			<![CDATA[ t1.projectState = #presales.projectState#]]>
		</isNotEmpty>
		<isNotEmpty prepend="and" property="presales.projectStates">
            <![CDATA[ FIND_IN_SET(t1.projectState, #presales.projectStates#) ]]>
        </isNotEmpty>
		<isNotEmpty prepend="and" property="presales.hasTransfer">
            <![CDATA[ t1.hasTransfer = #presales.hasTransfer#]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="presales.hasRma">
            <![CDATA[ t1.hasRma = #presales.hasRma#]]>
        </isNotEmpty>
        
        
        <isEqual property="presales.searchTimeType" compareValue="applyTime">
            <isNotNull prepend="AND" property="presales.searchStartTime"> t1.applyTime >= #presales.searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="presales.searchEndTime"> <![CDATA[ t1.applyTime <= #presales.searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="presales.searchTimeType" compareValue="endTime">
            <isNotNull prepend="AND" property="presales.searchStartTime"> t1.endTime >= #presales.searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="presales.searchEndTime"> <![CDATA[ t1.endTime <= #presales.searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="presales.searchTimeType" compareValue="testCompleteTime">
            <isNotNull prepend="AND" property="presales.searchStartTime"> cbt.START_TIME_ >= #presales.searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="presales.searchEndTime"> <![CDATA[ cbt.START_TIME_ <= #presales.searchEndTime# ]]> </isNotNull>
            GROUP BY t1.presalesId
        </isEqual>
        <isEqual property="presales.searchTimeType" compareValue="callbackQuesnarieTime">
            <isNotNull prepend="AND" property="presales.searchStartTime"> pcb.createTime >= #presales.searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="presales.searchEndTime"> <![CDATA[ pcb.createTime <= #presales.searchEndTime# ]]> </isNotNull>
            GROUP BY t1.presalesId
        </isEqual>
        <isEqual property="presales.searchTimeType" compareValue="callbackCompleteTime">
            <isNotNull prepend="AND" property="presales.searchStartTime"> cbt.END_TIME_ >= #presales.searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="presales.searchEndTime"> <![CDATA[ cbt.END_TIME_ <= #presales.searchEndTime# ]]> </isNotNull>
            GROUP BY t1.presalesId
        </isEqual>
		<![CDATA[ ORDER BY t1.`applyTime` DESC]]>
		<isNotEmpty property="displayParam.offset">
			<![CDATA[ limit #displayParam.offset#, #displayParam.pagesize# ]]> 
		</isNotEmpty>
	</select>
	<update id="update_presales_header" parameterClass="Presales">
		<!-- <![CDATA[
			UPDATE pm_presales_project_header SET projectType = IFNULL(#projectType#, projectType), confirmFileIds = #confirmFileIds#,updateBy = #updateBy# ,updateTime = #updateTime# 
			WHERE presalesId = #presalesId#
		]]> -->
		UPDATE pm_presales_project_header SET updateTime = IFNULL(#updateTime#, now())
		    <isNotEmpty prepend="," property="updateBy"> updateBy = #updateBy# </isNotEmpty>
		    <isNotEmpty prepend="," property="confirmFileIds"> confirmFileIds = #confirmFileIds# </isNotEmpty>
            <isNotEmpty prepend="," property="projectType"> projectType = #projectType# </isNotEmpty>
            <isNotEmpty prepend="," property="closeRemark"> closeRemark = #closeRemark# </isNotEmpty>
            WHERE presalesId = #presalesId#
	</update>
	
	<select id="query_presales_callbackId" parameterClass="Presales" resultClass="int">
		<![CDATA[ 
			SELECT id FROM pm_presales_project_callback WHERE presalesId = #presalesId# AND taskId = #taskId#
		]]>
	</select>
	<select id="query_presales_quesnaireId" parameterClass="Presales" resultClass="int">
		<![CDATA[
			SELECT quesnaireId FROM pm_presales_project_callback WHERE presalesId = #presalesId# AND taskId = #taskId#
		]]>
	</select>
	<update id="update_presales_quesnaire" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_presales_project_callback SET quesnaireId = #quesnaireId#,
				quesnaireState = #quesnaireState#,updateBy = #updateBy#,updateTime = #updateTime# WHERE id = #callbackQuesnaireId#;
		]]>
	</update>
	<select id="query_presales_version" parameterClass="int" resultClass="int">
		<![CDATA[
			SELECT COUNT(*) FROM pm_presales_project_callback WHERE presalesId = #presalesId#;
		]]>
	</select>
	<insert id="insert_presales_quesnaire" parameterClass="java.util.Map">
		<![CDATA[
			INSERT INTO pm_presales_project_callback(presalesId ,taskId ,quesnaireId ,quesnaireVersion ,quesnaireState ,createBy ,
			createTime , effectiveFrom )
			values(
			#presalesId# , #taskId# , #quesnaireId#, #quesnaireVersion# , #quesnaireState#, #createBy# , #createTime#, now()
			)
		]]>
	</insert>
	
	<update id="update_presales_state" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_presales_project_header SET presalesId = #presalesId#
		]]>
		<isNotEmpty prepend="," property="applyState">
			<![CDATA[ applyState = #applyState#]]>	
		</isNotEmpty>
		<isNotEmpty prepend="," property="endTime">
			<![CDATA[ endTime = #endTime#]]>
		</isNotEmpty>
		<isNotEmpty prepend="," property="projectState">
			<![CDATA[ projectState = #projectState#]]>
		</isNotEmpty>
			WHERE presalesId = #presalesId#
	</update>
	<select id="query_presales_code_num" parameterClass="int" resultClass="int">
		<![CDATA[
			SELECT COUNT(*) AS num FROM pm_presales_project_header WHERE projectCode = (
				SELECT projectCode FROM  pm_presales_project_header  WHERE presalesId = #presalesId#) 
			AND projectState != 10
		]]>
	</select>
	
	<update id="update_presales_code" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_presales_project_header SET presalesCode = CONCAT( projectCode , '-', $num$) 
			WHERE presalesId =  #presalesId#; 
		]]>
	</update>
	<update id="update_presales_product" parameterClass="int">
		<![CDATA[
			UPDATE pm_presales_project_product_line t1 , pm_presales_project_header t2 SET t1.`presalesId` = t2.`presalesId`
			WHERE t1.`lendInfoId` = t2.`lendInfoId` AND t2.`presalesId` = #presalesId#
		]]>
	</update>
	<select id="query_presales_task_size" parameterClass="java.util.Map" resultClass="int">
		<![CDATA[
			SELECT COUNT(*) FROM pm_project_task WHERE projectId = #projectId# AND projectType = #projectType#
		]]>
	</select>
	<insert id="insert_presales_tasks" parameterClass="java.util.Map" >
		<![CDATA[
			INSERT INTO pm_project_task(projectId ,projectType ,taskTypeCode ,taskTypeId , remark, createTime ,createBy,effectiveFrom )
			SELECT $projectId$ , $projectType$, dataTypeCode , basicDataId , null, NOW() ,#createBy# , NOW() FROM fnd_basic_data 
			WHERE dataTypeCode = #taskTypeCode#
			order by sortId
		]]>
	</insert>
	<resultMap class="com.dp.plat.data.bean.PresalesTask" id="PresalesTaskMap">
		<result property="taskId" column="taskId"/>
		<result property="projectId" column="projectId"/>
		<result property="projectType" column="projectType"/>
		<result property="taskTypeCode" column="taskTypeCode"/>
		<result property="taskTypeId" column="taskTypeId"/>
		<result property="taskName" column="taskName"/>
		<result property="taskState" column="taskState"/>
		<result property="taskStateName" column="taskStateName"/>
		<result property="eventActualFinishDate" column="eventActualFinishDate"/>
		<result property="deliverFileIds" column="deliverFileIds"/>
		<result property="remark" column="remark"/>
	</resultMap>
	<select id="query_presales_en_task" parameterClass="java.util.Map" resultMap="PresalesTaskMap">
		<![CDATA[
			SELECT t2.`basicDataName` AS taskName ,CASE WHEN t1.eventActualFinishDate IS NULL THEN 0 ELSE 1 END taskState ,
			CASE WHEN t1.eventActualFinishDate IS NULL THEN '未完成' ELSE '已完成' END taskStateName   , t1.*   
			FROM pm_project_task t1
			LEFT JOIN fnd_basic_data t2 ON t1.`taskTypeCode` = t2.`dataTypeCode` AND t1.`taskTypeId` = t2.`basicDataId`
			AND t2.`effectiveTo` IS NULL
			WHERE t1.`projectId` = #projectId#  AND t1.`projectType` = #projectType# AND t1.`effectiveTo` IS NULL;
		]]>
	</select>
	<update id="update_presales_task_files" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_project_task SET deliverFileIds =  CASE WHEN  deliverFileIds IS NULL OR deliverFileIds = '' THEN '$fileIds$' ELSE CONCAT(deliverFileIds ,',', '$fileIds$') END WHERE taskId = #taskId#;    
		]]>
	</update>
	<update id="update_presales_task_finshedtime" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_project_task SET taskId = #taskId#
		]]>
		<isNotEmpty prepend="," property="taskFinshedTime"> eventActualFinishDate = #taskFinshedTime# </isNotEmpty>
		<isNotEmpty prepend="," property="remark"> remark = #remark# </isNotEmpty>
		WHERE taskId = #taskId#
	</update>
	<update id="update_presales_confirmfiles" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_presales_project_header SET confirmFileIds = CASE WHEN  confirmFileIds IS NULL OR confirmFileIds = '' THEN '$fileIds$' ELSE CONCAT(confirmFileIds ,',', '$fileIds$') END 
			WHERE presalesId = #presalesid#;    
		]]>
	</update>
	
	<update id="update_presales_task_deliverFileIds_delete" parameterClass="java.util.Map">
		<![CDATA[
			update pm_project_task t1
	        inner join
			    (select 
			        @temp:=t2.deliverFileIds as deliverFileIds,
			            t2.taskId,
			            t2.projectId
			    from
			        pm_project_task t2
			    where
			        t2.taskId = #taskId#
			            and t2.projectId = #projectId# ) t2 ON t1.taskId = t2.taskId
			        and t1.projectId = t2.projectId 
			set 
			    t1.deliverFileIds = case
			        when t1.deliverFileIds like '%$fileId$,%' then replace(@temp, '$fileId$,', '')
					when t1.deliverFileIds like '%,$fileId$' then replace(@temp, ',$fileId$', '')
			        else replace(@temp, '$fileId$', null)
			    end
			where
			    t1.taskId = #taskId#
			        and t1.projectId = #projectId#;
		]]>
	</update>
	
	<update id="update_presales_confirmfiles_delete" parameterClass="java.util.Map">
		<![CDATA[
			update pm_presales_project_header t1
			        inner join
			    (select 
			        @temp:=t2.confirmFileIds as confirmFileIds, t2.presalesId
			    from
			        pm_presales_project_header t2
			    where
			        t2.presalesId = #presalesId# ) t2 ON t1.presalesId = t2.presalesId 
			set 
			    t1.confirmFileIds = case
			        when t1.confirmFileIds like '%$fileId$,%' then replace(@temp, '$fileId$,', '')
			        when t1.confirmFileIds like '%,$fileId$' then replace(@temp, ',$fileId$', '')
			        else replace(@temp, '$fileId$', null)
			    end
			where
			    t1.presalesId = #presalesId#;
		]]>
	</update>
	
	<select id="query_presale_shipmentInfo" parameterClass="map" resultClass="com.dp.plat.data.bean.ShipmentInfo">
		SELECT 
		    `c`.`contract_code` AS `contractNo`, `sb`.`item` AS `itemCode`, `fi`.`describe_` AS `itemName`, `sb`.`barcode` AS `barCode`, s.`packdate` AS packdate, s.`receiveName`, fd.`basicDataName` AS emsCompany, s.`emsNum`, NULL as rmaNo
		FROM
		    `fb_contract` `c` 
		    LEFT JOIN `fb_shipment` `s` 
		        ON `c`.`contract_id` = `s`.`con_id` 
		    LEFT JOIN `fb_shipment_barcode` `sb` 
		        ON `s`.`packlist_id` = `sb`.`pack_id` 
		    LEFT JOIN `fb_items` `fi` 
		        ON `sb`.`item` = `fi`.`item` 
		    LEFT JOIN `fnd_basic_data` `fd` 
		        ON `s`.`emsCompany` = `fd`.`basicDataId` 
		        AND `fd`.`dataTypeCode` = '01' 
		WHERE `sb`.`barcode` IS NOT NULL 
		    AND (
                ISNULL(`sb`.`rma_no`) 
                OR (`sb`.`rma_no` = '') 
                OR (`sb`.`rma_no` = 'null')
            ) 
		    AND contract_code = #projectCode#
	   <isEqual property="containRma" compareValue="true">
	    UNION ALL 
		SELECT 
		    `c`.`contract_code` AS `contractNo`, `sb`.`item` AS `itemCode`, `fi`.`describe_` AS `itemName`, `sb`.`barcode` AS `barCode`, s.`packdate` AS packdate, s.`receiveName`, fd.`basicDataName` AS emsCompany, s.`emsNum`, sb.`rma_no` AS rmaNo 
		FROM
		    `fb_contract` `c` 
		    LEFT JOIN `fb_shipment` `s` 
		        ON `c`.`contract_id` = `s`.`con_id` 
		    LEFT JOIN `fb_shipment_barcode` `sb` 
		        ON `s`.`packlist_id` = `sb`.`pack_id` 
		    LEFT JOIN `fb_items` `fi` 
		        ON `sb`.`item` = `fi`.`item` 
		    LEFT JOIN `fnd_basic_data` `fd` 
		        ON `s`.`emsCompany` = `fd`.`basicDataId` 
		        AND `fd`.`dataTypeCode` = '01' 
		WHERE `sb`.`barcode` IS NOT NULL 
		    AND FALSE = (
		        ISNULL(`sb`.`rma_no`) 
		        OR (`sb`.`rma_no` = '') 
		        OR (`sb`.`rma_no` = 'null')
		    ) 
		    AND c.`contract_code` = #projectCode#
       </isEqual>
	</select>
	
	<select id="query_presale_lend_2_sale" parameterClass="string" resultClass="java.util.HashMap">
        SELECT * FROM pm_presales_lend_2_sale_from_sms 
        WHERE projectCode = #projectCode#
    </select>

    <select id="query_presale_lend_2_rma" parameterClass="string" resultClass="java.util.HashMap" remapResults="true" >
        SELECT 
		    s.orderNumber, s.ppliCode, s.orderType, s.contract, s.itemcode, s.description, s.orderQty, s.dlvQty, s.rmaQty, s.createDate, s.canceled, pdo.deliveryDate, pdo.rmaDate
		FROM
		    pm_presales_lend_2_rma_from_sms s 
		    LEFT JOIN `pm_presales_lend_2_delivery_off_from_sap` pdo 
		        ON pdo.`orderNumber` = s.`orderNumber` 
		        AND pdo.`lineId` = s.`lineId` 
		WHERE s.contract = #projectCode#
		UNION
		SELECT 
		    s.orderNumber, s.contract, s.orderType, s.ppliCode, s.itemcode, s.description, s.orderQty, s.dlvQty, s.rmaQty, s.createDate, s.canceled, pdo.deliveryDate, pdo.rmaDate
		FROM
		    pm_presales_lend_2_rma_from_sms s 
		    LEFT JOIN `pm_presales_lend_2_delivery_off_from_sap` pdo 
		        ON pdo.`orderNumber` = s.`orderNumber` 
		        AND pdo.`lineId` = s.`lineId` 
		WHERE s.ppliCode = #projectCode#
		ORDER BY createDate, itemcode;
    </select>
	
	<select id="queryPresalesExportData" parameterClass="Presales" resultClass="com.dp.plat.data.vo.PresalesExportVO" remapResults="true">
	    SELECT 
	    <isEqual property="searchTimeType" compareValue="testCompleteTime">
	        <isNotEqual property="exportDetail" compareValue="2">DISTINCT</isNotEqual>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackQuesnarieTime">
            <isNotEqual property="exportDetail" compareValue="2">DISTINCT</isNotEqual>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackCompleteTime">
            <isNotEqual property="exportDetail" compareValue="2">DISTINCT</isNotEqual>
        </isEqual>
		    t1.presalesId, t1.instId, IFNULL(t1.applyState, - 1) AS applyState, t1.applyTime, t1.endTime, t1.projectState, 
		    t1.projectCode, t1.projectName, t1.projectType, t1.marketName, t1.systemName, t1.expendName, t1.industryName, 
		    t1.officeCode, t1.salesman, t1.productManager, t1.closeRemark,
		    IF(
		        t1.confirmFileIds IS NULL 
		        AND pd.deliverableType IS NULL, '否', '是'
		    ) AS isUpload, t1.hasTransfer AS hasTransfer, t1.hasRma AS hasRma,  IFNULL(
		        pd.deliverableType, IF(
		            t1.confirmFileIds IS NOT NULL, '历史附件', ''
		        )
		    ) AS deliverableType, IFNULL(pt.taskTypeName, IF(t1.projectState = 10, "待开始", "已完成")) AS taskTypeName, 
		    CASE
		        WHEN t1.presalesCode IS NULL 
		        THEN t1.projectCode 
		        ELSE t1.presalesCode 
		    END AS presalesCode, t5.`departmentName` AS officeName, t3.`memberCode` AS serviceManager, t3.`memberName` AS serviceManagerName, t4.`memberCode` AS projectManager, t4.`memberName` AS projectManagerName, t2.`ID_` AS taskId, t2.`ASSIGNEE_` AS taskAssignee, t2.`NAME_` AS taskName, t2.TASK_DEF_KEY_ AS taskDefKey, CONCAT(t6.`username`, '-', t6.`realName`) AS taskAssigneeName, t7.`basicDataName` AS projectStateName, t8.basicDataName AS projectTypeName 
		<!-- exportDetail: 0-基于项目， 1-基于设备， 2-基于回访  -->
		<isNotEqual prepend="," property="exportDetail" compareValue="1">
		    pppd.applyDuration, pppd.totalDuration, pppd.serviceDuration, pppd.programDuration, pppd.testDuration, pppd.callbackDuration 
		</isNotEqual>
		<isEqual prepend="," property="exportDetail" compareValue="1">
            IFNULL(tl1.`itemCode`, rma.itemcode) AS itemCode, 
            IFNULL(tl1.`itemModel`, rma.itemModel) AS itemModel, 
            tl1.`productFirstName`, tl1.`productTypeName`, tl1.`productNum`, 
            rma.orderQty, rma.dlvQty, rma.rmaQty, rma.deliveryDate, rma.rmaDate
        </isEqual>
		<isEqual prepend="," property="exportDetail" compareValue="2">
            cbt.START_TIME_ AS callbackStartTime, pcb.createTime as callbackQuesnarieTime, cbt.END_TIME_ AS callbackEndTime, pcb.taskId as callbackTaskId, IFNULL(pcb.quesnaireId, 0) AS quesnaireId, pqsl.*
        </isEqual>
		FROM
		    pm_presales_project_header t1 
		    LEFT JOIN act_ru_task t2 
		        ON t1.`instId` = t2.`PROC_INST_ID_` 
		    LEFT JOIN pm_project_member t3 
		        ON t1.`presalesId` = t3.`projectId` 
		        AND t3.`memberRole` = '20' 
		        AND t3.`effectiveTo` IS NULL 
		    LEFT JOIN pm_project_member t4 
		        ON t1.`presalesId` = t4.`projectId` 
		        AND t4.`memberRole` = '30' 
		        AND t4.`effectiveTo` IS NULL 
		    LEFT JOIN 
		        (SELECT 
		            ptt.projectId, SUBSTRING_INDEX(
		                GROUP_CONCAT(
		                    bd.basicDataName 
		                    ORDER BY bd.`sortId` ASC
		                ), ",", 1
		            ) AS taskTypeName 
		        FROM
		            `pm_project_task` ptt 
		            LEFT JOIN `fnd_basic_data` bd 
		                ON ptt.`taskTypeCode` = bd.`dataTypeCode` 
		                AND ptt.`taskTypeId` = bd.`basicDataId` 
		        WHERE projectType = '20' 
		            AND eventActualFinishDate IS NULL 
		        GROUP BY projectId) pt 
		        ON pt.projectId = t1.presalesId 
		    LEFT JOIN 
		        (SELECT 
		            projectId, GROUP_CONCAT(DISTINCT deliverableType) AS deliverableType 
		        FROM
		            `pm_basic_deliver_detail` pd 
		        WHERE projectType = 20 
		        GROUP BY projectId, projectType) pd 
		        ON pd.projectId = t1.presalesId 
		<isNotEqual property="exportDetail" compareValue="1">    
		    LEFT JOIN `view_presales_project_duration_temp` pppd 
		        ON pppd.presalesId = t1.presalesId 
        </isNotEqual>
	    <isEqual property="exportDetail" compareValue="1">    
            LEFT JOIN 
                pm_presales_project_rma_info rma 
                ON t1.projectCode = rma.contract
            LEFT JOIN 
                temp_presales_product_line tl1 
                ON t1.presalesId = tl1.presalesId 
                AND rma.itemcode = tl1.itemCode 
        </isEqual>
        <isNotEqual property="exportDetail" compareValue="2">
          <isEqual property="searchTimeType" compareValue="testCompleteTime">
            LEFT JOIN `act_hi_taskinst` cbt ON cbt.PROC_INST_ID_ = t1.instId AND cbt.TASK_DEF_KEY_ = 'usertask4' 
          </isEqual>
          <isEqual property="searchTimeType" compareValue="callbackQuesnarieTime">
            LEFT JOIN `pm_presales_project_callback` pcb ON pcb.presalesId = t1.presalesId AND pcb.quesnaireState = 1
          </isEqual>
          <isEqual property="searchTimeType" compareValue="callbackCompleteTime">
            LEFT JOIN `act_hi_taskinst` cbt ON cbt.PROC_INST_ID_ = t1.instId AND cbt.TASK_DEF_KEY_ = 'usertask4' 
          </isEqual>
        </isNotEqual>
        <isEqual property="exportDetail" compareValue="2">
            LEFT JOIN `act_hi_taskinst` cbt 
                ON cbt.PROC_INST_ID_ = t1.instId 
                AND cbt.TASK_DEF_KEY_ = 'usertask4' 
            LEFT JOIN `pm_presales_project_callback` pcb 
                ON pcb.presalesId = t1.presalesId 
                AND pcb.taskId = cbt.ID_ 
                AND pcb.quesnaireState = 1
            LEFT JOIN presales_tempQuesnaireResultTable pqsl 
                ON pqsl.quesnaireResultHeaderId = pcb.`quesnaireId`
        </isEqual>
		    LEFT JOIN fnd_department t5 
		        ON t1.`officeCode` = t5.`departmentNum` 
		        AND t5.`status` = 1 
		    LEFT JOIN fnd_user_info t6 
		        ON t2.`ASSIGNEE_` = t6.`username` 
		    LEFT JOIN fnd_basic_data t7 
		        ON t7.`basicDataId` = t1.`projectState` 
		        AND t7.`dataTypeCode` = 27 
		        AND t7.`effectiveTo` IS NULL 
		    LEFT JOIN fnd_basic_data t8 
		        ON t8.`basicDataId` = t1.`projectType` 
		        AND t8.`dataTypeCode` = "presalesType" 
		        AND t8.`effectiveTo` IS NULL 
		WHERE 1 = 1
		<isNotEmpty prepend="and" property="serviceManager">
            <![CDATA[ (t3.`memberCode` = #serviceManager#  or t4.`memberCode` = #serviceManager# ) ]]> 
        </isNotEmpty>
        <isNotEmpty prepend="and" property="projectManager">
            <![CDATA[ t4.`memberCode` = #projectManager#]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="presalesCode">
            <![CDATA[ (t1.projectCode = #presalesCode# or t1.presalesCode = #presalesCode# )]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="projectName">
            <![CDATA[ t1.projectName like '%$projectName$%']]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="officeCode">
            <![CDATA[ t1.officeCode = #officeCode#]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="projectType">
            <![CDATA[ t1.projectType = #projectType#]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="projectState">
            <![CDATA[ t1.projectState = #projectState#]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="projectStates">
            <![CDATA[ FIND_IN_SET(t1.projectState, #projectStates#) ]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="hasTransfer">
            <![CDATA[ t1.hasTransfer = #hasTransfer#]]>
        </isNotEmpty>
        <isNotEmpty prepend="and" property="hasRma">
            <![CDATA[ t1.hasRma = #hasRma#]]>
        </isNotEmpty>
        <isEqual property="searchTimeType" compareValue="applyTime">
            <isNotNull prepend="AND" property="searchStartTime"> t1.applyTime >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ t1.applyTime <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="endTime">
            <isNotNull prepend="AND" property="searchStartTime"> t1.endTime >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ t1.endTime <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="testCompleteTime">
            <isNotNull prepend="AND" property="searchStartTime"> cbt.START_TIME_ >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ cbt.START_TIME_ <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackQuesnarieTime">
            <isNotNull prepend="AND" property="searchStartTime"> pcb.createTime >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ pcb.createTime <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
        <isEqual property="searchTimeType" compareValue="callbackCompleteTime">
            <isNotNull prepend="AND" property="searchStartTime"> cbt.END_TIME_ >= #searchStartTime# </isNotNull>
            <isNotNull prepend="AND" property="searchEndTime"> <![CDATA[ cbt.END_TIME_ <= #searchEndTime# ]]> </isNotNull>
        </isEqual>
         ORDER BY t1.`applyTime` DESC
	</select>
	
	<insert id="createTempPresalesProductLine">
	    CREATE TEMPORARY TABLE IF NOT EXISTS temp_presales_product_line (
		    KEY presalesId (presalesId), KEY itemCode (itemCode)
		) 
		SELECT 
		    ppl.`productLineId`, t1.*, ppl.`itemCode`, ppl.`itemModel`, ppl.`productFirstName`, ppl.`productTypeName`, ppl.`productNum` 
		FROM
		    pm_presales_project_header t1 
		    INNER JOIN pm_presales_project_product_line ppl 
		        ON t1.`presalesId` = ppl.`presalesId` 
		        AND ppl.effectiveTo IS NULL 
		UNION
		SELECT 
		    ppl.`productLineId`, t1.*, ppl.`itemCode`, ppl.`itemModel`, ppl.`productFirstName`, ppl.`productTypeName`, ppl.`productNum` 
		FROM
		    pm_presales_project_header t1 
		    INNER JOIN pm_presales_project_product_line ppl 
		        ON t1.lendInfoId = ppl.`lendInfoId` 
		        AND ppl.effectiveTo IS NULL
	</insert>
	
	<delete id="deleteTempPresalesProductLine">
	   DROP TEMPORARY TABLE IF EXISTS temp_presales_product_line;
	</delete>
	
	<insert id="updatePresalesDuration" parameterClass="int">
	     INSERT INTO `pm_presales_project_duration` (
		    `presalesId`, `instId`, `totalDuration`, `serviceDuration`, `programDuration`, `testDuration`, `callbackDuration`
		 )
	     SELECT presalesId, instId,
	        REPLACE(REPLACE(REPLACE(IFNULL(CONCAT(TRUNCATE(totalDuration / 86400000, 0) , "天", 
		    TRUNCATE((totalDuration - (TRUNCATE(totalDuration / 86400000, 0) * 86400000)) / 3600000, 0) , "时", 
		    TRUNCATE((totalDuration - (TRUNCATE(totalDuration / 3600000, 0) * 3600000)) / 60000, 0) , "分", 
		    TRUNCATE((totalDuration - (TRUNCATE(totalDuration / 60000, 0) * 60000)) / 1000, 0) , "秒"),
		    CONCAT(TRUNCATE(allDuration / 86400000, 0) , "天", 
		    TRUNCATE((allDuration - (TRUNCATE(allDuration / 86400000, 0) * 86400000)) / 3600000, 0) , "时", 
		    TRUNCATE((allDuration - (TRUNCATE(allDuration / 3600000, 0) * 3600000)) / 60000, 0) , "分", 
		    TRUNCATE((allDuration - (TRUNCATE(allDuration / 60000, 0) * 60000)) / 1000, 0) , "秒")), "0天0时0分", ""), "0天0时", ""), "0天", "") AS totalDuration,
		    REPLACE(REPLACE(REPLACE(CONCAT(TRUNCATE(serviceDuration / 86400000, 0) , "天", 
		    TRUNCATE((serviceDuration - (TRUNCATE(serviceDuration / 86400000, 0) * 86400000)) / 3600000, 0) , "时", 
		    TRUNCATE((serviceDuration - (TRUNCATE(serviceDuration / 3600000, 0) * 3600000)) / 60000, 0) , "分", 
		    TRUNCATE((serviceDuration - (TRUNCATE(serviceDuration / 60000, 0) * 60000)) / 1000, 0) , "秒"), "0天0时0分", ""), "0天0时", ""), "0天", "") AS serviceDuration,
		    REPLACE(REPLACE(REPLACE(CONCAT(TRUNCATE(programDuration / 86400000, 0) , "天", 
		    TRUNCATE((programDuration - (TRUNCATE(programDuration / 86400000, 0) * 86400000)) / 3600000, 0) , "时", 
		    TRUNCATE((programDuration - (TRUNCATE(programDuration / 3600000, 0) * 3600000)) / 60000, 0) , "分", 
		    TRUNCATE((programDuration - (TRUNCATE(programDuration / 60000, 0) * 60000)) / 1000, 0) , "秒"), "0天0时0分", ""), "0天0时", ""), "0天", "") AS programDuration,
		    REPLACE(REPLACE(REPLACE(CONCAT(TRUNCATE(testDuration / 86400000, 0) , "天", 
		    TRUNCATE((testDuration - (TRUNCATE(testDuration / 86400000, 0) * 86400000)) / 3600000, 0) , "时", 
		    TRUNCATE((testDuration - (TRUNCATE(testDuration / 3600000, 0) * 3600000)) / 60000, 0) , "分", 
		    TRUNCATE((testDuration - (TRUNCATE(testDuration / 60000, 0) * 60000)) / 1000, 0) , "秒"), "0天0时0分", ""), "0天0时", ""), "0天", "") AS testDuration,
		    REPLACE(REPLACE(REPLACE(CONCAT(TRUNCATE(callbackDuration / 86400000, 0) , "天", 
		    TRUNCATE((callbackDuration - (TRUNCATE(callbackDuration / 86400000, 0) * 86400000)) / 3600000, 0) , "时", 
		    TRUNCATE((callbackDuration - (TRUNCATE(callbackDuration / 3600000, 0) * 3600000)) / 60000, 0) , "分", 
		    TRUNCATE((callbackDuration - (TRUNCATE(callbackDuration / 60000, 0) * 60000)) / 1000, 0) , "秒"), "0天0时0分", ""), "0天0时", ""), "0天", "") AS callbackDuration
		FROM (
			SELECT 
			    presalesId, instId, 
			    TIMESTAMPDIFF(SECOND, pph.applyTime, pph.endTime) * 1000 AS totalDuration,
			    IF(pph.projectState IN (20,100), SUM(DURATION_), NULL) AS allDuration,
			    SUM(IF(TASK_DEF_KEY_ = 'usertask1', DURATION_, NULL)) AS serviceDuration,
			    SUM(IF(TASK_DEF_KEY_ = 'usertask2', DURATION_, NULL)) AS programDuration,
			    SUM(IF(TASK_DEF_KEY_ = 'usertask3', DURATION_, NULL)) AS testDuration,
			    SUM(IF(TASK_DEF_KEY_ = 'usertask4', DURATION_, NULL)) AS callbackDuration
			FROM
			    `pm_presales_project_header` pph
			    LEFT JOIN `act_hi_taskinst` aht 
			        ON aht.`PROC_INST_ID_` = pph.`instId` 
			WHERE pph.presalesId = #presalesId# and pph.instId is not null
		GROUP BY pph.`presalesId`) t 
		ON DUPLICATE KEY UPDATE 
		    instId = VALUES(`instId`),
		    totalDuration = VALUES(`totalDuration`),
		    serviceDuration = VALUES(`serviceDuration`),
		    programDuration = VALUES(`programDuration`),
		    testDuration = VALUES(`testDuration`),
		    callbackDuration = VALUES(`callbackDuration`)
	</insert>
	
	<!-- <update id="updatePresalesTransferState">
	    UPDATE 
		    pm_presales_project_header pph
		    LEFT JOIN 
		        (SELECT DISTINCT 
		            contract AS projectCode, IF(borrowNum > 0, 1, 0) AS hasTransfer 
		        FROM
		            `pm_presales_lend_order_from_sms` plr 
		        WHERE borrowNum > 0) plr 
		        ON pph.`projectCode` = plr.projectCode SET pph.hasTransfer = IFNULL(plr.hasTransfer, 0) 
		WHERE plr.hasTransfer = 1
	</update> -->
</sqlMap>