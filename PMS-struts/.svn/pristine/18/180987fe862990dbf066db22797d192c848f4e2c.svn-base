package com.dp.plat.param;
/**
 * 工作台不同工作流所对应的不同选项卡值
 * @author admin
 *
 */
public class WorkspaceLiParam {
	/**重大项目  0*/
	public static final int  IMPORT_FLOW = 0;
	/**提前报备	1*/
	public static final int BEFORE_FLOW = 1;
	/**中标总结 	2*/
	public static final int ORDER_FLOW = 2;
	/**订单申请	4*/
	public static final int BUSINESS_ORDER_FLOW = 4;
	/**丢单申请	3*/
	public static final int LOST_FLOW = 3;
	/** 借货申请	5*/
	public static final int LEND_PRODUCT_FLOW = 5;

	/**项目失效	6*/
	public static final int INVALID_FLOW = 6;
	/**工作周报	7*/
	public static final int WEEKLY_REPLY = 7;
	/**已办理任务   8*/
	public static final int HISTORY_TASK =8 ;


	
}
