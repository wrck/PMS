<script>
function submit_${tr.name}()
{
	var cyc = getObj("${tr.name}_cyc").value;
	var time = getObj("${tr.name}_time").value;
	var time2 = getObj("${tr.name}_time2").value;
	
	getObj("${tr.parentParam}.${tr.name}").value="<"+"${tr.parentParam}.${tr.name}"+"|"+cyc+"|"+time+"|"+time2+">";

	try
	{
		autoSubmit("${tr.parentParam}.${tr.name}");
	}
	catch(e)
	{
		//alert(getObj("${tr.parentParam}.${tr.name}").value+"\r\n"+e);
	}
}

function onTS_${tr.name}_SelectChange()
{
	getObj("${tr.name}_cyc").value = getObj("queryCyc_$tr.name").value;
	getObj("${tr.name}_time").value = "";
	getObj("${tr.name}_time2").value = "";

	submit_${tr.name}();
}	

function dayChanged_${tr.name}(calendar) 
{
	if (calendar.dateClicked) 
	{
		//var y = calendar.date.getFullYear();
		//var m = calendar.date.getMonth(); 
		//var d = calendar.date.getDate(); 
		
		daychanged_${tr.name}_do();
	}
}

function daychanged_${tr.name}_do()
{
		getObj("${tr.name}_cyc").value = "1";
		getObj("${tr.name}_time").value = getObj("${tr.name}_input_day").value;
		getObj("${tr.name}_time2").value = getObj("${tr.name}_input_day").value;
		
		submit_${tr.name}();
}

function weekchange_${tr.name}()
{
	var osel = getObj("queryWeek_$tr.name");
	var day = osel.options[osel.selectedIndex].value;

	getObj("${tr.name}_cyc").value = "2";
	getObj("${tr.name}_time").value = day;
	getObj("${tr.name}_time2").value = day;
		
	submit_${tr.name}();
}
function monthchange_${tr.name}()
{
	var osel = getObj("queryMonth_$tr.name");
	var day = osel.options[osel.selectedIndex].value;

	getObj("${tr.name}_cyc").value = "3";
	getObj("${tr.name}_time").value = day;
	getObj("${tr.name}_time2").value = day;
		
	submit_${tr.name}();
}
function userdef_time_${tr.name}(start, end)
{
		getObj("${tr.name}_cyc").value = "4";
		getObj("${tr.name}_time").value = start;
		getObj("${tr.name}_time2").value = end;
		
		submit_${tr.name}();
}
function show_user_${tr.name}()
{
	var osel = getObj("queryCyc_${tr.name}");
	var cyc = osel.options[osel.selectedIndex].value;
	if(cyc==4)
	{
		getObj("${tr.name}_cyc").value = "4";
		getObj("${tr.name}_time").value = getObj("${tr.name}_input_day_s").value;
		getObj("${tr.name}_time2").value = getObj("${tr.name}_input_day_e").value;
		
		submit_${tr.name}();
	}
	else if(cyc == 3)
	{
		monthchange_${tr.name}();
	}
	else if(cyc == 2)
	{
		weekchange_${tr.name}();
	}
	else
	{
		daychanged_${tr.name}_do();
	}
}
</script>
<table cellSpacing=0 cellPadding=0>
<TR><TD colSpan="2" height=4></TD></TR>
<tr><td style="padding-right: 10px">
<table cellSpacing=0 cellPadding=0>
	<tr>
		<td style="padding-right: 10px"><label class=LABEL>#text("sys.vm.cyc")</label></td>
		<td style="padding-right: 10px"><select class=SELECTS id="queryCyc_$tr.name" onchange="onTS_${tr.name}_SelectChange();">
			<option value=1>#text("uag.param.tian")</option>
			<option value=2>#text("uag.param.zhouz")</option>
			<option value=3>#text("uag.param.month")</option>
			<option value=4>#text("uag.param.zidingyi")</option>
		</select>
		#select_setvalue("queryCyc_$tr.name" $tr.queryCyc)
		</td>
		<td style="padding-right: 10px"><label class=LABEL>&nbsp;&nbsp;#text("sys.vm.timec")</label></td>
		<td style="padding-right: 10px"><div class="DIVS" id="tr_cyc_1" #if($tr.queryCyc!=1)style="display:none;"#end>
				<INPUT id="${tr.name}_input_day" value="$tr.getDay()" size=12 class=TEXT style="margin:0px;padding:0px;">
				<a href="#"><img src="images/right_riqi.jpg" id="${tr.name}_img_day"
				 align="absMiddle" border="0" alt="#text("sys.vm.choosetime")"></a>
				<SCRIPT type=text/javascript>
					Calendar.setup({
					inputField     :    "${tr.name}_input_day", // id of the input field
					ifFormat       :    "%Y-%m-%d",                 // format of the input field  %Y-%m-%d %H:%M
					showsTime      :    false,
					button         :    "${tr.name}_img_day",  	   // trigger for the calendar (button ID)
					timeFormat     :    "24",
					align          :    "Bl",           	   // alignment (defaults to "Bl")
					singleClick    :    true,
					firstDay       :    1,
					weekNumbers    :    true,
					onUpdate       :    dayChanged_${tr.name} // our callback function
					});
				</SCRIPT>
			</div>
			<div class="DIVS" id="tr_cyc_2" #if($tr.queryCyc!=2)style="display:none;"#end>
			<select class=SELECTS id="queryWeek_$tr.name" onchange="weekchange_${tr.name}();">
				#set($weeks=$tr.getAllWeeks())
				#foreach($week in $weeks)
					<option value="$week.begin">$week.end.getYear()#text("sys.vm.niandi")${week.num}#text("uag.param.zhouz") $week.begin - $week.end</option>
				#end
			</select>
			#select_setvalue("queryWeek_$tr.name" "$tr.getDay()")
			</div>
			<div class="DIVS" id="tr_cyc_3" #if($tr.queryCyc!=3)style="display:none;"#end>
			<select class=SELECTS id="queryMonth_$tr.name" onchange="monthchange_${tr.name}();">
				#set($months=$tr.getAllMonths())
				#foreach($month in $months)
					<option value="$month.begin">$month.begin.getYear()#text("uag.param.nian") $month.begin.getMonth()#text("uag.param.month")</option>
				#end
			</select>
			#select_setvalue("queryMonth_$tr.name" "$tr.getDay()")
			</div>
			<div class="DIVS" id="tr_cyc_4" #if($tr.queryCyc!=4)style="display:none;"#end>
				<INPUT id="${tr.name}_input_day_s" value="$tr.queryTime" size=16 class=TEXT style="margin:0px;padding:0px;">
				<a href="#"><img src="images/right_riqi.jpg" id="${tr.name}_img_day_s"
				 align="absMiddle" border="0" alt="#text("sys.vm.choosetime")"></a>
				<SCRIPT type=text/javascript>
					Calendar.setup({
					inputField     :    "${tr.name}_input_day_s", // id of the input field
					ifFormat       :    "%Y-%m-%d %H:%M",                 // format of the input field  %Y-%m-%d %H:%M
					showsTime      :    true,
					button         :    "${tr.name}_img_day_s",  	   // trigger for the calendar (button ID)
					timeFormat     :    "24",
					align          :    "Bl",           	   // alignment (defaults to "Bl")
					singleClick    :    true,
					firstDay       :    1,
					weekNumbers    :    true
					//onUpdate       :    dayChanged_${tr.name} // our callback function
					});
				</SCRIPT>
				-
				<INPUT id="${tr.name}_input_day_e" value="$tr.queryTime2" size=16 class=TEXT style="margin:0px;padding:0px;">
				<a href="#"><img src="images/right_riqi.jpg" id="${tr.name}_img_day_e"
				 align="absMiddle" border="0" alt="#text("sys.vm.choosetime")"></a>
				<SCRIPT type=text/javascript>
					Calendar.setup({
					inputField     :    "${tr.name}_input_day_e", // id of the input field
					ifFormat       :    "%Y-%m-%d %H:%M",                 // format of the input field  %Y-%m-%d %H:%M
					showsTime      :    true,
					button         :    "${tr.name}_img_day_e",  	   // trigger for the calendar (button ID)
					timeFormat     :    "24",
					align          :    "Bl",           	   // alignment (defaults to "Bl")
					singleClick    :    true,
					firstDay       :    1,
					weekNumbers    :    true
					//onUpdate       :    dayChanged_${tr.name} // our callback function
					});
				</SCRIPT>
			</div>
		</td>
	</tr>
</table>
</td>
<td align=right vAlign=bottom style="padding-right:0px"><input type=button class=buttonNormal onclick="show_user_${tr.name}()" value="#text("sys.vm.view")" style="margin-right:0px"/>
</td>
</tr>
</table>
<input type=hidden id="${tr.name}_cyc" value="$tr.queryCyc"/>
<input type=hidden id="${tr.name}_time" value="$tr.queryTime"/>
<input type=hidden id="${tr.name}_time2" value="$tr.queryTime2"/>
<input type=hidden id="${tr.parentParam}.${tr.name}" name="${tr.parentParam}.${tr.name}" value="$tr.formatTo()"/>