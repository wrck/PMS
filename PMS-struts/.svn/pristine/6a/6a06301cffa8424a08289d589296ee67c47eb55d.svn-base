package com.dp.plat.data.bean;

import java.util.Date;

/**
 * 订单交付日期变更实例
 * @author admin
 *
 */
public class OrderChangeState {
	private int id ;
	private String contractNo;
	private int changeType;//交付日期类型 1 客户交付日期 0计划交付日期
	private Date deliveryDate;
	private int deliveryQuantity;
	private String changeRemark;
	private Date newDeliveryDate;
	private String createBy;
	private Date createTime;
	public int getId() {
		return id;
	}
	public void setId(int id) {
		this.id = id;
	}
	public String getContractNo() {
		return contractNo;
	}
	public void setContractNo(String contractNo) {
		this.contractNo = contractNo;
	}
	public int getChangeType() {
		return changeType;
	}
	public void setChangeType(int changeType) {
		this.changeType = changeType;
	}
	public Date getDeliveryDate() {
		return deliveryDate;
	}
	public void setDeliveryDate(Date deliveryDate) {
		this.deliveryDate = deliveryDate;
	}
	public int getDeliveryQuantity() {
		return deliveryQuantity;
	}
	public void setDeliveryQuantity(int deliveryQuantity) {
		this.deliveryQuantity = deliveryQuantity;
	}
	public String getChangeRemark() {
		return changeRemark;
	}
	public void setChangeRemark(String changeRemark) {
		this.changeRemark = changeRemark;
	}
	public Date getNewDeliveryDate() {
		return newDeliveryDate;
	}
	public void setNewDeliveryDate(Date newDeliveryDate) {
		this.newDeliveryDate = newDeliveryDate;
	}
	public String getCreateBy() {
		return createBy;
	}
	public void setCreateBy(String createBy) {
		this.createBy = createBy;
	}
	public Date getCreateTime() {
		return createTime;
	}
	public void setCreateTime(Date createTime) {
		this.createTime = createTime;
	}
	
	
	
}
