package com.dp.plat.data.bean;

import java.util.Date;

public class ReportQueryParam {
	private Date startTime;
	private Date endTime;
	
	private Date quarterStartTime;
	private Date quarterEndTime;
	
	private String officeCodes;
	
	private Integer isALl;
	private int implWay;//实施方式
	
	private String projectCategory;
	
	public Date getStartTime() {
		return startTime;
	}

	public void setStartTime(Date startTime) {
		this.startTime = startTime;
	}

	public Date getEndTime() {
		return endTime;
	}

	public void setEndTime(Date endTime) {
		this.endTime = endTime;
	}

	public String getOfficeCodes() {
		return officeCodes;
	}

	public void setOfficeCodes(String officeCodes) {
		this.officeCodes = officeCodes;
	}

	public Integer getIsALl() {
		return isALl;
	}

	public void setIsALl(Integer isALl) {
		this.isALl = isALl;
	}
	
	public int getImplWay() {
		return implWay;
	}
	
	public void setImplWay(int implWay) {
		this.implWay = implWay;
	}

	public Date getQuarterStartTime() {
		return quarterStartTime;
	}

	public void setQuarterStartTime(Date quarterStartTime) {
		this.quarterStartTime = quarterStartTime;
	}

	public Date getQuarterEndTime() {
		return quarterEndTime;
	}

	public void setQuarterEndTime(Date quarterEndTime) {
		this.quarterEndTime = quarterEndTime;
	}

	public String getProjectCategory() {
		return projectCategory;
	}

	public void setProjectCategory(String projectCategory) {
		this.projectCategory = projectCategory;
	}

	
}
