package com.dp.plat.param;

public class Person {
	private String salesmanCode;
	private String salesmanTel;
	private String salesmanName;
	private String salesmanMail;
	public String getSalesmanCode() {
		return salesmanCode;
	}
	public void setSalesmanCode(String salesmanCode) {
		this.salesmanCode = salesmanCode;
	}
	public String getSalesmanTel() {
		return salesmanTel;
	}
	public void setSalesmanTel(String salesmanTel) {
		this.salesmanTel = salesmanTel;
	}
	public String getSalesmanName() {
		return salesmanName;
	}
	public void setSalesmanName(String salesmanName) {
		this.salesmanName = salesmanName;
	}
	public String getSalesmanMail() {
		return salesmanMail;
	}
	public void setSalesmanMail(String salesmanMail) {
		this.salesmanMail = salesmanMail;
	}
	
	
}
