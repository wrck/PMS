    }
    public String getBarCode2() {
        return barCode2;
    }
    public void setBarCode2(String barCode2) {
        this.barCode2 = barCode2;
    }
    public String getItemCode2() {
        return itemCode2;
    }
    public void setItemCode2(String itemCode2) {
