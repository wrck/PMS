package com.dp.plat.data.bean;

/**
 * 
 * @title: 流程类型
 * @desc: 功能描述
 * @connection: 对应 dp_act_proc_type 表的 ID
 * @author: xumaocai
 * @date: 2014年7月12日下午4:59:47
 */
public class DpActProcType {
	
	public static int BUSINESS_BEFORE_APPLY_PROC_TYPE = 1;// 商务提前报备流程
	public static int BUSINESS_APPLY_BID_PROC_TYPE = 2;// 项目总结流程
	public static int BUSINESS_ORDER = 3;// 订单申报流程
	public static int MAJOR_PROJECT_PROC_TYPE = 4;// 重大项目流程
	public static int PROJECT_PRODUCT_LEND_INFO = 5;// 借货流程
	public static int PLVERIFIAPPLY = 7;// 借转退申请流程
	public static int PLTOPROJECT = 8;// 借货转项目申请流程
	public static int PROJECT_INVALID = 10;//项目失效申请流程
	public static int BUSINESS_APPLY_LOST = 9;// 项目丢单总结
	
	private int id;
	private String desc;//流程描述
	private String procDefKey;//流程定义key
	public int getId() {
		return id;
	}
	public void setId(int id) {
		this.id = id;
	}
	public String getDesc() {
		return desc;
	}
	public void setDesc(String desc) {
		this.desc = desc;
	}
	public String getProcDefKey() {
		return procDefKey;
	}
	public void setProcDefKey(String procDefKey) {
		this.procDefKey = procDefKey;
	}
	
}
