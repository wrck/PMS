package com.dp.plat.data.vo;

import java.util.Date;

import com.dp.plat.data.bean.Presales;

/**
 * @author w02611
 *
 */
public class PresalesExportVO extends Presales {
	private int productLineId;// 明细表主键
	private String productFirstName;// 产品一级
	private String productTypeName;// 产品类型
	private String itemCode;// 编码
	private String itemModel;// 型号
	private String itemDesc;// 描述
	private Double price;// 目录价
	private Integer productNum;// 数量
	private Integer transferNum;// 转销数
	private Integer hexiaoNum;// 核销数
	private Integer orderQty;// 订单数
	private Integer dlvQty;// 发货数
	private Integer rmaQty;// 核销数
	private Date deliveryDate;// 发货日期
	private Date rmaDate; // 核销日期
	private String remark;// 备注
	private String hasTransfer;
	
	private String isUpload;
	private String taskTypeName;
	private String deliverableType;
	
	private Date callbackStartTime;
	private Date callbackQuesnarieTime;
	private Date callbackEndTime;
	
	public int getProductLineId() {
		return productLineId;
	}

	public void setProductLineId(int productLineId) {
		this.productLineId = productLineId;
	}

	public String getProductFirstName() {
		return productFirstName;
	}

	public void setProductFirstName(String productFirstName) {
		this.productFirstName = productFirstName;
	}

	public String getProductTypeName() {
		return productTypeName;
	}

	public void setProductTypeName(String productTypeName) {
		this.productTypeName = productTypeName;
	}

	public String getItemCode() {
		return itemCode;
	}

	public void setItemCode(String itemCode) {
		this.itemCode = itemCode;
	}

	public String getItemModel() {
		return itemModel;
	}

	public void setItemModel(String itemModel) {
		this.itemModel = itemModel;
	}

	public String getItemDesc() {
		return itemDesc;
	}

	public void setItemDesc(String itemDesc) {
		this.itemDesc = itemDesc;
	}

	public Double getPrice() {
		return price;
	}

	public void setPrice(Double price) {
		this.price = price;
	}

	public Integer getProductNum() {
		return productNum;
	}

	public void setProductNum(Integer productNum) {
		this.productNum = productNum;
	}

	public Integer getTransferNum() {
		return transferNum;
	}

	public void setTransferNum(Integer transferNum) {
		this.transferNum = transferNum;
	}

	public Integer getHexiaoNum() {
		return hexiaoNum;
	}

	public void setHexiaoNum(Integer hexiaoNum) {
		this.hexiaoNum = hexiaoNum;
	}

    public Integer getOrderQty() {
        return orderQty;
    }

    public void setOrderQty(Integer orderQty) {
        this.orderQty = orderQty;
    }

    public Integer getDlvQty() {
        return dlvQty;
    }

    public void setDlvQty(Integer dlvQty) {
        this.dlvQty = dlvQty;
    }

    public Integer getRmaQty() {
        return rmaQty;
    }

    public void setRmaQty(Integer rmaQty) {
        this.rmaQty = rmaQty;
    }

    public Date getDeliveryDate() {
        return deliveryDate;
    }

    public void setDeliveryDate(Date deliveryDate) {
        this.deliveryDate = deliveryDate;
    }

    public Date getRmaDate() {
        return rmaDate;
    }

    public void setRmaDate(Date rmaDate) {
        this.rmaDate = rmaDate;
    }

    public String getRemark() {
		return remark;
	}

	public void setRemark(String remark) {
		this.remark = remark;
	}

	public String getHasTransfer() {
        return hasTransfer;
    }

    public void setHasTransfer(String hasTransfer) {
        this.hasTransfer = hasTransfer;
    }

    public String getIsUpload() {
		return isUpload;
	}

	public void setIsUpload(String isUpload) {
		this.isUpload = isUpload;
	}

	public String getTaskTypeName() {
		return taskTypeName;
	}

	public void setTaskTypeName(String taskTypeName) {
		this.taskTypeName = taskTypeName;
	}

    public String getDeliverableType() {
        return deliverableType;
    }

    public void setDeliverableType(String deliverableType) {
        this.deliverableType = deliverableType;
    }

    public Date getCallbackStartTime() {
        return callbackStartTime;
    }

    public void setCallbackStartTime(Date callbackStartTime) {
        this.callbackStartTime = callbackStartTime;
    }
    
    public Date getCallbackQuesnarieTime() {
        return callbackQuesnarieTime;
    }

    public void setCallbackQuesnarieTime(Date callbackQuesnarieTime) {
        this.callbackQuesnarieTime = callbackQuesnarieTime;
    }

    public Date getCallbackEndTime() {
        return callbackEndTime;
    }

    public void setCallbackEndTime(Date callbackEndTime) {
        this.callbackEndTime = callbackEndTime;
    }

}
