package com.dp.plat.subcontract.vo;

import com.dp.plat.subcontract.entity.SubcontractLine;

/**
 * @author w02611
 *
 */
public class SubcontractLineVO extends SubcontractLine {
    
    private String barCode2;
    private String itemCode2;
    private String itemName2;
    private String itemModel2;
    
    public String getBarCode2() {
        return barCode2;
    }
    public void setBarCode2(String barCode2) {
        this.barCode2 = barCode2;
    }
    public String getItemCode2() {
        return itemCode2;
    }
    public void setItemCode2(String itemCode2) {
        this.itemCode2 = itemCode2;
    }
    public String getItemName2() {
        return itemName2;
    }
    public void setItemName2(String itemName2) {
        this.itemName2 = itemName2;
    }
    public String getItemModel2() {
        return itemModel2;
    }
    public void setItemModel2(String itemModel2) {
        this.itemModel2 = itemModel2;
    }
    
}
