<%@ page contentType="text/html;charset=UTF-8" language="java"%>
<%@ taglib prefix="s" uri="/struts-tags"%>
<%@ taglib prefix="dp" uri="/dp"%>
<%@ taglib uri="http://displaytag.sf.net" prefix="display"%>
<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN">
<html>
<head>
<dp:base />
<meta name="menu" content="SysLeftMenu">
<meta name="module" content="<s:text name='module.plat' />">
<meta name="group" content="<s:text name='sys.leftmenu.powermanage' />">
<meta name="function" content="<s:text name='pm.presales.flow' />">
<style type="text/css">
#mainForm div lable{
	width: 100px;
}
</style>
<script type="text/javascript">
	$(function(){
		setselect("projectState","projectStates", ",");
		var projectStates = $("#projectStates").val();
		if (projectStates) {
			$("#projectState").val(projectStates.split(","));
		}
		$("#projectState").multiselect({
	        header : true,
	        classes: "",
	        minWidth : 163,
	        selectedList : 50,//预设值最多显示10被选中项
	        hide : [ "explode", 500],
	        checkAllText : "全选",
	        uncheckAllText : '取消',
	        noneSelectedText : '==请选择==',
	        close : function() {
	            var values = $("#projectState").val();
	            $("#projectStates").val(values);
	        }
	    });
		var width = $("button.ui-multiselect").addClass("form-control").css("width");
	    $("button.ui-multiselect").addClass("form-control").css({"minWidth": width, "width": 'auto'});
		
	    
		queryprogramuser();
		$("#projectManager").autocomplete({
			source: realnameArr3,
		});
		
		//获取流程图
		$("#queryPresalesView").click(function(){
			$.ajax({
				url:"viewDeployment.action",
				type:"post",
				dataType:"json",
				data:{procdefKey:"Presales"},
				success:function(data){
				  	window.open("work/WorkFlowViewImage.action?param.deploymentId="+data.deploymentId+"&param.imageName="+data.imageName);
				},
				error:function(){
					alert('error!');
				}
			});
			return false;
		});
		
		var prevText = '确定';
		$("#terminate2CloseBtn").click(function() {
			var type = $(this).data("type") || "select";
			var text = $(this).text();
			$(this).text(prevText);
			if (type == "select") {
				$(".presalesIds").removeClass("hidden");
				$("#terminate2CloseCancelBtn").show();
				$(this).data("type", "submit");
			} else {
				$(".presalesIds").addClass("hidden");
                $(this).data("type", "select");
                $("#terminate2CloseCancelBtn").hide();
                /* $("#terminate2CloseForm").html("<input type='hidden' name='redirect' value='module/presales_list.action'>");
                $("#terminate2CloseForm").html($(".presalesIds input:checked").not("[id='checkall']").addClass("hidden"));
                $("#terminate2CloseForm").submit(); */
                var comment = prompt("终止流程说明", "终止流程直接关闭");
                if (comment) {
	                var presalesIds = [];
	                $(".presalesIds input:checked").not("[id='checkall']").each(function() {
	                	presalesIds.push(this.value);
	                });
	                var $btn = $(this);
	                $btn.bootstrapBtn("loading");
	                $.ajax({
	                    url:"module/s/terminate2Close.action",
	                    type:"post",
	                    async: true,
	                    dataType:"json",
	                    data:{presalesIds: presalesIds.join(","), "message": comment},
	                    success:function(data){
	                    	if (data.message == 'success') {
	                    		window.location.reload();
	                    	} else {
	                    		alert(data.message);
	                    	}
	                    },
	                    error: function() {
	                    	alert("发生错误，请联系管理员");
	                    },
	                    complete : function() {
	                    	$btn.bootstrapBtn("reset");
	                    }
	                });
                }
			}
			prevText = text;
		});
		
		$("#terminate2CloseCancelBtn").click(function() {
            var text = $("#terminate2CloseBtn").text();
            $("#terminate2CloseBtn").text(prevText);
            prevText = text;
            
            $(".presalesIds").addClass("hidden");
            $("#terminate2CloseBtn").data("type", "select");
            $(this).hide();
        });
		
		$("#checkall").click(function() {
			if ($(this).is(":checked")) {
				$(".presalesIds input").prop("checked", true);
			} else {
				$(".presalesIds input").prop("checked", false);
			}
		});
		date_picker("searchStartTime");
        date_picker("searchEndTime");
        
        // 将导出选择框，添加到列表导出链接中
        $exportLinks = $("#presalesTable").parent().find(".exportlinks");
        if ($exportLinks.length > 0) {
            $("#exportDetailSelect").appendTo($exportLinks);
            $exportLinks.addClass("form-inline");
            $("#exportDetailSelect select").on("change", changeExportDetailSelect);
            changeExportDetailSelect();
        } else {
        	$("#exportDetailSelect").remove();
        }
        
        /* $("#mainForm").submit(function() {
        	var params = "?" + $(this).serialize();
        	localStorage.setItem("presalesRedirectSearch", params);
        }); */
        localStorage.setItem("presalesRedirectSearch", "?" + $("#mainForm").serialize());
        function changeExportDetailSelect() {
        	var exportDetail = $("#exportDetailSelect select").val();
            //var regex = /(&?presales.exportDetail=)([^&]*)/g;
            var regex = /(&?(presales.)?exportDetail=)([^&]*)/g;
            $exportLinks.find("a").each(function() {
                var href = $(this).attr("href");
                if (regex.test(href)) {
                    href = href.replace(regex, "$1" + exportDetail);
                } else {
                    //href += "&presales.exportDetail=" + exportDetail;
                	href += "&exportDetail=" + exportDetail;
                }
                $(this).attr("href", href);
            })
        }
	});
	var realnameArr3 = new Array();
	var usernameArr3  = new Array();
	function queryprogramuser(){
		$.ajax({
			url:'queryalluser.action',
			type:'post',
			dataType:'json',
			data:{roleid :12},
			success:queryprogramuser2
		});
	}
	function queryprogramuser2(json){
		var userlist = json.allusernameList;
		for(var i = 0;i < userlist.length;i++){
			usernameArr3[i] = userlist[i].username;
			realnameArr3[i] = userlist[i].username+"-"+userlist[i].realName;
		}
	}
	function fillpm(){
		var obj=document.getElementById("projectManager");
		if(obj.value==""){
			document.getElementById("pm_hide").value="";
		}
		if(obj.value!=""){
			var i=0;
			for(;i<realnameArr3.length;i++){
				if(realnameArr3[i]==obj.value){
					break;
				}
			}
			if(i==realnameArr3.length){
				return false;
			} else{
				document.getElementById("pm_hide").value=usernameArr3[i];
			}
		}
	}
</script>
</head>
<body>
	<!-- 查询 -->
	<s:form id="mainForm" name="mainForm" cssClass="form-inline" action="module/presales_list.action">
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="projectName"><s:text name="pm.project.projectName" /></label>
			<s:textfield name="presales.projectName" id="projectName"
				placeholder="支持模糊搜索" cssStyle="width:163px" cssClass="form-control" />
		</div>
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="projectCode">项目编码</label>
			<s:textfield name="presales.presalesCode" id="projectCode"
				 cssStyle="width:163px" cssClass="form-control" />
		</div>
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="officeCode">办事处</label>
			<s:select name="presales.officeCode" id="officeCode"  cssClass="form-control" cssStyle="width:163px;"
				list="officeList" listKey="departmentNum" listValue="departmentName"
				headerKey="" headerValue="--请选择--"></s:select>	
		</div>
        <div class="form-group form-group-query form-group-width-1">
            <label>
                <select name="presales.searchTimeType" id="searchTimeType" class="form-control" style="padding:0px;border:none;box-shadow:none;">
                    <option value="applyTime" <s:if test='%{presales.searchTimeType == "appyTime"}'>selected="selected"</s:if>><s:text name="pm.presales.applyTime"/></option>
                    <option value="testCompleteTime" <s:if test='%{presales.searchTimeType == "testCompleteTime"}'>selected="selected"</s:if>><s:text name="pm.presales.testCompleteTime"/></option>
                    <option value="callbackQuesnarieTime" <s:if test='%{presales.searchTimeType == "callbackQuesnarieTime"}'>selected="selected"</s:if>><s:text name="pm.presales.callbackQuesnarieTime"/></option>
                    <option value="callbackCompleteTime" <s:if test='%{presales.searchTimeType == "callbackCompleteTime"}'>selected="selected"</s:if>><s:text name="pm.presales.callbackCompleteTime"/></option>
                    <option value="endTime" <s:if test='%{presales.searchTimeType == "endTime"}'>selected="selected"</s:if>><s:text name="pm.presales.endTime"/></option>
                </select>
            </label>
            <s:textfield id="searchStartTime" name="presales.searchStartTime" cssClass="form-control" style="width: 100px; display: inline-block;" placeholder="开始时间"></s:textfield>
            <s:textfield id="searchEndTime" name="presales.searchEndTime" cssClass="form-control" style="width: 100px; display: inline-block;" placeholder="结束时间"></s:textfield>
        </div>
		<br/>
		<div class="form-group form-group-query form-group-width-1">
			<dp:fielderror accesskey="errmsg" onlyone="true" />
			<label for="projectManager">项目经理</label>
			<s:textfield id="projectManager" onblur="fillpm()" onfocus="fillpm()"
				placeholder="支持模糊搜索" cssStyle="width:163px" cssClass="form-control" />
			<s:hidden name="presales.projectManager" value="" id="pm_hide"></s:hidden>
		</div>
        <div class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="projectState"><s:text name="pm.presales.projectType"/></label>
            <s:select list="projectTypeList" name="presales.projectType" id="projectType"
                cssClass="form-control" listKey="basicDataId" listValue="basicDataName"
                headerKey="" headerValue="--请选择--" cssStyle="width:163px;"></s:select>  
        </div>
        <div class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="hasTransfer"><s:text name="pm.presales.hasTransfer"/></label>
            <s:select cssClass="form-control" list="#{0:'否', 1:'是'}" headerKey="" headerValue="--请选择--" name="presales.hasTransfer" id="hasTransfer"></s:select>  
        </div>
        <div class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="hasRma"><s:text name="pm.presales.hasRma"/></label>
            <s:select cssClass="form-control" list="#{0:'否', 1:'是'}" headerKey="" headerValue="--请选择--" name="presales.hasRma" id="hasRma"></s:select>  
        </div>
        <div id="exportDetailSelect" class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="exportDetail">导出选择</label>
            <s:select cssClass="form-control" list="#{0:'基于项目', 1:'基于设备明细', 2:'基于回访'}" headerKey="0" name="presales.exportDetail" id="hasRma"></s:select>  
        </div>
        <div class="form-group form-group-query form-group-width-1">
            <button class="btn btn-default btn-sm">
                <span class="glyphicon glyphicon-search"></span>
                查询
            </button>
        </div>
        <br>
        <div class="form-group form-group-query form-group-width-1">
            <dp:fielderror accesskey="errmsg" onlyone="true" />
            <label for="projectState">项目状态</label>
            <s:select list="projectStateList" multiple="true" id="projectState"
                cssClass="form-control" listKey="basicDataId" listValue="basicDataName" cssStyle="min-width:163px;"></s:select>
            <s:hidden name="presales.projectStates" value="%{presales.projectStates}" id="projectStates"></s:hidden>
        </div>
	</s:form>
	<!-- 蓝色箭头，项目列表 -->
	<div class="divHeader div-height">
		<img src="images/right_zhishi.gif" border="0">
		<s:text name="projectmanage.projectlist.waitcreate"></s:text>
	</div>
	
	<s:if test="user.isHasRole(13) || user.isHasRole(1) || user.isHasRole(17)">
        <a id="terminate2CloseBtn" href="javascript:void(0)" style="margin-bottom:1rem;" class="btn btn-default btn-sm">终止并关闭项目</a>
        <a id="terminate2CloseCancelBtn" href="javascript:void(0)" style="margin-bottom:1rem;display:none" class="btn btn-default btn-sm">取消</a>
        <form id="terminate2CloseForm" class="hidden" action="module/presales_terminate2Close.action" method="post">
        </form>
    </s:if>
	<div>
		<!-- 查看售前测试项目流程图 -->
		<div style="text-align: right;">
			<a id="queryPresalesView" target="_blank" href="">
				<span class="panel-heading">查看售前测试项目流程图&nbsp;</span><span class="glyphicon glyphicon-picture" style="font-size:12px; color:#428bca;"></span>
			</a>
		</div>
		<!-- 分页，项目列表 -->
			<%-- decorator="com.dp.plat.decorators.Wrapper" --%>
		<display:table id="presalesTable" name="presalesList" pagesize="${displayParam.pagesize }"
			export="true" size="${displayParam.totalcount }" sort="external"
			requestURI="module/presales_list.action"
            decorator="com.dp.plat.decorators.PresalesDecorator" 
			class="table table-striped" partialList="true">
			<s:if test="user.isHasRole(13) || user.isHasRole(1) || user.isHasRole(17)">
			<display:column title="<input type='checkbox' id='checkall'>" class="presalesIds hidden" headerClass="presalesIds hidden" media="html">
		        <input name="presalesIds" value="${presalesTable.presalesId}" type="checkbox">
			</display:column>
			</s:if>
			<display:column property="presalesCode" titleKey="pm.presales.projectcode"></display:column>
			<display:column property="projectName" titleKey="pm.presales.projectname"></display:column>
			<display:column property="projectTypeName" titleKey="pm.presales.projectType"></display:column>
			<display:column titleKey="pm.presales.hasTransfer" media="html">
                ${presalesTable.hasTransfer == 1 ? '是' : '否'}
            </display:column>
            <display:column title="项目是否发生借转销" media="excel">
                ${presalesTable.hasTransfer == 1 ? '是' : '否'}
            </display:column>
            <display:column titleKey="pm.presales.hasRma" media="html">
                ${presalesTable.hasRma == 1 ? '是' : '否'}
            </display:column>
            <display:column title="项目是否未全部核销" media="excel">
                ${presalesTable.hasRma == 1 ? '是' : '否'}
            </display:column>
			<!-- excel导出字段Start -->
			<display:column property="marketName" titleKey="pm.presales.marketname" media="excel" ></display:column>
			<display:column property="systemName" titleKey="pm.presales.systemname" media="excel"></display:column>
			<display:column property="expendName" titleKey="pm.presales.expendName" media="excel"></display:column>
			<display:column property="industryName" titleKey="pm.presales.industryName" media="excel"></display:column>
			<!-- excel导出字段End -->
			
			<display:column property="officeName" titleKey="pm.presales.officeName"></display:column>
			<display:column property="salesman" titleKey="pm.presales.salesman"></display:column>
			<display:column property="applyTime" titleKey="pm.presales.applyTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="html"></display:column>
			<display:column property="projectStateName" titleKey="pm.project.state" media="html"></display:column>
            
            <display:column property="projectManagerName" titleKey="pm.presales.pm"></display:column>
			<display:column titleKey="sys.write" property="presalesWrapper" media="html"></display:column>
			
			<!-- excel导出字段 Start-->
			<display:column property="applyTime" titleKey="pm.presales.applyTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
            <display:column property="endTime" titleKey="pm.presales.endTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
            <display:column property="projectStateName" titleKey="pm.project.state" media="excel"></display:column>
            <display:column property="taskTypeName" title="工程计划状态" media="excel"></display:column>
            <display:column property="isUpload" title="是否上传交付件" media="excel"></display:column>
            <display:column property="deliverableType" title="交付件类型" media="excel"></display:column>
            <s:if test="%{presales.exportDetail == 1}">
                <display:column property="productFirstName" titleKey="pm.ps.pro.fisrtname" media="excel"></display:column>
                <display:column property="productTypeName" titleKey="pm.ps.pro.typename" media="excel"></display:column>
                <display:column property="itemCode" titleKey="pm.ps.pro.itemcode" media="excel"></display:column>
    			<display:column property="itemModel" titleKey="pm.ps.pro.itemmodel" media="excel"></display:column>
                <display:column property="productNum" title="该次测试产品配置数量" media="excel"></display:column>
                <display:column property="orderQty" title="项目订单数" media="excel"></display:column>
                <display:column property="dlvQty" title="项目发货数" media="excel"></display:column>
                <display:column property="rmaQty" title="项目核销数" media="excel"></display:column>
                <display:column title="项目未核销数" media="excel">${presalesTable.dlvQty - presalesTable.rmaQty}</display:column>
                <display:column property="deliveryDate" titleKey="pm.ps.pro.deliveryDate" format="{0,date,yyyy-MM-dd}"></display:column>
                <display:column property="rmaDate" titleKey="pm.ps.pro.rmaDate" format="{0,date,yyyy-MM-dd}"></display:column>
                <display:column property="lendPeriod" titleKey="pm.ps.pro.lendPeriod"></display:column>
            </s:if>
            <s:elseif test="%{presales.exportDetail == 2}">
                <display:column property="callbackStartTime" titleKey="pm.presales.testCompleteTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
                <display:column property="callbackQuesnarieTime" titleKey="pm.presales.callbackQuesnarieTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
                <display:column property="callbackEndTime" titleKey="pm.presales.callbackCompleteTime" format="{0,date,yyyy-MM-dd HH:mm:ss}" media="excel"></display:column>
                <display:column property="closeRemark" title="直接闭环备注" media="excel"></display:column>
                <display:column property="expendPresalesQuesResult" title="${presales.questionColumns.tableQuestionHeader}" headerScope="splitCell=true"></display:column>
            </s:elseif>
            <s:else>
                <display:column property="applyDuration" titleKey="pm.presales.applyDuration" media="excel"></display:column>
                <display:column property="totalDuration" titleKey="pm.presales.totalDuration" media="excel"></display:column>
                <display:column property="serviceDuration" titleKey="pm.presales.serviceDuration" media="excel"></display:column>
                <display:column property="programDuration" titleKey="pm.presales.programDuration" media="excel"></display:column>
                <display:column property="testDuration" titleKey="pm.presales.testDuration" media="excel"></display:column>
                <s:if test="%{user.isHasRole(1) || user.isHasRole(10) || user.isHasRole(13) || user.isHasRole(14) || user.isHasRole(17)}">
                <display:column property="callbackDuration" titleKey="pm.presales.callbackDuration" media="excel"></display:column>
                </s:if>
                <display:column property="closeRemark" title="直接闭环备注" media="excel"></display:column>
            </s:else>
            <display:setProperty name="export.excel.filename" value="售前测试清单-${presales.exportDetail == '1' ?  '基于设备明细' : (presales.exportDetail == '2' ? '基于回访' : '基于项目') }.xls" />
            <!-- excel导出字段 End-->
		</display:table>
	</div>	
</body>
</html>