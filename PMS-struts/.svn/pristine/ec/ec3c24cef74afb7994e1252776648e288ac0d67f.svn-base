<?xml version="1.0" encoding="UTF-8"?>  
<!DOCTYPE sqlMap  
PUBLIC "-//ibatis.apache.org//DTD SQL MAP 2.0//EN"  
"http://ibatis.apache.org/dtd/sql-map-2.dtd"> 
<!-- 回访数据库操作--> 
<sqlMap>
	<typeAlias alias="CallBack" type="com.dp.plat.data.bean.CallBack"/>
	<insert id="insert_callback_info" parameterClass="CallBack">
		<![CDATA[
			INSERT INTO pm_cl_callback(projectId , remark ,applyBy ,applyTime ,createTime ,createBy ,effectiveFrom)
			VALUES( #projectId# , #remark# , #applyBy# , #applyTime# , #createTime# , #createBy# , #effectiveFrom#)
		]]>
		<selectKey resultClass="int"  keyProperty="callBackId">    
             SELECT last_insert_id() as id ;   
        </selectKey>
	</insert>
	
	<update id="update_callback_instid" parameterClass="java.util.Map">
		<![CDATA[
			UPDATE pm_cl_callback SET instId = #instId#, applyState = #applyState#, updateTime = #updateTime# ,updateBy = #updateBy# 
			WHERE id = #callBackId#
		]]>
	</update>
	<resultMap id="CallBackOne" class="CallBack">
		<result property="callBackId" column="id"/>
		<result property="projectId" column="projectId"/>
		<result property="quesnaireId" column="quesnaireId" nullValue="0"/>
		<result property="instId" column="instId"/>
		<result property="remark" column="remark"/>
		<result property="applyState" column="applyState"/>
		<result property="applyBy" column="applyBy"/>
		<result property="applyTime" column="applyTime"/>
		<result property="taskId" column="taskId"/>
	</resultMap>
	<select id="query_callback_byId" parameterClass="int" resultMap="CallBackOne">
		<![CDATA[
			SELECT t1.id , t1.projectId,t1.instId ,t1.remark,t1.applyState , MAX(t2.id) AS quesnaireId ,t1.applyBy ,t1.applyTime,
			MAX( CONVERT(t2.taskId , SIGNED)) AS taskId  FROM pm_cl_callback t1
			LEFT JOIN  pm_cl_callback_quesnaire t2  ON t1.`id` = t2.`callBackId`
			WHERE t1.id = #callBackId#
		]]>
	</select>
	<typeAlias alias="CallBackQuesnaire" type="com.dp.plat.data.bean.CallBackQuesnaire"/>
	<insert id="insert_callback_quesnaire" parameterClass="CallBackQuesnaire">
		<![CDATA[
			INSERT INTO pm_cl_callback_quesnaire(callBackId , taskId ,quesnaireId , quesnaireVersion ,quesnaireState ,createBy ,createTime ,effectiveFrom )
			values( #callBackId# , #taskId# , #quesnaireId#, #quesnaireVersion# , #quesnaireState# , #createBy# , #createTime# ,#effectiveFrom#)
		]]>
	</insert>
	<select id="query_cb_quesnaire_version" parameterClass="int" resultClass="int">
		<![CDATA[
			SELECT COUNT(*) FROM pm_cl_callback_quesnaire WHERE callBackId = #callBackId#
		]]>
	</select>
	
	<select id="query_callback_quesnaire" parameterClass="int" resultClass="CallBackQuesnaire">
		<![CDATA[
			SELECT * FROM pm_cl_callback_quesnaire WHERE id = #quesnaireId#
		]]>
	</select>
	<select id="query_quesnaire_template_id" parameterClass="int" resultClass="int">
		<![CDATA[
			SELECT 	quesnaireTemplateHeaderId FROM `pm_cl_quesnaire_result_header` WHERE id = #quesnaireId#
		]]>
	</select>
	<select id="query_callbackQuesnaireId" parameterClass="CallBack" resultClass="int">
		<![CDATA[
			SELECT id FROM pm_cl_callback_quesnaire WHERE callBackId = #callBackId# AND taskId = #taskId#
		]]>
	</select>
	<update id="update_callback_quesnaire" parameterClass="java.util.Map" >
		<![CDATA[
			UPDATE pm_cl_callback_quesnaire SET quesnaireId = #quesnaireId#, quesnaireState = #quesnaireState# WHERE id = #id#
		]]>
	</update>
	
	<update id="update_callback_applyState" parameterClass="java.util.Map">
		<![CDATA[
			update pm_cl_callback set applyState = #applyState#,updateTime = #updateTime#,
			updateBy = #updateBy# where id = #id#
		]]>
	</update>
	<typeAlias alias="CallBackComment" type="com.dp.plat.data.bean.CallBackComment"/>
	<resultMap class="CallBackComment" id="CallBackCommentMap">
		<result property="objId" column="objId"/>
		<result property="procdefKey" column="procdefKey"/>
		<result property="taskId" column="taskId"/>
		<result property="instId" column="instId"/>
		<result property="assignee" column="assignee"/>
		<result property="assigneeTime" column="assigneeTime"/>
		<result property="result" column="result"/>
		<result property="resultName" column="resultName"/>
		<result property="message" column="message"/>
		<result property="assigneeName" column="assigneeName"/>
		<result property="quesnaireId" column="quesnaireId" nullValue="0"/>
	</resultMap>
	
	<select id="query_callback_comment" parameterClass="int" resultMap="CallBackCommentMap">
		<![CDATA[
			SELECT t1.* ,t2.`basicDataName` AS resultName , CONCAT(t3.`username`,'-' , t3.`realName`) AS assigneeName ,t4.`quesnaireId` FROM fnd_act_hi_comment t1 
			LEFT JOIN fnd_basic_data t2 ON t1.`result` = t2.`basicDataId` AND t2.`dataTypeCode` = 26
			LEFT JOIN fnd_user_info t3 ON t1.`assignee` = t3.`username` 
			LEFT JOIN pm_cl_callback_quesnaire t4 ON t1.`taskId` = t4.`taskId`
			WHERE t1.`objId` = #callBackId# and t1.procdefKey = 'CallBack'
		]]>
	</select>
	<update id="update_callback" parameterClass="CallBack" >
		<![CDATA[
			UPDATE pm_cl_callback SET remark = #remark# WHERE id = #callBackId#
		]]>
	</update>
	<resultMap class="com.dp.plat.data.bean.CallBackQuesnaire" id="CallBackQuesnaireMap">
		<result property="quesnaireId" column="quesnaireId"/>
		<result property="createBy" column="createBy"/>
		<result property="createTime" column="createTime"/>
	</resultMap>
	<select id="query_is_callback" parameterClass="int" resultMap="CallBackQuesnaireMap">
		<![CDATA[
			SELECT t2.* FROM pm_cl_callback t1
			LEFT JOIN pm_cl_callback_quesnaire t2 ON t1.`id` = t2.`callBackId`  AND t2.`quesnaireState` = 1
			WHERE t1.projectId = #projectId# AND t1.applyState = 2 ORDER BY t1.applyTime DESC ,t2.`quesnaireVersion` DESC LIMIT 1
		]]>
	</select>
	<update id="update_EvaluationHeaderId_byId" parameterClass="java.util.Map" >
		<![CDATA[
			UPDATE pm_cl_quesnaire_result_header SET evaluationHeaderId = #headerId# WHERE id = #quesnaireId#
		]]>
	</update>
	<update id="update_EvaluationHeader_NextAcceptPerson" parameterClass="java.util.Map" >
		<![CDATA[
			UPDATE 
			  pm_cl_evaluation_header
			SET
			  nextAcceptPerson = #nextAcceptPerson#,
			  nextAcceptPersonName = #nextAcceptPersonName#
			WHERE id IN 
			  (SELECT 
			    * 
			  FROM
			    (SELECT 
			      MAX(id) id 
			    FROM
			    `pm_cl_evaluation_header` t
			 	WHERE t.projectId IN ($projectIds$) 
			    	AND t.nextAcceptPerson = #oldNextAcceptPerson# 
			  	GROUP BY t.projectId) tt)
		]]>
	</update>
	
</sqlMap>