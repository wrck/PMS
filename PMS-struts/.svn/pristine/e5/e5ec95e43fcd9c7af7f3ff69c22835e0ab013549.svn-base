package com.dp.plat.type;

import java.util.ArrayList;

public class ValueList extends ArrayList<Object> implements UserParamInterface
{
    private Class<Object> type = null;
    private String spliter = null;

    public String getSpliter()
    {
        return spliter;
    }

    public void setSpliter(String spliter)
    {
        this.spliter = spliter;
    }

    /**
     * 
     */
    public ValueList(Class<Object> type)
    {
        super();
        this.type = type;
    }

    private static final long serialVersionUID = 1L;

    public String formatTo()
    {
        if(null != spliter)
        {
            StringBuffer sb = new StringBuffer();
            int count = 0;
            for(Object obj: this)
            {
                if(count != 0)
                {
                    sb.append(spliter);
                }
                count++;
                
                sb.append(obj.toString());
            }
            return sb.toString();
        }
        return "";
    }

    public boolean parseFrom(String input)
    {
        return true;
    }

    public Class<Object> getType()
    {
        return type;
    }

    public void setType(Class<Object> type)
    {
        this.type = type;
    }

    @Override
    public String toString()
    {
        return formatTo();
    }

}
