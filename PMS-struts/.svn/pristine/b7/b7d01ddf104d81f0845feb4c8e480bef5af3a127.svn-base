	/**
	 * 部署管理
	 */
	@Override
	public String execute(){
		/**流程部署信息查看**/
		listDeployment = this.workFlowService.listDeployments();
		
		/**流程定义信息查看**/
		listProcessDefinition = this.workFlowService.listProcessDefinition();
		return INPUT;
	}
	
	/**
	 * 发布流程
	 * @return
	 */
	public String newdeploy(){
		try {
			this.workFlowService.deployFlow(filename, file);
		} catch (Exception e) {
			e.printStackTrace();
			setErrmsg(ExceptionUtils.getStackTrace(e));
			return ERROR;
		}
		return 	SUCCESS;
	}
	/**
	 * 删除部署信息
	 * @return
	 */
	public String deldeployment(){
		if(StringUtils.isNotBlank(param.getDeploymentId())){
			this.workFlowService.delDeployment(param.getDeploymentId());
		}
		return SUCCESS;
	}
	/**
	 * 根据部署的流程KEY 查询流程部署的信息
	 * @return
	 */
	public String viewDeployment(){
		if(procdef == null){
			procdef = new Procdef();
		}
		procdef.setKey(procdefKey);
		procdef = workFlowService.getProcdef(procdef);
		deploymentId = procdef.getDeploymentId();
		imageName = procdef.getDgrmResouceName();
		return SUCCESS;
	}
	
	/**
	 * 查看流程图
	 * @return
	 */
	public String viewimage(){
		InputStream in = this.workFlowService.getInputStream(param.getDeploymentId(), param.getImageName());
		HttpServletResponse response = ServletActionContext.getResponse();
		try {
			OutputStream out = response.getOutputStream();
			byte[] b = new byte[1024];
			for(int len = -1;(len = in.read(b)) != -1;){
				out.write(b, 0, len);
			}
			out.close();
			in.close();
		} catch (Exception e) {
			e.printStackTrace();
		}
		return null;
	}
	/**
	 * 私有任务
	 * @return
	 * @throws Exception 
	 */
	public String selftask() throws Exception{
		User user = UserContext.getUserContext().getUser();
		if(dpActProcDesc == null){
			dpActProcDesc = new DpActProcDesc();
		}
		dpActProcDesc.setAssignee(user.getUsername());
		displayParam.getParam();
		dapdlist = workFlowService.findRunSelfTaskList(displayParam, dpActProcDesc);
		return SUCCESS;
	}
	
	/**
	 * 打开任务表单
	 * @return
	 */
	public String viewTaskForm(){
		String taskId = param.getTaskId();
		TaskFormData formData = this.workFlowService.getTaskFromData(taskId);
		String formKey = formData.getFormKey();
		String objId = this.workFlowService.getBusinessObjId(taskId);
		String formUrl =  formKey + "?param.objId=" +objId + "&param.taskId=" +taskId+"&param.canSee="+param.getCanSee()+"&dpActProcDesc.procType="+dpActProcDesc.getProcType();
		param.setFormUrl(formUrl);
		return SUCCESS;
	}
	
	/**
	 * 提交任务
	 * @return
	 */
	public String submitTask(){
		this.workFlowService.submitTask(param);
		
		String url = "";
		param.setFormUrl(url);
		return "redirect";
	}
	/**
	 * 查看当前流程图
	 */
	public String viewCurrentImage(){
		//获取流程定义
		processDefinition = workFlowService.getProcessDefinitionByTaskId(param.getTaskId());
		//获取当前活动的坐标
		map = workFlowService.getCurrentActivityCoordinates(param.getTaskId());
		return "image";
	}
	
	
	/**
	 * 管理员查看所有任务
	 * @return
	 */
	public String taskmanager(){
		
		return SUCCESS;
	}
	/**
	 * 查看已办理任务表单
	 * @return
	 */
	public String hisTaskForm(){
		String instId = param.getInstId();
		String objId = this.workFlowService.getHistBusinessObjId(param.getInstId());
		
		String formKey = this.workFlowService.getFormKey(instId);
		String formUrl =  formKey + "?param.objId=" +objId + "&param.instId=" +instId + "&param.flag=1&param.showflag=1";
		param.setFormUrl(formUrl);
		return 	SUCCESS;
	}
