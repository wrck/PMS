package com.dp.plat.data.bean;

import java.util.Date;

public class PmClosedLoopQuesnaireOpt {
	private String questionOptionsContent;
	private Date createdTime;
	private int questionOptionNum;
	private int quesnaireTemplateHeaderId; 
	private Date effectiveEndTime;
	private String createdPerson;
	private Date effectiveStartTime;
	private int id;
	private double questionOptionScore;
	private int questionId;
	private String updatedPerson;
	private Date updatedTime;
	public String getQuestionOptionsContent() {
		return questionOptionsContent;
	}
	public void setQuestionOptionsContent(String questionOptionsContent) {
		this.questionOptionsContent = questionOptionsContent;
	}
	public Date getCreatedTime() {
		return createdTime;
	}
	public void setCreatedTime(Date createdTime) {
		this.createdTime = createdTime;
	}
	public int getQuestionOptionNum() {
		return questionOptionNum;
	}
	public void setQuestionOptionNum(int questionOptionNum) {
		this.questionOptionNum = questionOptionNum;
	}
	
	public int getQuesnaireTemplateHeaderId() {
		return quesnaireTemplateHeaderId;
	}
	public void setQuesnaireTemplateHeaderId(int quesnaireTemplateHeaderId) {
		this.quesnaireTemplateHeaderId = quesnaireTemplateHeaderId;
	}
	public Date getEffectiveEndTime() {
		return effectiveEndTime;
	}
	public void setEffectiveEndTime(Date effectiveEndTime) {
		this.effectiveEndTime = effectiveEndTime;
	}
	
	public String getCreatedPerson() {
		return createdPerson;
	}
	public void setCreatedPerson(String createdPerson) {
		this.createdPerson = createdPerson;
	}
	public Date getEffectiveStartTime() {
		return effectiveStartTime;
	}
	public void setEffectiveStartTime(Date effectiveStartTime) {
		this.effectiveStartTime = effectiveStartTime;
	}
	public int getId() {
		return id;
	}
	public void setId(int id) {
		this.id = id;
	}
	public double getQuestionOptionScore() {
		return questionOptionScore;
	}
	public void setQuestionOptionScore(double questionOptionScore) {
		this.questionOptionScore = questionOptionScore;
	}
	
	public int getQuestionId() {
		return questionId;
	}
	public void setQuestionId(int questionId) {
		this.questionId = questionId;
	}
	public String getUpdatedPerson() {
		return updatedPerson;
	}
	public void setUpdatedPerson(String updatedPerson) {
		this.updatedPerson = updatedPerson;
	}
	public Date getUpdatedTime() {
		return updatedTime;
	}
	public void setUpdatedTime(Date updatedTime) {
		this.updatedTime = updatedTime;
	}
	
	
}
