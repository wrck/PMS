log4j.rootLogger=debug, Console

log4j.logger.com.ibatis=DEBUG
log4j.logger.com.ibatis.common.jdbc.SimpleDataSource=DEBUG
log4j.logger.com.ibatis.common.jdbc.ScriptRunner=DEBUG
log4j.logger.com.ibatis.sqlmap.engine.impl.SqlMapClientDelegate=DEBUG
log4j.logger.java.sql.Connection=DEBUG
log4j.logger.java.sql.Statement=DEBUG 
log4j.logger.java.sql.PreparedStatement=DEBUG 
log4j.logger.java.sql.ResultSet=error  

log4j.logger.org.springframework=error,Stdlog
log4j.logger.com.opensymphony.xwork2=error,Stdlog
log4j.logger.org.apache.struts2=error,Stdlog
log4j.logger.org.displaytag=error,Stdlog
log4j.logger.freemarker=error,Stdlog

log4j.category.debug=warn, Console
log4j.category.release=warn, Stdlog

log4j.category.velocity=warn, Console

log4j.category.task.debug=warn, Console
log4j.category.task.release=warn, Stdlog

log4j.category.db.debug=error, Console
log4j.category.db.release=error, Stddb

log4j.category.datatask.debug=warn, Console
log4j.category.datatask.release=warn, Stddatatask

#Console
log4j.appender.Console=org.apache.log4j.ConsoleAppender
log4j.appender.Console.layout=org.apache.log4j.PatternLayout
log4j.appender.Console.layout.ConversionPattern=[%c %p] %d{yyyy-MM-dd HH\:mm\:ss,SSS} \# %m\r\n

#Stdlog
log4j.appender.Stdlog=org.apache.log4j.DailyRollingFileAppender
#log4j.appender.Stdlog.File=${webapp.logpath}/stdlog.log
log4j.appender.Stdlog.DatePattern='.'yyyy-MM-dd'.log'
log4j.appender.Stdlog.append=true
log4j.appender.Stdlog.layout=org.apache.log4j.PatternLayout
log4j.appender.Stdlog.layout.ConversionPattern=[%p] %d{yyyy-MM-dd HH:mm:ss,SSS} %l # %m%n

#Stddb
log4j.appender.Stddb=org.apache.log4j.DailyRollingFileAppender
#log4j.appender.Stddb.File=${webapp.logpath}/stddb.log
log4j.appender.Stddb.DatePattern='.'yyyy-MM-dd'.log'
log4j.appender.Stddb.append=true
log4j.appender.Stddb.layout=org.apache.log4j.PatternLayout
log4j.appender.Stddb.layout.ConversionPattern=[%p] %d{yyyy-MM-dd HH:mm:ss,SSS} %l # %m%n

#Stddatatask
log4j.appender.Stddatatask=org.apache.log4j.DailyRollingFileAppender
#log4j.appender.Stddatatask.File=${webapp.logpath}/stddatatask.log
log4j.appender.Stddatatask.DatePattern='.'yyyy-MM-dd'.log'
log4j.appender.Stddatatask.append=true
log4j.appender.Stddatatask.layout=org.apache.log4j.PatternLayout
log4j.appender.Stddatatask.layout.ConversionPattern=[%p] %d{yyyy-MM-dd HH:mm:ss,SSS} %l # %m%n

