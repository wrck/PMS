package com.dp.plat.tags;

import java.beans.PropertyDescriptor;
import java.lang.reflect.Method;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.jsp.JspException;
import javax.servlet.jsp.JspWriter;
import javax.servlet.jsp.tagext.TagSupport;
import org.springframework.beans.BeanUtils;
import com.dp.plat.type.UserParamInterface;
import com.dp.plat.util.StringEscUtil;
import com.opensymphony.xwork2.util.ValueStack;

public class QueryParamsTag extends TagSupport
{
	private static final long serialVersionUID = -4144487353121992818L;
	private String param;

	public String getParam()
	{
		return param;
	}

	public void setParam(String param)
	{
		this.param = param;
	}

	public int doStartTag() throws JspException
	{
		return TagSupport.SKIP_BODY;
	}

	public int doEndTag() throws JspException
	{
		try
		{
			HttpServletRequest request = (HttpServletRequest) pageContext
					.getRequest();
			ValueStack vs = (ValueStack) request
					.getAttribute("struts.valueStack");
			JspWriter out = pageContext.getOut();
			Object sigName = (Object) vs.findValue(param);
			PropertyDescriptor[] properties = BeanUtils
					.getPropertyDescriptors(sigName.getClass());
			String queryString = "";
			for (PropertyDescriptor property : properties)
			{
				String propertyName = property.getDisplayName();
                if (propertyName.equals("class")
                        || propertyName.equals("query"))
                {
                    continue;
                }
				
				Method readMethod = property.getReadMethod();
				try
				{
					Object retVal = readMethod.invoke(sigName, new Object[]{});
					String propertyValue = Param2String(retVal);
					queryString += (param + "." + propertyName + "="
							+ StringEscUtil.urlEscape(propertyValue) + "&");
				} catch (Exception e)
				{
					e.printStackTrace();
				}
			}
			out.println("sys_addenv('" + queryString + "')");
		} catch (Exception e)
		{
			e.printStackTrace();
		}
		return TagSupport.EVAL_PAGE;
	}

	public static String Param2String(Object value)
	{
		if (null == value)
		{
			return "";
		}
		if (value instanceof UserParamInterface)
		{
			return ((UserParamInterface) value).formatTo();
		}
		return value.toString();
	}

	public void release()
	{
		super.release();
	}
}
