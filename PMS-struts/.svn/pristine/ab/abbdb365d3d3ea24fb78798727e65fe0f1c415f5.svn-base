    /* ###########################维护记录######################################## */
	//定义show、hide事件，显示设备清单、序列号明细、实际发货清单、局点信息的Tab页时触发
	(function ($) {
		  $.each(['show', 'hide'], function (i, ev) {
		    var el = $.fn[ev];
		    $.fn[ev] = function () {
		      this.trigger(ev);
		      return el.apply(this, arguments);
		    };
		  });
	})(jQuery);
	$(document).on('show',".shipmentListDiv",function() {
		if($(".shipmentListDiv form").length == 0){
			checkShipmentInfo();
