	height: 30px;
}
#displaytable1table input{
	height: 25px;
}
input[type=file]{
	display: inline-block;
}
li{
	overflow: initial;
}
td a:VISITED {
	color: #003300;
}
.rotate180 {
    transform: rotate(180deg);
}

