.txtbox{
	font: 11px Verdana, Arial, Helvetica, sans-serif;
	color: #000000;
	height:20px;
	background: #FFFFFF;
	border-top: 1px solid #CCCCCC;
	border-right: 1px solid #CCCCCC;
	border-bottom: 1px solid #CCCCCC;
	border-left: 1px solid #CCCCCC;
	position:relative;
}

.login_btn{
	background: url(../images/login/logoin_button.jpg)  left top no-repeat;
	width: 103px;
	height:29px;
	border: 0px;
	cursor:pointer;
	position:relative;
}

.login_btnen{
	background: url(../images/login/logoin_button_en.jpg)  left top no-repeat;
	width: 103px;
	height:29px;
	border: 0px;
	cursor:pointer;
	position:relative;
}

.login_bg{
	background:url("../images/login/logoin_BG.jpg");
	margin:0px auto;
}

#center {  
  margin:10% auto auto;
}  


.login_window{
	background:url("../images/login/logoin_window.png");

}

.login_windowen{
	background:url("../images/login/logoin_windowen.png");
	_filter: progid:DXImageTransform.Microsoft.AlphaImageLoader(src='images/login/logoin_windowen.png'); /* IE6 */
	_background-image: none; /* IE6 */
}

