      <bpmndi:BPMNEdge bpmnElement="approveReject" id="BPMNEdge_approveReject">
        <omgdi:waypoint x="92.0" y="282.0"></omgdi:waypoint>
        <omgdi:waypoint x="26.0" y="282.0"></omgdi:waypoint>
        <omgdi:waypoint x="26.0" y="583.0"></omgdi:waypoint>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds height="14.0" width="24.0" x="33.0" y="289.0"></omgdc:Bounds>
