package com.dp.plat.data.bean;

import java.util.Date;

/**
 * SMS系统财务收款计划
* @ClassName: ProjectPlan 
* @Description: TODO(这里用一句话描述这个类的作用) 
* @author dp 
* @date 2015年5月26日 下午6:10:36 
*
 */
public class ProjectPlan {

	private Integer id;
	private String contractNo;
	private String batchCode;
	private String basicDataName;
	private String referenceEventName;
	private Date eventPlanHappenDate;
	private int afterDaysNum;
	private Date eventActualFinishDate;
	private String marketingFeedback;
	private String attachment;
	public Integer getId() {
		return id;
	}
	public void setId(Integer id) {
		this.id = id;
	}
	public String getContractNo() {
		return contractNo;
	}
	public void setContractNo(String contractNo) {
		this.contractNo = contractNo;
	}
	public String getBatchCode() {
		return batchCode;
	}
	public void setBatchCode(String batchCode) {
		this.batchCode = batchCode;
	}
	public String getBasicDataName() {
		return basicDataName;
	}
	public void setBasicDataName(String basicDataName) {
		this.basicDataName = basicDataName;
	}
	public String getReferenceEventName() {
		return referenceEventName;
	}
	public void setReferenceEventName(String referenceEventName) {
		this.referenceEventName = referenceEventName;
	}
	public Date getEventPlanHappenDate() {
		return eventPlanHappenDate;
	}
	public void setEventPlanHappenDate(Date eventPlanHappenDate) {
		this.eventPlanHappenDate = eventPlanHappenDate;
	}
	public int getAfterDaysNum() {
		return afterDaysNum;
	}
	public void setAfterDaysNum(int afterDaysNum) {
		this.afterDaysNum = afterDaysNum;
	}
	public Date getEventActualFinishDate() {
		return eventActualFinishDate;
	}
	public void setEventActualFinishDate(Date eventActualFinishDate) {
		this.eventActualFinishDate = eventActualFinishDate;
	}
	public String getMarketingFeedback() {
		return marketingFeedback;
	}
	public void setMarketingFeedback(String marketingFeedback) {
		this.marketingFeedback = marketingFeedback;
	}
	public String getAttachment() {
		return attachment;
	}
	public void setAttachment(String attachment) {
		this.attachment = attachment;
	}
	
}
