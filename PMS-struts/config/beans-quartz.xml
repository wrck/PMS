	<bean id="SubcontractNextPaymentMailerTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
        <property name="jobDetail">
            <ref bean="SubcontractNextPaymentMailer" />
        </property>
        <!--秒 分 时 月内日期 月 周内日期 年（可选字段） -->
        <property name="cronExpression">
            <!-- 59 10 23 L * ? 每月最后一日 -->
            <value>00 25 08 * * ?</value>
        </property>
    </bean>

    <!-- 项目转包SSE付款信息同步并自动完成服务经理提交付款申请流程节点，先于项目转包余款提醒 -->
    <bean id="SubcontractPaymentAutoComplete" class="org.springframework.scheduling.quartz.JobDetailFactoryBean">
        <property name="jobClass" value="com.dp.plat.subcontract.quartz.SubcontractPaymentAutoComplete" />
        <property name="jobDataAsMap">
            <map>
                <entry key="timeout">
                    <value>work</value>
                </entry>
            </map>
        </property>
    </bean>
	<bean id="SubcontractPaymentAutoCompleteTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
        <property name="jobDetail">
            <ref bean="SubcontractPaymentAutoComplete" />
        </property>
        <!--秒 分 时 月内日期 月 周内日期 年（可选字段） -->
        <property name="cronExpression">
            <!-- <value>00 25 07 * * ?</value> -->
            <value>00 00 08,13 * * ?</value>
        </property>
    </bean> 
    <!-- 项目维护日报 -->
	<bean id="MaintenanceDailyReportMailer" class="org.springframework.scheduling.quartz.JobDetailFactoryBean">
        <property name="jobClass" value="com.dp.plat.job.MaintenanceDailyReportMailer" />
        <property name="jobDataAsMap">
