    </bean>
	<bean id="MaintenanceDailyReportMailerTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
        <property name="jobDetail">
            <ref bean="MaintenanceDailyReportMailer" />
        </property>
        <!--秒 分 时 月内日期 月 周内日期 年（可选字段） -->
        <property name="cronExpression">
            <!-- <value>00 25 07 * * ?</value> -->
            <value>00 00 02 * * ?</value>
        </property>
    </bean> 
    <!-- 总调配中心 -->
    <bean class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
        <property name="triggers">
            <list>
                <!-- <ref bean="ReportTaskTrigger" />
                <ref bean="TaskBySmsTrigger" />
                <ref bean="MailTrigger" />
                <ref bean="GainOrderBySAPTrigger" />
                <ref bean="GainPersonByOATrigger" />
                <ref bean="SubcontractNextPaymentMailerTrigger" />
                <ref bean="ProjectInspectionMailerTrigger" />
                <ref bean="ProjectArrivalDelayMailerTrigger" />
                <ref bean="SubcontractPaymentAutoCompleteTrigger" />
                <ref bean="MaintenanceDailyReportMailerTrigger" />
                <ref bean="CloseNotTrackProjectTrigger" />  -->

                <!-- <ref bean="PrjArrivalReceiptMailerTrigger" /> -->
                <!-- <ref bean="PrjPreAndFinalInspectionMailerTrigger" />  -->
                
                <!-- <ref bean="ReportTaskTrigger"/> 从SMS系统获取信息 <ref bean="TaskBySmsTrigger"/> 
                    检测邮件 <ref bean="MailTrigger"/> 合同订单数据 <ref bean="GainOrderBySAPTrigger"/> 
                    OA人员信息 <ref bean="GainPersonByOATrigger"/> -->
            </list>
        </property>
    </bean>
</beans>