<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0 //EN"
 "http://ibatis.apache.org/dtd/sql-map-2.dtd">
<sqlMap namespace="project">
	<sql id="sqlItemGroups">
        <dynamic prepend=" " open="(" close=")">
            <isNotEmpty prepend="AND" property="itemGroups[].itemCodeLike">
                fi.`item` LIKE #itemGroups[].itemCodeLike#
            </isNotEmpty>
            <isNotEmpty prepend="AND" property="itemGroups[].itemModelLike">
                fi.`itemName` LIKE #itemGroups[].itemModelLike#
            </isNotEmpty>
            <isNotEmpty prepend="AND" property="itemGroups[].itemDescLike">
                fi.`describe_` LIKE #itemGroups[].itemDescLike#
            </isNotEmpty>
            
            <isNotEmpty prepend="AND" property="itemGroups[].itemCodeIn">
                <iterate property="itemGroups[].itemCodeIn" conjunction="," open="fi.item IN (" close=")">
                    #itemGroups[].itemCodeIn[]#
                </iterate>
            </isNotEmpty>
            <isNotEmpty prepend="AND" property="itemGroups[].itemModelIn">
                <iterate property="itemGroups[].itemModelIn" conjunction="," open="fi.itemName IN (" close=")">
                    #itemGroups[].itemModelIn[]#
                </iterate>
            </isNotEmpty>
            
            <isNotEmpty prepend="AND" property="itemGroups[].itemCodeNotIn">
                <iterate property="itemGroups[].itemCodeNotIn" conjunction="," open="fi.item Not IN (" close=")">
                    #itemGroups[].itemCodeNotIn[]#
                </iterate>
            </isNotEmpty>
            <isNotEmpty prepend="AND" property="itemGroups[].itemModelNotIn">
                <iterate property="itemGroups[].itemModelNotIn" conjunction="," open="fi.itemName Not IN (" close=")">
                    #itemGroups[].itemModelNotIn[]#
                </iterate>
            </isNotEmpty>
            
            <isNotEmpty prepend="AND" property="itemGroups[].orGroups">
                <iterate property="itemGroups[].orGroups" conjunction="AND" open="(" close=")">
                    <include refid="sqlItemGroupsOrGroups" />
                </iterate>
            </isNotEmpty>
        </dynamic>
    </sql>
    
