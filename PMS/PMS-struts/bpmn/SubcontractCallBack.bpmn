      <bpmndi:BPMNEdge bpmnElement="sid-352AE2AF-4B02-440A-8587-1B5D6099077B" id="BPMNEdge_sid-352AE2AF-4B02-440A-8587-1B5D6099077B">
        <omgdi:waypoint x="72.0" y="386.0"></omgdi:waypoint>
        <omgdi:waypoint x="72.0" y="410.0"></omgdi:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="callbackValid" id="BPMNEdge_callbackValid">
