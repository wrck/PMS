<TABLE class="menuTopMargin" cellSpacing="0" cellPadding="0" align="center" border="0">
  <TR>
    <TD vAlign="top" align="left">
      <TABLE class="menuTitleCell" cellSpacing="0" cellPadding="0" width="100%" border="0">
        <TR>
          <TD class="menuTitle" width="152"><IMG hspace="4" src="$imgurl" height="16" align="middle" /></TD>
          <TD class="menuTitle" align="left" vAlign="middle" width="100%">$title</TD>
          <TD class="menuTitle" vAlign="middle" align="center" width="30"></TD>
        </TR>
      </TABLE>
      <DIV style="DISPLAY: block">
        <TABLE cellSpacing="0" cellPadding="0" width="100%" border="0">
          <TR>
            <TD class="menuCell">
              <TABLE class="menuList" cellSpacing="0" cellPadding="0" width="100%" border="0">
				#foreach($li in $lis)
	                <TR onmouseover="this.className='menuHover'" onmouseout="this.className=''">
						$li.drow($pageContext)
					</TR>
					<TR>
						<TD></TD>
						<TD>
							<TABLE>
								#foreach($childli in $li.getChildlis())
									<TR onmouseover="this.className='childmenuHover'" class='childmenu' onmouseout="this.className=''">
										$childli.childdrow($pageContext)
									</TR>
								#end
							</TABLE>
						</TD>
					</TR>
				#end				
              </TABLE>
            </TD>
          </TR>
        </TABLE>
      </DIV>
    </TD>
  </TR>
</TABLE>