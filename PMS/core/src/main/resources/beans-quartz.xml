<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>
	<!-- ============================= Spring Quartz ================================ -->
	<!-- 要调用的工作类 -->
	<bean id="mailJob" class="com.dp.plat.core.schedule.MailerJob"></bean>
	<!-- 定义调用对象和调用对象的方法 -->
	<bean id="mailTask"
		class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<!-- 调用的类 -->
		<property name="targetObject">
			<ref bean="mailJob" />
		</property>
		<!-- 调用类中的方法 -->
		<property name="targetMethod">
			<value>execute</value>
		</property>
		<property name="concurrent" value="false" /><!-- 控制定时任务单线程执行，防止上次同步未执行完，本次又开始执行 -->
	</bean>
	<!-- 定义触发时间 -->
	<bean id="mailTrigger" class="org.springframework.scheduling.quartz.CronTriggerFactoryBean">
		<property name="jobDetail">
			<ref bean="mailTask" />
		</property>
		<!-- cron表达式 -->
		<property name="cronExpression">
			<!-- <value>0 0/50 * * * ?</value> -->
			<value>0 0/5 8-20 * * ?</value>
		</property>
	</bean>
	
	<!-- 总管理类 如果将lazy-init='false'那么容器启动就会执行调度程序 -->
	<bean id="startQuartz" lazy-init="false" autowire="no"
		class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
		<property name="triggers">
			<list>
			    <!-- <ref bean="incrementTrigger" />
				<ref bean="fullTrigger" />
				<ref bean="mailTrigger" /> -->
				<!-- <ref bean="copyTrigger" /> -->
				<!-- <ref bean="doTime" /> -->
			</list>
		</property>
	</bean>
	
</beans>