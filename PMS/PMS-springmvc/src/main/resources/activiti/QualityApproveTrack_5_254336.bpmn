      <bpmndi:BPMNEdge bpmnElement="sid-D2606CDC-FADC-4547-A950-046C98A220CE" id="BPMNEdge_sid-D2606CDC-FADC-4547-A950-046C98A220CE">
        <omgdi:waypoint x="625.0" y="141.0"></omgdi:waypoint>
        <omgdi:waypoint x="765.0" y="141.0"></omgdi:waypoint>
